    "faq": {
      "type": "leo-faq",
      "blocks": {
        "faq-1": {
          "type": "faq",
          "settings": {
            "question": "Will it cause bloating?",
            "answer": "<p>The first week, sometimes — your gut bacteria are adjusting. Start at half a scoop and build up over 7 days; this minimises bloating. By week 2, most people feel less bloated than before.</p>"
          }
        },
        "faq-2": {
          "type": "faq",
          "settings": {
            "question": "Can I take more than one scoop a day?",
            "answer": "<p>Stick to one scoop until you've been at it for 8+ weeks. After that, some people benefit from two — talk to your doctor if you're considering doubling up.</p>"
          }
        },
        "faq-3": {
          "type": "faq",
          "settings": {
            "question": "Can kids take it?",
            "answer": "<p>Children 6+ can take half a scoop daily. Under 6, check with your pediatrician first. Acacia fiber has been safely used in food for centuries.</p>"
          }
        },
        "faq-4": {
          "type": "faq",
          "settings": {
            "question": "Does it interact with medications?",
            "answer": "<p>Soluble fiber can slow absorption of some medications. Take Fiber Boost at least 1 hour apart from prescription medications. If on multiple meds, ask your doctor.</p>"
          }
        },
        "faq-5": {
          "type": "faq",
          "settings": {
            "question": "Is it safe with probiotics?",
            "answer": "<p>Yes — and recommended. Prebiotic fiber feeds the probiotic strains you take. Most people take fiber in the morning and probiotics with dinner, but timing isn't critical.</p>"
          }
        },
        "faq-6": {
          "type": "faq",
          "settings": {
            "question": "How long does one bag last?",
            "answer": "<p>50 daily servings — about 7 weeks at one scoop a day. Subscribe-and-save customers get auto-shipped every 6 weeks to never run out.</p>"
          }
        }
      },
