{%- comment -%}
  fk-color-cascade — sets per-product CSS variables on .fk-page wrappers.
  Render once per section file inside its wrapper (cheap; emits CSS only).
{%- endcomment -%}
{%- assign accent = product.metafields.custom.theme_accent | default: '#4F7C57' -%}
{%- assign accent_dark = product.metafields.custom.theme_accent_dark | default: '#2F5337' -%}
{%- assign accent_soft = product.metafields.custom.theme_accent_soft | default: '#DBEDDF' -%}
{%- assign accent_contrast = product.metafields.custom.theme_accent_contrast | default: '#FFF6F2' -%}
{%- assign accent_secondary = product.metafields.custom.theme_accent_secondary | default: '#DBEDDF' -%}
{%- assign accent_secondary_dark = product.metafields.custom.theme_accent_secondary_dark | default: '#1F4332' -%}
<style>
  .fk-page {
    --fk-accent: {{ accent }};
    --fk-accent-dark: {{ accent_dark }};
    --fk-accent-soft: {{ accent_soft }};
    --kit-color: {{ accent }};
    --kit-color-dark: {{ accent_dark }};
    --kit-color-soft: {{ accent_soft }};
    --kit-contrast: {{ accent_contrast }};
    --kit-secondary: {{ accent_secondary }};
    --kit-secondary-dark: {{ accent_secondary_dark }};
  }
</style>
