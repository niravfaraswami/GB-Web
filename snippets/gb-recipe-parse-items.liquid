{%- comment -%}
  Parses a chunk of HTML (typically a <ul> or <ol>) into rows of
  pipe-separated fields. Outputs the rendered HTML directly.

  Usage:
    {%- render 'gb-recipe-parse-items',
        html: ingredients_html,
        style: 'ingredient' -%}    # or 'method' or 'note'

  Each <li>field1 | field2 | field3</li> becomes a row.

  styles:
    ingredient → amount | name | desc
    method     → emoji  | title | desc
    note       → text (single field; pipes ignored)
{%- endcomment -%}

{%- liquid
  assign style = style | default: 'ingredient'
  assign chunks = html | split: '<li'
  assign idx = 0
-%}

{%- for chunk in chunks -%}
  {%- if chunk contains '</li>' -%}
    {%- assign idx = idx | plus: 1 -%}
    {%- assign tail = chunk | split: '</li>' | first -%}
    {%- assign after_open = tail | split: '>' -%}
    {%- assign after_open = after_open | shift -%}
    {%- assign inner_html = after_open | join: '>' | strip -%}
    {%- if inner_html != '' -%}
      {%- if style == 'ingredient' -%}
        {%- assign parts = inner_html | split: '|' -%}
        {%- if parts.size >= 2 -%}
          <div class="ingredient-row">
            <div class="ing-amount">{{ parts[0] | strip }}</div>
            <div>
              <div class="ing-name">{{ parts[1] | strip }}</div>
              {%- if parts.size >= 3 -%}<div class="ing-desc">{{ parts[2] | strip }}</div>{%- endif -%}
            </div>
          </div>
        {%- else -%}
          <div class="ingredient-row">
            <div class="ing-amount"></div>
            <div><div class="ing-name">{{ inner_html | strip_html | strip }}</div></div>
          </div>
        {%- endif -%}
      {%- elsif style == 'method' -%}
        {%- assign parts = inner_html | split: '|' -%}
        <div class="method-step">
          <div class="step-image">
            <span class="step-num">{{ idx }}</span>
            {%- if parts.size >= 1 -%}{{ parts[0] | strip | strip_html }}{%- endif -%}
          </div>
          <div class="step-body">
            <div class="step-title">{%- if parts.size >= 2 -%}{{ parts[1] | strip | strip_html }}{%- else -%}{{ inner_html | strip_html | strip }}{%- endif -%}</div>
            {%- if parts.size >= 3 -%}<div class="step-desc">{{ parts[2] | strip }}</div>{%- endif -%}
          </div>
        </div>
      {%- elsif style == 'note' -%}
        <div class="note-row">{{ inner_html }}</div>
      {%- endif -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}
