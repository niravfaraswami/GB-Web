{%- comment -%}
  fkv3-section-attrs — emits a style="" attribute carrying:
    • section background color
    • CSS custom properties for font sizes (eyebrow / heading / sub),
      separate desktop + mobile.
  Render INSIDE the opening tag of every fkv3 section's outer wrapper:
    <div data-kit="fermentation" class="..." {%- render 'fkv3-section-attrs' -%}>
  CSS in fermentation-kit-v3.css consumes the variables.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign bg = s.section_bg | default: '#ffffff'
  assign eyebrow_d = s.eyebrow_size_d | default: 11
  assign eyebrow_m = s.eyebrow_size_m | default: 11
  assign heading_d = s.heading_size_d | default: 44
  assign heading_m = s.heading_size_m | default: 28
  assign sub_d = s.sub_size_d | default: 16
  assign sub_m = s.sub_size_m | default: 14
-%}
 style="background: {{ bg }}; --fkv3-eyebrow-size-d: {{ eyebrow_d }}px; --fkv3-eyebrow-size-m: {{ eyebrow_m }}px; --fkv3-heading-size-d: {{ heading_d }}px; --fkv3-heading-size-m: {{ heading_m }}px; --fkv3-sub-size-d: {{ sub_d }}px; --fkv3-sub-size-m: {{ sub_m }}px;"
