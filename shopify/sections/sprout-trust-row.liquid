<section class="trust-row-section" data-kit="sprouts">
  <div class="container">
    <div class="trust-row-grid">
      {%- for block in section.blocks -%}
        <div class="tr-card" {{ block.shopify_attributes }}>
          <div class="tr-icon">{{ block.settings.icon }}</div>
          <div class="tr-h">{{ block.settings.heading }}</div>
          <div class="tr-d">{{ block.settings.description }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Sprout — Trust Row",
  "tag": "section",
  "class": "section--sprout-trust",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "trust_card",
      "name": "Trust card",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "🌱" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Trust signal" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    }
  ],
  "presets": [{ "name": "Sprout — Trust Row" }]
}
{% endschema %}
