<section class="reviews-section" data-kit="sprouts">
  <div class="container">
    <div class="section-header">
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h2>{{ section.settings.heading }}<br><em>{{ section.settings.heading_em }}</em></h2>
    </div>
    <div class="reviews-grid">
      {%- for block in section.blocks -%}
        <div class="review-card" {{ block.shopify_attributes }}>
          <div class="rev-content">
            <h3 class="rev-title">"{{ block.settings.quote }}"</h3>
            <div class="rev-foot">
              <div class="rev-stars">★★★★★</div>
              <div class="rev-name">{{ block.settings.name }}</div>
              <div class="rev-meta">{{ block.settings.meta }}</div>
            </div>
          </div>
          <div class="rev-photo">
            {%- if block.settings.photo != blank -%}
              {{ block.settings.photo | image_url: width: 800 | image_tag: loading: 'lazy', alt: block.settings.name }}
            {%- else -%}
              <span class="photo-placeholder">📷</span>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Sprout — UGC Reviews",
  "tag": "section",
  "class": "section--sprout-reviews",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "REAL RESULTS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "WHAT OUR" },
    { "type": "text", "id": "heading_em", "label": "Heading (highlighted)", "default": "CUSTOMERS SAY." }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Headline quote" },
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "text", "id": "meta", "label": "Age, city · Persona" },
        { "type": "image_picker", "id": "photo", "label": "Photo" }
      ]
    }
  ],
  "presets": [{ "name": "Sprout — UGC Reviews" }]
}
{% endschema %}
