<section class="cross-section" data-kit="sprouts">
  <div class="container">
    <div class="section-header">
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h2>{{ section.settings.heading }}<br><em>{{ section.settings.heading_em }}</em></h2>
    </div>

    {%- assign products = product.metafields.custom.cross_sell_products.value -%}
    {%- if products == blank -%}
      {%- assign products = section.settings.collection.products | default: empty -%}
    {%- endif -%}

    <div class="cs-grid">
      {%- if products != empty and products != blank -%}
        {%- for p in products limit: 3 -%}
          <div class="cs-card">
            <a href="{{ p.url }}" class="cs-img">
              {%- if p.featured_media -%}
                {{ p.featured_media | image_url: width: 800 | image_tag: loading: 'lazy', alt: p.title }}
              {%- else -%}🌱{%- endif -%}
            </a>
            <div class="cs-body">
              <div class="cs-eyebrow">{{ p.type | default: 'PAIR WITH' | upcase }}</div>
              <a href="{{ p.url }}" class="cs-h">{{ p.title }}</a>
              <div class="cs-d">{{ p.metafields.custom.short_description | default: p.description | strip_html | truncatewords: 18 }}</div>
              <div class="cs-foot">
                <div class="cs-price">{{ p.price | money }}</div>
                {%- form 'product', p, class: 'cs-atc-form' -%}
                  <input type="hidden" name="id" value="{{ p.selected_or_first_available_variant.id }}">
                  <button type="submit" class="cs-atc">Add to cart</button>
                {%- endform -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          {%- assign p = block.settings.product -%}
          {%- if p != blank -%}
            <div class="cs-card" {{ block.shopify_attributes }}>
              <a href="{{ p.url }}" class="cs-img">
                {%- if p.featured_media -%}
                  {{ p.featured_media | image_url: width: 800 | image_tag: loading: 'lazy', alt: p.title }}
                {%- else -%}🌱{%- endif -%}
              </a>
              <div class="cs-body">
                <div class="cs-eyebrow">{{ block.settings.eyebrow | default: p.type | upcase }}</div>
                <a href="{{ p.url }}" class="cs-h">{{ p.title }}</a>
                <div class="cs-d">{{ block.settings.description | default: p.description | strip_html | truncatewords: 18 }}</div>
                <div class="cs-foot">
                  <div class="cs-price">{{ p.price | money }}</div>
                  {%- form 'product', p, class: 'cs-atc-form' -%}
                    <input type="hidden" name="id" value="{{ p.selected_or_first_available_variant.id }}">
                    <button type="submit" class="cs-atc">Add to cart</button>
                  {%- endform -%}
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Sprout — Cross-sell",
  "tag": "section",
  "class": "section--sprout-cross",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "PAIR IT WITH" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "COMPLETE THE" },
    { "type": "text", "id": "heading_em", "label": "Heading (highlighted)", "default": "SPROUT KITCHEN." },
    { "type": "collection", "id": "collection", "label": "Fallback collection (used if product has no cross_sell_products metafield)" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Manual product",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow override" },
        { "type": "textarea", "id": "description", "label": "Description override" }
      ]
    }
  ],
  "presets": [{ "name": "Sprout — Cross-sell" }]
}
{% endschema %}
