<section class="reels-section" data-kit="sprouts">
  <div class="container">
    <div class="section-header">
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h2>{{ section.settings.heading }}<br><em>{{ section.settings.heading_em }}</em></h2>
    </div>
    <div class="reels-grid">
      {%- for block in section.blocks -%}
        <div class="reels-tile" {{ block.shopify_attributes }}>
          {%- if block.settings.video != blank -%}
            {{ block.settings.video | video_tag: image_size: '600x', controls: false, loop: true, muted: true, autoplay: true }}
          {%- elsif block.settings.poster != blank -%}
            {{ block.settings.poster | image_url: width: 600 | image_tag: loading: 'lazy', alt: block.settings.caption | default: 'Customer reel' }}
          {%- else -%}
            📷
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Sprout — UGC Reels",
  "tag": "section",
  "class": "section--sprout-reels",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "REAL CUSTOMERS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "SPROUTS IN" },
    { "type": "text", "id": "heading_em", "label": "Heading (highlighted)", "default": "REAL KITCHENS." }
  ],
  "blocks": [
    {
      "type": "reel",
      "name": "Reel",
      "settings": [
        { "type": "video", "id": "video", "label": "Vertical 9:16 video" },
        { "type": "image_picker", "id": "poster", "label": "Poster (fallback)" },
        { "type": "text", "id": "caption", "label": "Caption" }
      ]
    }
  ],
  "presets": [{ "name": "Sprout — UGC Reels" }]
}
{% endschema %}
