<section class="box-section" data-kit="sprouts">
  <div class="container">
    <div class="section-header">
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h2>{{ section.settings.heading }}<br><em>{{ section.settings.heading_em }}</em></h2>
    </div>
    <div class="box-grid">
      <div class="box-image">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: 'What is in the box' }}
        {%- else -%}
          🫙
        {%- endif -%}
      </div>
      <div>
        <div class="box-pills">
          {%- for block in section.blocks -%}
            <div class="box-pill" {{ block.shopify_attributes }}>
              <span class="bp-icon">{{ forloop.index }}</span>
              <span class="bp-name">{{ block.settings.name }}</span>
              <span class="bp-sub">{{ block.settings.description }}</span>
            </div>
          {%- endfor -%}
        </div>
        {%- if section.settings.note != blank -%}
          <p class="box-note">{{ section.settings.note }}</p>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Sprout — What's in the Box",
  "tag": "section",
  "class": "section--sprout-box",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "WHAT'S IN THE BOX" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "3 PARTS." },
    { "type": "text", "id": "heading_em", "label": "Heading (highlighted)", "default": "ONE KIT." },
    { "type": "image_picker", "id": "image", "label": "Box / kit image" },
    { "type": "textarea", "id": "note", "label": "Note", "default": "Just add water and a kitchen counter." }
  ],
  "blocks": [
    {
      "type": "component",
      "name": "Component",
      "settings": [
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    }
  ],
  "presets": [{ "name": "Sprout — What's in the Box" }]
}
{% endschema %}
