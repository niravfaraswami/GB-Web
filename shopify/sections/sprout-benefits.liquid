<section class="outcomes-section" data-kit="sprouts">
  <div class="container">
    <div class="section-header centered">
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h2>{{ section.settings.heading }}<br><em>{{ section.settings.heading_em }}</em></h2>
    </div>
    <div class="qb-grid">
      {%- for block in section.blocks -%}
        <div class="qb-card" {{ block.shopify_attributes }}>
          <div class="qb-icon">{{ block.settings.icon }}</div>
          <div class="qb-h">{{ block.settings.heading }}</div>
          <div class="qb-d">{{ block.settings.description }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Sprout — Benefits",
  "tag": "section",
  "class": "section--sprout-benefits",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "QUICK BENEFITS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "WHY SPROUTS ARE" },
    { "type": "text", "id": "heading_em", "label": "Heading (highlighted)", "default": "NUTRITIONAL POWERHOUSES." }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "💪" },
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    }
  ],
  "presets": [{ "name": "Sprout — Benefits" }]
}
{% endschema %}
