{%- render 'leo_kit_chrome' -%}

{%- assign enjoy_blocks = section.blocks | where: 'type', 'enjoy_card' -%}

{%- if enjoy_blocks.size > 0 or section.settings.enjoy_h != blank -%}
  <section class="eat-section ferment-pdp-leo" data-leo="1" {%- render 'leo_kit_attrs' -%}>
    <div class="container">
      <div class="section-header centered">
        <div class="eyebrow">{{ section.settings.enjoy_eyebrow }}</div>
        <h2>{{ section.settings.enjoy_h }} <em>{{ section.settings.enjoy_h_em }}</em>{{ section.settings.enjoy_h_tail }}</h2>
      </div>

      <div class="enjoy-grid">
        {%- for block in enjoy_blocks -%}
          <div class="enjoy-card" {{ block.shopify_attributes }}>
            <div class="enjoy-card-img">
              {%- if block.settings.image != blank -%}<img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="450" height="600">{%- endif -%}
            </div>
            <div class="enjoy-card-num">{{ forloop.index }}</div>
            <div class="enjoy-card-text">
              <div class="enjoy-card-h">{{ block.settings.heading }}</div>
              <div class="enjoy-card-d">{{ block.settings.description }}</div>
            </div>
          </div>
        {%- endfor -%}
      </div>

      {%- if section.settings.spoons_num != blank -%}
        <div class="spoons-strip">
          <div class="spoons-num">{{ section.settings.spoons_num }}</div>
          {%- if section.settings.spoons_label != blank -%}<div class="spoons-label">{{ section.settings.spoons_label }}</div>{%- endif -%}
          {%- if section.settings.spoons_cap != blank -%}<div class="spoons-cap">{{ section.settings.spoons_cap }}</div>{%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Leo · How To Drink",
  "tag": "section",
  "class": "leo-enjoy-section",
  "settings": [
    {
      "type": "text",
      "id": "enjoy_eyebrow",
      "label": "Eyebrow",
      "default": "HOW TO"
    },
    {
      "type": "text",
      "id": "enjoy_h",
      "label": "Heading",
      "default": "HOW TO"
    },
    {
      "type": "text",
      "id": "enjoy_h_em",
      "label": "Heading (highlighted)",
      "default": "DRINK IT"
    },
    {
      "type": "text",
      "id": "enjoy_h_tail",
      "label": "Heading (tail)",
      "default": " DAILY."
    },
    {
      "type": "text",
      "id": "spoons_num",
      "label": "Dosage — value",
      "default": "50–150"
    },
    {
      "type": "text",
      "id": "spoons_label",
      "label": "Dosage — unit label",
      "default": "ml per day"
    },
    {
      "type": "text",
      "id": "spoons_cap",
      "label": "Dosage — caption",
      "default": "Drink chilled or room temp. Don't heat."
    },
    {
      "type": "header",
      "content": "Spacing & Typography"
    },
    {
      "type": "range",
      "id": "pad_top_d",
      "label": "Padding top — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_bot_d",
      "label": "Padding bottom — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_top_m",
      "label": "Padding top — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "pad_bot_m",
      "label": "Padding bottom — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "mar_top_d",
      "label": "Margin top — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_d",
      "label": "Margin bottom — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_top_m",
      "label": "Margin top — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_m",
      "label": "Margin bottom — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "eyebrow_size_d",
      "label": "Eyebrow font size — desktop (px)",
      "min": 9,
      "max": 32,
      "step": 1,
      "default": 22
    },
    {
      "type": "range",
      "id": "eyebrow_size_m",
      "label": "Eyebrow font size — mobile (px)",
      "min": 9,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "heading_size_d",
      "label": "Heading font size — desktop (px)",
      "min": 18,
      "max": 80,
      "step": 2,
      "default": 44
    },
    {
      "type": "range",
      "id": "heading_size_m",
      "label": "Heading font size — mobile (px)",
      "min": 16,
      "max": 60,
      "step": 2,
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "enjoy_card",
      "name": "Enjoy card",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Leo · How To Drink"
    }
  ]
}
{% endschema %}
