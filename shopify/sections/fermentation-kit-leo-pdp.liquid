<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=DM+Sans:wght@400;500;600;700&family=DM+Mono:wght@400;500&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet">
{{ 'fermentation-kit.css' | asset_url | stylesheet_tag }}
{{ 'fermentation-kit-leo.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign p = product
  assign accent      = p.metafields.custom.theme_accent      | default: '#C24528'
  assign accent_dark = p.metafields.custom.theme_accent_dark | default: '#8E2E1A'
  assign accent_soft = p.metafields.custom.theme_accent_soft | default: '#FCE5DE'
-%}

<style>
  .ferment-pdp-leo {
    --kit-color: {{ accent }};
    --kit-color-dark: {{ accent_dark }};
    --kit-color-soft: {{ accent_soft }};
  }
</style>

{%- liquid
  assign tagline         = p.metafields.custom.hero_tagline | default: 'Make authentic, gut-loving ferments at home.'
  assign save_badge      = p.metafields.custom.discount_badge
  assign rating          = p.metafields.custom.rating | default: 4.8
  assign review_count    = p.metafields.custom.review_count | default: 0
  assign bought_today    = p.metafields.custom.bought_today
  assign capacity_label  = p.metafields.custom.jar_capacity | default: p.metafields.custom.capacity
  assign size_chart      = p.metafields.custom.jar_size_chart_image | default: p.metafields.custom.size_chart_image
  assign companion       = p.metafields.custom.companion_size_product.value
  assign hero_trust      = p.metafields.custom.hero_trust_strip.value
  assign cross_sell      = p.metafields.custom.cross_sell_products.value
  assign coupon_text     = p.metafields.custom.coupon_text
  assign coupon_code     = p.metafields.custom.coupon_code
  assign mf_how_video    = p.metafields.custom.how_to_make_video.value

  assign hero_benefit_blocks = section.blocks | where: 'type', 'hero_benefit'
  assign accordion_blocks    = section.blocks | where: 'type', 'hero_accordion_tab'
  assign f30_row_blocks      = section.blocks | where: 'type', 'f30_row'
  assign f30_stat_blocks     = section.blocks | where: 'type', 'f30_stat'
  assign stacks_row_blocks   = section.blocks | where: 'type', 'stacks_row'
  assign stag_card_blocks    = section.blocks | where: 'type', 'stag_card'
  assign ugc_blocks          = section.blocks | where: 'type', 'ugc_review'
  assign faq_blocks          = section.blocks | where: 'type', 'faq'
  assign cross_blocks        = section.blocks | where: 'type', 'cross_sell_product'
-%}

<div data-kit="fermentation" data-template="leo" class="ferment-pdp ferment-pdp-leo">

  {%- comment %} ============== 1. HERO ============== {% endcomment -%}
  <section class="pdp-hero">
    <div class="container">
      {%- if section.settings.show_breadcrumb -%}
        <div class="breadcrumb">
          <a href="{{ routes.root_url }}">Home</a> /
          {%- if collection -%}<a href="{{ collection.url }}">{{ collection.title }}</a> /{%- endif -%}
          <span>{{ p.title }}</span>
        </div>
      {%- endif -%}

      <div class="hero-title-block">
        <h1 class="product-name">{{ p.title }}</h1>
        <p class="product-tagline">{{ tagline }}</p>
      </div>

      <div class="hero-grid">
        <div class="gallery-stack">
          <div class="gallery-main">
            {%- if save_badge != blank -%}<span class="save-badge">{{ save_badge }}</span>{%- endif -%}
            {%- if p.featured_image -%}
              <img class="gallery-main-img"
                   src="{{ p.featured_image | image_url: width: 1200 }}"
                   srcset="{{ p.featured_image | image_url: width: 600 }} 600w, {{ p.featured_image | image_url: width: 1200 }} 1200w, {{ p.featured_image | image_url: width: 1800 }} 1800w"
                   sizes="(min-width: 768px) 50vw, 100vw"
                   alt="{{ p.featured_image.alt | default: p.title | escape }}"
                   loading="eager"
                   width="{{ p.featured_image.width }}"
                   height="{{ p.featured_image.height }}">
            {%- else -%}
              <div class="gallery-illustration">🫙</div>
            {%- endif -%}
            {%- if p.images.size > 1 -%}
              <button class="gallery-nav gallery-nav--prev" type="button" data-gallery-prev aria-label="Previous image">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
              </button>
              <button class="gallery-nav gallery-nav--next" type="button" data-gallery-next aria-label="Next image">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>
              </button>
            {%- endif -%}
          </div>
          {%- if p.images.size > 1 -%}
            <div class="gallery-thumbs">
              {%- for image in p.images limit: 8 -%}
                <button class="gallery-thumb {% if forloop.first %}active{% endif %}" type="button"
                        data-full-src="{{ image | image_url: width: 1200 }}"
                        data-full-alt="{{ image.alt | default: p.title | escape }}"
                        aria-label="View image {{ forloop.index }}">
                  <img src="{{ image | image_url: width: 180 }}" alt="{{ image.alt | default: p.title | escape }}" loading="lazy" width="90" height="90">
                </button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>

        <div class="product-info">
          {%- if review_count > 0 -%}
            <div class="rating-row">
              <span class="stars" aria-label="{{ rating }} out of 5">★★★★★</span>
              <a href="#judgeme-reviews" class="rating-link">{{ rating }} ({{ review_count }} reviews)</a>
            </div>
          {%- endif -%}

          {%- if bought_today != blank and bought_today > 0 -%}
            <div class="activity-row">
              <div class="item"><span class="dot"></span><span><strong>{{ bought_today }}</strong> people bought this today</span></div>
            </div>
          {%- endif -%}

          {%- if hero_benefit_blocks.size > 0 -%}
            <div class="benefits-block">
              <div class="label">Benefits</div>
              <div class="benefits-grid">
                {%- for block in hero_benefit_blocks -%}
                  <div class="benefit-item" {{ block.shopify_attributes }}>
                    <span class="benefit-icon-svg">
                      {%- if block.settings.icon_svg != blank -%}
                        {%- render 'kit_icon', icon: block.settings.icon_svg, size: 28 -%}
                      {%- elsif block.settings.icon_emoji != blank -%}
                        {{ block.settings.icon_emoji }}
                      {%- endif -%}
                    </span>
                    <span>{{ block.settings.label }}</span>
                  </div>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}

          {%- form 'product', p, id: 'ferment-product-form' -%}
            <div class="variant-block">
              {%- assign opt_name = p.options.first | default: 'Pack' -%}
              {%- if p.variants.size > 1 -%}
                <div class="variant-label">Select {{ opt_name }}</div>
                <div class="variant-grid variant-grid--{{ p.variants.size }}">
                  {%- for variant in p.variants -%}
                    {%- assign v_tag = variant.metafields.custom.tag -%}
                    {%- assign v_best = variant.metafields.custom.best_for -%}
                    {%- assign v_img = variant.metafields.custom.variant_illustration | default: variant.image -%}
                    {%- assign is_selected = false -%}
                    {%- if variant == p.selected_or_first_available_variant -%}{%- assign is_selected = true -%}{%- endif -%}
                    <label class="variant{% if is_selected %} active{% endif %}{% unless variant.available %} sold-out{% endunless %}"
                           data-variant-id="{{ variant.id }}"
                           data-variant-price="{{ variant.price | money }}">
                      <input type="radio" name="id" value="{{ variant.id }}" class="variant-input"
                             {% if is_selected %}checked{% endif %}
                             {% unless variant.available %}disabled{% endunless %}>
                      {%- if v_tag != blank -%}<span class="variant-tag">{{ v_tag }}</span>{%- endif -%}
                      <span class="variant-radio"></span>
                      <div class="variant-pack">{{ variant.title | upcase }}</div>
                      {%- if v_img != blank -%}
                        <div class="variant-illustration">
                          <img src="{{ v_img | image_url: width: 320 }}" alt="{{ variant.title }}" loading="lazy" width="160" height="120">
                        </div>
                      {%- endif -%}
                      {%- if v_best != blank -%}
                        <div class="variant-rationale">
                          <div class="vr-row"><span class="vr-label">BEST FOR</span><span class="vr-text">{{ v_best }}</span></div>
                        </div>
                      {%- endif -%}
                      <div class="variant-price">
                        <span>{{ variant.price | money }}</span>
                        {%- if variant.compare_at_price > variant.price -%}
                          <span class="variant-compare">{{ variant.compare_at_price | money }}</span>
                        {%- endif -%}
                      </div>
                      {%- if variant.compare_at_price > variant.price -%}
                        <span class="variant-save">You save {{ variant.compare_at_price | minus: variant.price | money }}</span>
                      {%- endif -%}
                    </label>
                  {%- endfor -%}
                </div>
              {%- else -%}
                <input type="hidden" name="id" value="{{ p.selected_or_first_available_variant.id }}">
              {%- endif -%}

              {%- if size_chart != blank or p.metafields.custom.help_note != blank -%}
                <div class="variant-help-note">
                  <span class="vhn-text">{{ p.metafields.custom.help_note | default: 'Choose the pack that fits your household.' }}</span>
                  {%- if size_chart != blank -%}
                    <button type="button" class="vhn-link" data-open-size-modal>Jar Size Chart →</button>
                  {%- endif -%}
                </div>
              {%- endif -%}

              {%- if companion -%}
                {%- assign other_capacity = companion.metafields.custom.jar_capacity | default: companion.metafields.custom.capacity | default: 'other size' -%}
                <a href="{{ companion.url }}" class="companion-link">
                  Looking for the {{ other_capacity }} version? View {{ companion.title }} →
                </a>
              {%- endif -%}
            </div>

            <button type="submit" name="add" class="atc-btn" data-atc {% unless p.available %}disabled{% endunless %}>
              {%- if p.available -%}ADD TO CART · <span data-atc-price>{{ p.price | money }}</span>{%- else -%}SOLD OUT{%- endif -%}
            </button>
          {%- endform -%}

          <div class="trust-strip">
            {%- if hero_trust != blank -%}
              {%- for t in hero_trust -%}
                <div class="item"><span class="check">✓</span> {{ t }}</div>
              {%- endfor -%}
            {%- else -%}
              <div class="item"><span class="check">✓</span> Secure Payment</div>
              <div class="item"><span class="check">✓</span> Free Shipping</div>
              <div class="item"><span class="check">✓</span> FSSAI Licensed</div>
            {%- endif -%}
          </div>

          {%- if coupon_text != blank or coupon_code != blank -%}
            <div class="coupon-bar">
              <span>{{ coupon_text }}</span>
              {%- if coupon_code != blank -%}<span class="code">{{ coupon_code }}</span>{%- endif -%}
            </div>
          {%- endif -%}

          {%- if accordion_blocks.size > 0 -%}
            <div class="hero-accordion">
              {%- for block in accordion_blocks -%}
                <div class="hero-accordion-item{% if forloop.first %} is-open{% endif %}" data-accordion {{ block.shopify_attributes }}>
                  <button class="hero-accordion-trigger" type="button" aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}">
                    <span class="hero-accordion-label">{{ block.settings.label }}</span>
                    <span class="hero-accordion-toggle" aria-hidden="true"></span>
                  </button>
                  <div class="hero-accordion-panel">{{ block.settings.body }}</div>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  {%- comment %} ============== 2. TRUST ROW ============== {% endcomment -%}
  <section class="trust-row-section">
    <div class="container">
      <div class="trust-row-grid">
        {%- for n in (1..4) -%}
          {%- assign h_key = 'trust' | append: n | append: '_h' -%}
          {%- assign d_key = 'trust' | append: n | append: '_d' -%}
          {%- assign i_key = 'trust' | append: n | append: '_icon' -%}
          {%- assign th = section.settings[h_key] -%}
          {%- assign td = section.settings[d_key] -%}
          {%- assign ti = section.settings[i_key] -%}
          {%- if th != blank -%}
            <div class="tr-card">
              <div class="tr-icon">
                {%- if ti != blank -%}{%- render 'kit_icon', icon: ti, size: 32, extra: 'gb-icon' -%}{%- endif -%}
              </div>
              <div class="tr-h">{{ th }}</div>
              <div class="tr-d">{{ td }}</div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

  {%- comment %} ============== 3. HOW TO MAKE (video + steps) ============== {% endcomment -%}
  {%- assign step_blocks = section.blocks | where: 'type', 'step' -%}
  {%- if step_blocks.size > 0 or mf_how_video != blank or section.settings.how_poster != blank -%}
    <section class="how-make-section section-accent">
      <div class="container">
        <div class="section-header centered">
          <div class="eyebrow">{{ section.settings.how_eyebrow }}</div>
          <h2>{{ section.settings.how_heading }} <em>{{ section.settings.how_heading_em }}</em></h2>
        </div>
        {%- assign how_video = mf_how_video | default: section.settings.how_video -%}
        <div class="how-make-grid">
          <div class="hm-video-hero {% if how_video != blank %}hm-video-hero--has-video{% endif %}">
            {%- if how_video != blank -%}
              {%- if how_video.sources or how_video.media_type == 'video' -%}
                {{ how_video | video_tag: image_size: '1100x', controls: false, loop: true, muted: true, autoplay: true, playsinline: true }}
              {%- else -%}
                {%- assign video_src = how_video.url | default: how_video.src -%}
                {%- if video_src != blank -%}
                  <video src="{{ video_src }}" autoplay loop muted playsinline preload="auto" style="width:100%;height:100%;object-fit:cover;"></video>
                {%- endif -%}
              {%- endif -%}
            {%- elsif section.settings.how_poster != blank -%}
              <img src="{{ section.settings.how_poster | image_url: width: 1200 }}" alt="How to make" loading="lazy" width="1200" height="1200">
            {%- else -%}
              <div class="hm-video-placeholder"><span class="hm-play">▶</span></div>
            {%- endif -%}
          </div>
          <div class="hm-steps">
            {%- for block in step_blocks -%}
              <div class="hm-step" {{ block.shopify_attributes }}>
                <div class="hm-num">{{ forloop.index }}</div>
                <div class="hm-step-body">
                  <div class="hm-title">{{ block.settings.title }}</div>
                  <div class="hm-desc">{{ block.settings.description }}</div>
                </div>
              </div>
            {%- endfor -%}
          </div>
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment %} ============== 4. FIRST 30 DAYS ============== {% endcomment -%}
  {%- if f30_row_blocks.size > 0 or section.settings.f30_h != blank -%}
    <section class="first30-section">
      <div class="container">
        <div class="first30-grid">
          <div class="first30-left">
            {%- if section.settings.f30_eyebrow != blank -%}<div class="first30-eyebrow">{{ section.settings.f30_eyebrow }}</div>{%- endif -%}
            <h2 class="first30-h">{{ section.settings.f30_h }} {%- if section.settings.f30_h_em != blank %}<em>{{ section.settings.f30_h_em }}</em>{%- endif -%}{{ section.settings.f30_h_tail }}</h2>
            {%- if section.settings.f30_intro != blank -%}<p class="first30-intro">{{ section.settings.f30_intro }}</p>{%- endif -%}

            {%- if f30_row_blocks.size > 0 -%}
              <div class="first30-rows">
                {%- for block in f30_row_blocks -%}
                  <div class="first30-row" {{ block.shopify_attributes }}>
                    <div class="f30-icon">
                      {%- if block.settings.icon_svg != blank -%}{%- render 'kit_icon', icon: block.settings.icon_svg, size: 24 -%}
                      {%- elsif block.settings.icon_emoji != blank -%}{{ block.settings.icon_emoji }}{%- endif -%}
                    </div>
                    <div class="f30-body">
                      <div class="f30-h">{{ block.settings.heading }}</div>
                      <div class="f30-d">{{ block.settings.description }}</div>
                    </div>
                  </div>
                {%- endfor -%}
              </div>
            {%- endif -%}

            {%- if f30_stat_blocks.size > 0 or section.settings.f30_stats_line != blank -%}
              <div class="first30-stats-strip">
                {%- if section.settings.f30_stats_line != blank -%}<div class="first30-stats-line">{{ section.settings.f30_stats_line }}</div>{%- endif -%}
                {%- if f30_stat_blocks.size > 0 -%}
                  <div class="first30-stats-row">
                    {%- for block in f30_stat_blocks -%}
                      <div class="first30-stat-cell" {{ block.shopify_attributes }}>
                        <div class="first30-stat-circle"><div class="first30-stat-num">{{ block.settings.num }}{%- if block.settings.num_unit != blank %}<span>{{ block.settings.num_unit }}</span>{%- endif -%}</div></div>
                        <div class="first30-stat-label">{{ block.settings.label }}</div>
                      </div>
                    {%- endfor -%}
                  </div>
                {%- endif -%}
                {%- if section.settings.f30_disclaimer != blank -%}<div class="first30-disclaimer">{{ section.settings.f30_disclaimer }}</div>{%- endif -%}
              </div>
            {%- endif -%}
          </div>

          <div class="first30-right">
            {%- if section.settings.f30_image != blank -%}
              <img src="{{ section.settings.f30_image | image_url: width: 1200 }}" alt="{{ section.settings.f30_h | escape }}" loading="lazy" width="1000" height="1250">
            {%- endif -%}
            <svg class="f30-overlay-svg" viewBox="0 0 100 125" preserveAspectRatio="none" aria-hidden="true">
              <defs>
                <filter id="f30-glow-{{ section.id }}" x="-50%" y="-50%" width="200%" height="200%">
                  <feGaussianBlur stdDeviation="1.4" result="blur"/>
                  <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                </filter>
              </defs>
              <path class="f30-curve" d="M 5 22 Q 2 45 11 66 Q 45 86 81 101" filter="url(#f30-glow-{{ section.id }})"/>
              <circle class="f30-dot" cx="5" cy="22" r="1.6" filter="url(#f30-glow-{{ section.id }})"/>
              <circle class="f30-dot" cx="11" cy="66" r="1.6" filter="url(#f30-glow-{{ section.id }})"/>
              <circle class="f30-dot" cx="81" cy="101" r="1.6" filter="url(#f30-glow-{{ section.id }})"/>
            </svg>
            {%- if section.settings.f30_anno_1 != blank -%}<div class="first30-anno a1">{{ section.settings.f30_anno_1 }}</div>{%- endif -%}
            {%- if section.settings.f30_anno_2 != blank -%}<div class="first30-anno a2">{{ section.settings.f30_anno_2 }}</div>{%- endif -%}
            {%- if section.settings.f30_anno_3 != blank -%}<div class="first30-anno a3">{{ section.settings.f30_anno_3 }}</div>{%- endif -%}
          </div>
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment %} ============== 5. STACKS COMPARISON ============== {% endcomment -%}
  {%- if stacks_row_blocks.size > 0 -%}
    <section class="stacks-section">
      <div class="container">
        <div class="section-header centered">
          <div class="eyebrow">{{ section.settings.stacks_eyebrow }}</div>
          <h2>{{ section.settings.stacks_heading }} <em>{{ section.settings.stacks_heading_em }}</em></h2>
          {%- if section.settings.stacks_intro != blank -%}<p>{{ section.settings.stacks_intro }}</p>{%- endif -%}
        </div>

        <div class="stacks-table-wrap">
        <div class="stacks-table">
          <div class="st-head">
            <div class="st-h-cell st-h-label">&nbsp;</div>
            <div class="st-h-cell st-h-kit">{{ section.settings.stacks_col_kit | default: 'GutBasket Kit' }}</div>
            <div class="st-h-cell">{{ section.settings.stacks_col_3 | default: 'Traditional Homemade' }}</div>
            <div class="st-h-cell">{{ section.settings.stacks_col_4 | default: 'Probiotic Capsule' }}</div>
          </div>

          {%- for block in stacks_row_blocks -%}
            <div class="st-row" {{ block.shopify_attributes }}>
              <div class="st-cell st-cell-label">{{ block.settings.label }}</div>
              <div class="st-cell st-cell-kit">
                {%- if block.settings.kit_mark == 'yes' -%}<span class="st-mark st-mark-yes"></span>
                {%- elsif block.settings.kit_mark == 'no' -%}<span class="st-mark st-mark-no"></span>{%- endif -%}
                {{ block.settings.kit_text }}
              </div>
              <div class="st-cell st-cell-other">
                {%- if block.settings.col3_mark == 'yes' -%}<span class="st-mark st-mark-yes"></span>
                {%- elsif block.settings.col3_mark == 'no' -%}<span class="st-mark st-mark-no"></span>{%- endif -%}
                {{ block.settings.col3_text }}
              </div>
              <div class="st-cell st-cell-other">
                {%- if block.settings.col4_mark == 'yes' -%}<span class="st-mark st-mark-yes"></span>
                {%- elsif block.settings.col4_mark == 'no' -%}<span class="st-mark st-mark-no"></span>{%- endif -%}
                {{ block.settings.col4_text }}
              </div>
            </div>
          {%- endfor -%}
        </div>
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment %} ============== 6. STAGGERED GRID INCLUDES ============== {% endcomment -%}
  {%- if stag_card_blocks.size > 0 -%}
    <section class="stag-section">
      <div class="container">
        <div class="section-header">
          <div class="eyebrow">{{ section.settings.stag_eyebrow }}</div>
          <h2>{{ section.settings.stag_heading }} <em>{{ section.settings.stag_heading_em }}</em></h2>
        </div>

        <div class="stag-grid">
          {%- for block in stag_card_blocks -%}
            {%- assign variant = block.settings.variant -%}
            {%- assign span_cls = '' -%}
            {%- if block.settings.span_row_2 -%}{%- assign span_cls = ' span-row-2' -%}{%- endif -%}
            {%- if block.settings.span_col_2 -%}{%- assign span_cls = span_cls | append: ' span-col-2' -%}{%- endif -%}

            {%- if variant == 'image_only' -%}
              <div class="stag-card stag-image-only{{ span_cls }}" {{ block.shopify_attributes }}>
                {%- if block.settings.image != blank -%}
                  {%- if block.settings.image_mobile != blank -%}
                    <picture>
                      <source media="(max-width: 768px)" srcset="{{ block.settings.image_mobile | image_url: width: 800 }}">
                      <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="800" height="800">
                    </picture>
                  {%- else -%}
                    <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="800" height="800">
                  {%- endif -%}
                {%- endif -%}
              </div>

            {%- elsif variant == 'dark' -%}
              <div class="stag-card stag-dark{{ span_cls }}" {{ block.shopify_attributes }}>
                {%- if block.settings.numeral != blank -%}<div class="stag-num">{{ block.settings.numeral }}</div>{%- endif -%}
                <div class="stag-body">
                  {%- if block.settings.eyebrow != blank -%}<span class="stag-num-small">{{ block.settings.eyebrow }}</span>{%- endif -%}
                  <div class="stag-h">{{ block.settings.heading }}</div>
                  <div class="stag-d">{{ block.settings.description }}</div>
                </div>
              </div>

            {%- elsif variant == 'dark_photo' -%}
              <div class="stag-card stag-dark stag-dark-photo{{ span_cls }}" {{ block.shopify_attributes }}>
                {%- if block.settings.image != blank -%}<img class="stag-dark-img" src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="800" height="450">{%- endif -%}
                <div class="stag-dark-content">
                  {%- if block.settings.numeral != blank -%}<div class="stag-num">{{ block.settings.numeral }}</div>{%- endif -%}
                  <div class="stag-body">
                    {%- if block.settings.eyebrow != blank -%}<span class="stag-num-small">{{ block.settings.eyebrow }}</span>{%- endif -%}
                    <div class="stag-h">{{ block.settings.heading }}</div>
                    <div class="stag-d">{{ block.settings.description }}</div>
                  </div>
                </div>
              </div>

            {%- elsif variant == 'light' -%}
              <div class="stag-card stag-light{{ span_cls }}" {{ block.shopify_attributes }}>
                <div class="stag-light-img">
                  {%- if block.settings.image != blank -%}<img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="600" height="400">{%- endif -%}
                </div>
                <div class="stag-light-body">
                  {%- if block.settings.eyebrow != blank -%}<span class="stag-pill">{{ block.settings.eyebrow }}</span>{%- endif -%}
                  <div class="stag-h">{{ block.settings.heading }}</div>
                  <div class="stag-d">{{ block.settings.description }}</div>
                </div>
              </div>

            {%- elsif variant == 'detail' -%}
              <div class="stag-card stag-detail{{ span_cls }}" {{ block.shopify_attributes }}>
                <div class="stag-detail-head">
                  <div class="stag-detail-thumb">
                    {%- if block.settings.image != blank -%}<img src="{{ block.settings.image | image_url: width: 200 }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="96" height="96">{%- endif -%}
                  </div>
                  <div class="stag-detail-titles">
                    {%- if block.settings.eyebrow != blank -%}<div class="stag-detail-eyebrow">{{ block.settings.eyebrow }}</div>{%- endif -%}
                    <div class="stag-detail-h">{{ block.settings.heading }}</div>
                  </div>
                </div>
                <ul class="stag-detail-list">
                  {%- assign lines = block.settings.bullets | newline_to_br | split: '<br />' -%}
                  {%- for line in lines -%}
                    {%- assign trimmed = line | strip -%}
                    {%- if trimmed != blank -%}<li>{{ trimmed }}</li>{%- endif -%}
                  {%- endfor -%}
                </ul>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if section.settings.stag_note != blank -%}
          <p class="stag-note-strip">{{ section.settings.stag_note }}</p>
        {%- endif -%}

        {%- if section.settings.refill_show -%}
          <div class="refill-card">
            <div class="refill-img">
              {%- if section.settings.refill_image != blank -%}<img src="{{ section.settings.refill_image | image_url: width: 800 }}" alt="{{ section.settings.refill_h | escape }}" loading="lazy" width="800" height="600">{%- endif -%}
            </div>
            <div class="refill-body">
              {%- if section.settings.refill_h != blank -%}<div class="refill-h">{{ section.settings.refill_h }}</div>{%- endif -%}
              {%- if section.settings.refill_bullets != blank -%}
                <ul class="refill-list">
                  {%- assign rl = section.settings.refill_bullets | newline_to_br | split: '<br />' -%}
                  {%- for line in rl -%}{%- assign t = line | strip -%}{%- if t != blank -%}<li>{{ t }}</li>{%- endif -%}{%- endfor -%}
                </ul>
              {%- endif -%}
              {%- if section.settings.refill_cta_label != blank -%}<a class="refill-cta" href="{{ section.settings.refill_cta_url | default: '#' }}">{{ section.settings.refill_cta_label }}</a>{%- endif -%}
            </div>
          </div>
        {%- endif -%}
      </div>
    </section>
  {%- endif -%}

  {%- comment %} ============== 7. UGC REVIEWS ============== {% endcomment -%}
  {%- if ugc_blocks.size > 0 -%}
    <section class="reviews-section" data-leo="1">
      <div class="container">
        <div class="section-header centered">
          <div class="eyebrow">{{ section.settings.reviews_eyebrow }}</div>
          <h2>{{ section.settings.reviews_heading }} <em>{{ section.settings.reviews_heading_em }}</em></h2>
        </div>
        <div class="ugc-grid">
          {%- for block in ugc_blocks -%}
            <div class="ugc-card" {{ block.shopify_attributes }}>
              <div class="ugc-card-photo">
                {%- if block.settings.photo != blank -%}<img src="{{ block.settings.photo | image_url: width: 800 }}" alt="{{ block.settings.name | escape }}" loading="lazy" width="600" height="800">{%- endif -%}
              </div>
              <div class="ugc-card-text">
                <div class="ugc-card-quote">{{ block.settings.quote }}</div>
                <div class="ugc-card-name">{{ block.settings.name }}</div>
                {%- if block.settings.meta != blank -%}<div class="ugc-card-age">{{ block.settings.meta }}</div>{%- endif -%}
              </div>
              <div class="ugc-card-spacer"></div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment %} ============== 8. SCIENCE 4×2 CHECKERBOARD ============== {% endcomment -%}
  {%- if section.settings.sci_h != blank -%}
    <section class="science-stag-section">
      <div class="container">
        <div class="section-header centered">
          <div class="eyebrow">{{ section.settings.sci_eyebrow }}</div>
          <h2>{{ section.settings.sci_h }} <em>{{ section.settings.sci_h_em }}</em></h2>
        </div>

        <div class="science-stag-grid">
          {%- comment %} Layout: stat1 · img1 · stat2 · img2 / img3 · stat3 · img4 · stat4 {% endcomment -%}
          {%- assign stat_idx = 1 -%}
          {%- assign img_idx = 1 -%}
          {%- assign order = 'stat,img,stat,img,img,stat,img,stat' | split: ',' -%}
          {%- for kind in order -%}
            {%- if kind == 'stat' -%}
              {%- assign num_key = 'sci_stat' | append: stat_idx | append: '_num' -%}
              {%- assign unit_key = 'sci_stat' | append: stat_idx | append: '_unit' -%}
              {%- assign h_key = 'sci_stat' | append: stat_idx | append: '_h' -%}
              {%- assign d_key = 'sci_stat' | append: stat_idx | append: '_d' -%}
              {%- assign img_key = 'sci_stat' | append: stat_idx | append: '_img' -%}
              {%- assign s_num = section.settings[num_key] -%}
              {%- assign s_unit = section.settings[unit_key] -%}
              {%- assign s_h = section.settings[h_key] -%}
              {%- assign s_d = section.settings[d_key] -%}
              {%- assign s_img = section.settings[img_key] -%}
              {%- if s_num != blank or s_h != blank -%}
                <div class="science-stag-card sci-stat">
                  {%- if s_img != blank -%}<img class="sci-stat-bg" src="{{ s_img | image_url: width: 800 }}" alt="{{ s_h | escape }}" loading="lazy" width="600" height="450">{%- endif -%}
                  <div class="sci-stat-eyebrow">{{ section.settings.sci_stat_eyebrow | default: 'REPORTED' }}</div>
                  <div>
                    <div class="sci-stat-num">{{ s_num }}{%- if s_unit != blank %}<span>{{ s_unit }}</span>{%- endif -%}</div>
                    <div class="sci-stat-h">{{ s_h }}</div>
                    <div class="sci-stat-d">{{ s_d }}</div>
                  </div>
                </div>
              {%- endif -%}
              {%- assign stat_idx = stat_idx | plus: 1 -%}
            {%- else -%}
              {%- assign img_key = 'sci_img' | append: img_idx -%}
              {%- assign s_img = section.settings[img_key] -%}
              {%- if s_img != blank -%}
                <div class="science-stag-card sci-image">
                  <img src="{{ s_img | image_url: width: 800 }}" alt="Science image {{ img_idx }}" loading="lazy" width="600" height="450">
                </div>
              {%- endif -%}
              {%- assign img_idx = img_idx | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if section.settings.sci_caption != blank -%}<div class="science-stag-caption">{{ section.settings.sci_caption }}</div>{%- endif -%}
        {%- if section.settings.sci_disclaimer != blank -%}<div class="science-stag-disclaimer">{{ section.settings.sci_disclaimer }}</div>{%- endif -%}
      </div>
    </section>
  {%- endif -%}

  {%- comment %} ============== 9. ENJOY (HOW TO DRINK) ============== {% endcomment -%}
  {%- assign enjoy_blocks = section.blocks | where: 'type', 'enjoy_card' -%}
  {%- if enjoy_blocks.size > 0 or section.settings.enjoy_h != blank -%}
    <section class="eat-section" data-leo="1">
      <div class="container">
        <div class="section-header centered">
          <div class="eyebrow">{{ section.settings.enjoy_eyebrow }}</div>
          <h2>{{ section.settings.enjoy_h }} <em>{{ section.settings.enjoy_h_em }}</em>{{ section.settings.enjoy_h_tail }}</h2>
        </div>

        <div class="enjoy-grid">
          {%- for block in enjoy_blocks -%}
            <div class="enjoy-card" {{ block.shopify_attributes }}>
              <div class="enjoy-card-img">
                {%- if block.settings.image != blank -%}<img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="450" height="600">{%- endif -%}
              </div>
              <div class="enjoy-card-num">{{ forloop.index }}</div>
              <div class="enjoy-card-text">
                <div class="enjoy-card-h">{{ block.settings.heading }}</div>
                <div class="enjoy-card-d">{{ block.settings.description }}</div>
              </div>
            </div>
          {%- endfor -%}
        </div>

        {%- if section.settings.spoons_num != blank -%}
          <div class="spoons-strip">
            <div class="spoons-num">{{ section.settings.spoons_num }}</div>
            {%- if section.settings.spoons_label != blank -%}<div class="spoons-label">{{ section.settings.spoons_label }}</div>{%- endif -%}
            {%- if section.settings.spoons_cap != blank -%}<div class="spoons-cap">{{ section.settings.spoons_cap }}</div>{%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </section>
  {%- endif -%}

  {%- comment %} ============== 10. RECIPES ============== {% endcomment -%}
  {%- assign recipe_blocks = section.blocks | where: 'type', 'recipe_item' -%}
  {%- if section.settings.recipe_banner != blank or section.settings.recipe_count != blank or recipe_blocks.size > 0 -%}
    <section class="recipes-section" data-leo="1">
      <div class="container">
        <div class="section-header">
          <div class="eyebrow">{{ section.settings.recipes_eyebrow }}</div>
          <div class="recipes-h-row">
            {%- if section.settings.recipe_count != blank -%}<div class="recipes-num">{{ section.settings.recipe_count }}</div>{%- endif -%}
            <div class="recipes-h-text"><em>{{ section.settings.recipe_h_label }}</em> <span>{{ section.settings.recipe_h_text }}</span></div>
          </div>
        </div>
        {%- if section.settings.recipe_banner != blank -%}
          <div class="recipes-banner"><img src="{{ section.settings.recipe_banner | image_url: width: 1600 }}" alt="Recipes" loading="lazy" width="1600" height="700"></div>
        {%- endif -%}
        {%- if recipe_blocks.size > 0 -%}
          <div class="recipes-grid">
            {%- for block in recipe_blocks -%}
              {%- if block.settings.url != blank -%}
                <a class="recipe-item" href="{{ block.settings.url }}" {{ block.shopify_attributes }}>
              {%- else -%}
                <div class="recipe-item" {{ block.shopify_attributes }}>
              {%- endif -%}
                <div class="recipe-item-img">
                  {%- if block.settings.image != blank -%}<img src="{{ block.settings.image | image_url: width: 500 }}" alt="{{ block.settings.name | escape }}" loading="lazy" width="400" height="300">{%- endif -%}
                </div>
                <div class="recipe-item-body">
                  <div class="recipe-item-name">{{ block.settings.name }}</div>
                  {%- if block.settings.description != blank -%}<div class="recipe-item-d">{{ block.settings.description }}</div>{%- endif -%}
                </div>
              {%- if block.settings.url != blank -%}</a>{%- else -%}</div>{%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </section>
  {%- endif -%}

  {%- comment %} ============== 11. FAQ ============== {% endcomment -%}
  {%- if faq_blocks.size > 0 -%}
    <section class="faq-section">
      <div class="container">
        <div class="section-header centered">
          <div class="eyebrow">{{ section.settings.faq_eyebrow }}</div>
          <h2>{{ section.settings.faq_heading }} <em>{{ section.settings.faq_heading_em }}</em></h2>
        </div>
        <div class="faq-list">
          {%- for block in faq_blocks -%}
            <div class="faq-item {% if forloop.first %}open{% endif %}" data-faq {{ block.shopify_attributes }}>
              <div class="faq-q"><span>{{ block.settings.question }}</span><span class="faq-toggle">+</span></div>
              <div class="faq-a">{{ block.settings.answer }}</div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment %} ============== 12. CROSS-SELL ============== {% endcomment -%}
  {%- assign show_cross = false -%}
  {%- if cross_sell != blank or cross_blocks.size > 0 or section.settings.cross_collection != blank -%}{%- assign show_cross = true -%}{%- endif -%}
  {%- if show_cross -%}
    <section class="cross-section">
      <div class="container">
        <div class="section-header centered">
          <div class="eyebrow">{{ section.settings.cross_eyebrow }}</div>
          <h2>{{ section.settings.cross_heading }}</h2>
        </div>
        <div class="cross-grid">
          {%- if cross_sell != blank -%}
            {%- for cp in cross_sell limit: 3 -%}{%- render 'ferment_cross_card', p: cp -%}{%- endfor -%}
          {%- elsif cross_blocks.size > 0 -%}
            {%- for block in cross_blocks -%}{%- if block.settings.product != blank -%}{%- render 'ferment_cross_card', p: block.settings.product, attrs: block.shopify_attributes -%}{%- endif -%}{%- endfor -%}
          {%- elsif section.settings.cross_collection.products.size > 0 -%}
            {%- for cp in section.settings.cross_collection.products limit: 3 -%}{%- render 'ferment_cross_card', p: cp -%}{%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment %} ============== 13. JUDGE.ME ============== {% endcomment -%}
  {%- if section.settings.show_judgeme -%}
    <section class="judgeme-section" id="judgeme-reviews">
      <div class="container">
        <div class="section-header centered">
          <div class="eyebrow">{{ section.settings.judgeme_eyebrow }}</div>
          <h2>{% if review_count > 0 %}{{ review_count }} {% endif %}{{ section.settings.judgeme_heading }} <em>{{ section.settings.judgeme_heading_em }}</em></h2>
        </div>
        {%- if section.settings.judgeme_embed != blank -%}{{ section.settings.judgeme_embed }}
        {%- else -%}<div class="jdgm-widget jdgm-review-widget" data-id="{{ p.id }}"></div>{%- endif -%}
      </div>
    </section>
  {%- endif -%}

  {%- comment %} JAR SIZE MODAL {% endcomment -%}
  {%- if size_chart != blank -%}
    <div class="size-modal" id="jar-size-modal" data-size-modal>
      <div class="size-modal-card">
        <button type="button" class="size-modal-close" data-close-size-modal aria-label="Close">×</button>
        <div class="size-modal-eyebrow">JAR SIZE COMPARISON</div>
        <h3 class="size-modal-title">{{ capacity_label | default: p.title }}</h3>
        <div class="size-modal-image"><img src="{{ size_chart | image_url: width: 1200 }}" alt="Size chart" loading="lazy" width="1200" height="900"></div>
      </div>
    </div>
  {%- endif -%}

</div>

<script>
  (function () {
    function init(scope) {
      var root = scope || document;
      var pdp = root.querySelector ? (root.matches && root.matches('.ferment-pdp-leo') ? root : root.querySelector('.ferment-pdp-leo')) : null;
      if (!pdp) return;

      pdp.querySelectorAll('[data-faq]').forEach(function (i) {
        if (i.dataset.bound) return;
        i.dataset.bound = '1';
        i.addEventListener('click', function () { i.classList.toggle('open'); });
      });

      pdp.querySelectorAll('[data-accordion]').forEach(function (i) {
        if (i.dataset.bound) return;
        i.dataset.bound = '1';
        var trigger = i.querySelector('.hero-accordion-trigger');
        if (trigger) trigger.addEventListener('click', function () {
          var open = i.classList.toggle('is-open');
          trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
        });
      });

      var modal = pdp.querySelector('[data-size-modal]');
      if (modal && !modal.dataset.bound) {
        modal.dataset.bound = '1';
        pdp.querySelectorAll('[data-open-size-modal]').forEach(function (b) { b.addEventListener('click', function () { modal.classList.add('open'); }); });
        modal.addEventListener('click', function (e) { if (e.target === modal || (e.target.closest && e.target.closest('[data-close-size-modal]'))) modal.classList.remove('open'); });
      }

      var grid = pdp.querySelector('.variant-grid');
      var atcPrice = pdp.querySelector('[data-atc-price]');
      if (grid && !grid.dataset.bound) {
        grid.dataset.bound = '1';
        grid.addEventListener('change', function (e) {
          if (!e.target.classList.contains('variant-input')) return;
          grid.querySelectorAll('.variant').forEach(function (v) { v.classList.remove('active'); });
          var card = e.target.closest('.variant');
          if (card) { card.classList.add('active'); if (atcPrice && card.dataset.variantPrice) atcPrice.textContent = card.dataset.variantPrice; }
          try { var u = new URL(window.location.href); u.searchParams.set('variant', e.target.value); history.replaceState({}, '', u); } catch (err) {}
        });
      }

      // Inline SVG icons + recolor pass (re-uses cache from base section if loaded)
      window.__gbSvgCache = window.__gbSvgCache || {};
      function recolorSvg(svgRoot) {
        if (!svgRoot) return;
        var rgb = function (s) { var m = String(s).match(/rgba?\((\d+),\s*(\d+),\s*(\d+)/); return m ? [+m[1], +m[2], +m[3]] : null; };
        var lightnessOf = function (c) { return (Math.max(c[0], c[1], c[2]) + Math.min(c[0], c[1], c[2])) / 2 / 255; };
        svgRoot.querySelectorAll('*').forEach(function (el) {
          var cs = getComputedStyle(el);
          var fillC = rgb(cs.fill);
          var strokeC = rgb(cs.stroke);
          if (cs.fill && cs.fill !== 'none' && fillC && cs.fill !== 'rgba(0, 0, 0, 0)') {
            el.setAttribute('data-fill-tone', lightnessOf(fillC) > 0.7 ? 'light' : 'dark');
          }
          if (cs.stroke && cs.stroke !== 'none' && strokeC && cs.stroke !== 'rgba(0, 0, 0, 0)') {
            el.setAttribute('data-has-stroke', '1');
          }
        });
      }
      pdp.querySelectorAll('.kit-icon-svg[data-svg-src]').forEach(function (el) {
        if (el.dataset.svgBound) return;
        el.dataset.svgBound = '1';
        var src = el.getAttribute('data-svg-src');
        if (!src) return;
        var setMarkup = function (txt) {
          var clean = String(txt).replace(/<\?xml[^?]*\?>\s*/, '').replace(/<!DOCTYPE[^>]*>\s*/i, '');
          el.innerHTML = clean;
          el.removeAttribute('data-svg-src');
          requestAnimationFrame(function () { recolorSvg(el.querySelector('svg')); });
        };
        var cached = window.__gbSvgCache[src];
        if (typeof cached === 'string') { setMarkup(cached); return; }
        if (cached && cached.then) { cached.then(setMarkup); return; }
        var pr = fetch(src).then(function (r) { return r.text(); }).then(function (txt) { window.__gbSvgCache[src] = txt; return txt; });
        window.__gbSvgCache[src] = pr;
        pr.then(setMarkup).catch(function () {});
      });

      // Gallery thumbs
      var mainImg = pdp.querySelector('.gallery-main-img');
      var thumbs = pdp.querySelectorAll('.gallery-thumb');
      function activateThumb(t) {
        var s = t.getAttribute('data-full-src');
        var a = t.getAttribute('data-full-alt');
        if (!s || !mainImg) return;
        mainImg.removeAttribute('srcset'); mainImg.removeAttribute('sizes');
        mainImg.setAttribute('src', s); if (a) mainImg.setAttribute('alt', a);
        thumbs.forEach(function (x) { x.classList.remove('active'); });
        t.classList.add('active');
      }
      function step(delta) {
        if (!thumbs.length) return;
        var current = 0;
        thumbs.forEach(function (x, i) { if (x.classList.contains('active')) current = i; });
        var next = (current + delta + thumbs.length) % thumbs.length;
        activateThumb(thumbs[next]);
      }
      if (mainImg && thumbs.length) {
        thumbs.forEach(function (t) {
          if (t.dataset.bound) return;
          t.dataset.bound = '1';
          t.addEventListener('click', function (e) { e.preventDefault(); activateThumb(t); });
        });
        var prevBtn = pdp.querySelector('[data-gallery-prev]');
        var nextBtn = pdp.querySelector('[data-gallery-next]');
        if (prevBtn && !prevBtn.dataset.bound) { prevBtn.dataset.bound = '1'; prevBtn.addEventListener('click', function (e) { e.preventDefault(); step(-1); }); }
        if (nextBtn && !nextBtn.dataset.bound) { nextBtn.dataset.bound = '1'; nextBtn.addEventListener('click', function (e) { e.preventDefault(); step(1); }); }
      }
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', function () { init(); }); else init();
    document.addEventListener('shopify:section:load', function (e) { init(e.target); });
  })();
</script>

{% schema %}
{
  "name": "Fermentation Kit Leo PDP",
  "tag": "section",
  "class": "section--ferment-leo-pdp",
  "max_blocks": 50,
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "checkbox", "id": "show_breadcrumb", "label": "Show breadcrumb", "default": true },

    { "type": "header", "content": "Trust Strip (4 cards)" },
    { "type": "image_picker", "id": "trust1_icon", "label": "Card 1 — icon SVG" },
    { "type": "text", "id": "trust1_h", "label": "Card 1 — heading", "default": "50K+ Customers Served" },
    { "type": "textarea", "id": "trust1_d", "label": "Card 1 — description", "default": "Trusted by Indian homes since 2020." },
    { "type": "image_picker", "id": "trust2_icon", "label": "Card 2 — icon SVG" },
    { "type": "text", "id": "trust2_h", "label": "Card 2 — heading", "default": "Fermentation Expert Help" },
