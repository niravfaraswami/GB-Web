{%- render 'leo_kit_chrome' -%}

{%- liquid
  assign p = product
-%}

{%- if section.settings.sticky_show -%}
  <div class="sticky-atc ferment-pdp-leo" data-sticky-atc aria-hidden="true" {%- render 'leo_kit_attrs' -%}>
    <div class="sticky-atc-inner">
      <div class="sticky-atc-prod">
        {%- if p.featured_image -%}
          <img class="sticky-atc-img" src="{{ p.featured_image | image_url: width: 160 }}" alt="{{ p.title | escape }}" width="48" height="48">
        {%- endif -%}
        <div class="sticky-atc-name">{{ p.title }}</div>
      </div>
      <div class="sticky-atc-price"><span data-sticky-price>{{ p.price | money }}</span></div>
      <button type="button" class="sticky-atc-btn" data-sticky-atc-trigger aria-label="Add to cart">
        <svg class="sticky-atc-cart-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6L18 2H6z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <span class="sticky-atc-btn-label">Add to cart</span>
      </button>
      {%- if section.settings.sticky_social_show -%}
        {%- assign has_social = false -%}
        {%- if section.settings.sticky_fb != blank or section.settings.sticky_ig != blank or section.settings.sticky_yt != blank or section.settings.sticky_tt != blank or section.settings.sticky_x != blank -%}{%- assign has_social = true -%}{%- endif -%}
        {%- if has_social -%}
          <div class="sticky-atc-social">
            {%- if section.settings.sticky_fb != blank -%}<a href="{{ section.settings.sticky_fb }}" target="_blank" rel="noopener" aria-label="Facebook"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.6 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.3c-1.2 0-1.6.8-1.6 1.6V12h2.7l-.4 2.9h-2.3v7A10 10 0 0 0 22 12z"/></svg></a>{%- endif -%}
            {%- if section.settings.sticky_ig != blank -%}<a href="{{ section.settings.sticky_ig }}" target="_blank" rel="noopener" aria-label="Instagram"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.4A4 4 0 1 1 12.6 8 4 4 0 0 1 16 11.4z"/><line x1="17.5" y1="6.5" x2="17.5" y2="6.5"/></svg></a>{%- endif -%}
            {%- if section.settings.sticky_yt != blank -%}<a href="{{ section.settings.sticky_yt }}" target="_blank" rel="noopener" aria-label="YouTube"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23 7.6s-.2-1.5-.9-2.2c-.8-.9-1.7-.9-2.2-1C16.6 4.1 12 4.1 12 4.1s-4.6 0-7.9.3c-.4.1-1.4.1-2.2 1C1.2 6.1 1 7.6 1 7.6S.8 9.4.8 11.2v1.6c0 1.8.2 3.6.2 3.6s.2 1.5.9 2.2c.8.9 1.9.9 2.4 1 1.7.2 7.7.3 7.7.3s4.6 0 7.9-.3c.5-.1 1.4-.1 2.2-1 .7-.7.9-2.2.9-2.2s.2-1.8.2-3.6v-1.6c0-1.8-.2-3.6-.2-3.6zM9.7 14.6V8.4l5.9 3.1-5.9 3.1z"/></svg></a>{%- endif -%}
            {%- if section.settings.sticky_tt != blank -%}<a href="{{ section.settings.sticky_tt }}" target="_blank" rel="noopener" aria-label="TikTok"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.6 6.7a4.8 4.8 0 0 1-2.9-1V15a5.5 5.5 0 1 1-5.5-5.5h.5v2.5h-.5a3 3 0 1 0 3 3V2h2.4a4.8 4.8 0 0 0 3 4.7v0z"/></svg></a>{%- endif -%}
            {%- if section.settings.sticky_x != blank -%}<a href="{{ section.settings.sticky_x }}" target="_blank" rel="noopener" aria-label="X"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.9 3h3.3l-7.2 8.2L23.5 21h-6.7l-5.2-6.8L5.5 21H2.2l7.7-8.8L1.5 3h6.8l4.7 6.2L18.9 3zm-1.2 16h1.8L7.4 5H5.5l12.2 14z"/></svg></a>{%- endif -%}
          </div>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Leo · Sticky ATC",
  "tag": "section",
  "class": "leo-sticky-atc-section",
  "settings": [
    { "type": "checkbox", "id": "sticky_show", "label": "Show sticky add-to-cart bar", "default": true },
    { "type": "checkbox", "id": "sticky_social_show", "label": "Show social links (desktop only)", "default": true },
    { "type": "url", "id": "sticky_fb", "label": "Facebook URL" },
    { "type": "url", "id": "sticky_ig", "label": "Instagram URL" },
    { "type": "url", "id": "sticky_yt", "label": "YouTube URL" },
    { "type": "url", "id": "sticky_tt", "label": "TikTok URL" },
    { "type": "url", "id": "sticky_x", "label": "X (Twitter) URL" }
  ],
  "presets": [{ "name": "Leo · Sticky ATC" }]
}
{% endschema %}
