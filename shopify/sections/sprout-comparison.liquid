<section class="myth-section" data-kit="sprouts">
  <div class="container">
    <div class="myth-header">
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h2>{{ section.settings.heading }}<br><em>{{ section.settings.heading_em }}</em></h2>
      {%- if section.settings.intro != blank -%}
        <p style="margin-top:18px;">{{ section.settings.intro }}</p>
      {%- endif -%}
    </div>

    <div class="compare-block">
      <div class="compare-images">
        <div class="compare-image">
          {%- if section.settings.left_image != blank -%}
            {{ section.settings.left_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: section.settings.left_label }}
          {%- else -%}
            {{ section.settings.left_emoji }}
          {%- endif -%}
        </div>
        <div class="compare-image">
          {%- if section.settings.right_image != blank -%}
            {{ section.settings.right_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: section.settings.right_label }}
          {%- else -%}
            {{ section.settings.right_emoji }}
          {%- endif -%}
        </div>
      </div>
      <div class="compare-labels">
        <span>{{ section.settings.left_label }}</span>
        <span>{{ section.settings.right_label }}</span>
      </div>
      <div class="compare-table" id="compare-table">
        {%- for block in section.blocks -%}
          <div class="compare-row" {{ block.shopify_attributes }}>
            <div class="compare-cell left">
              <div class="h">{{ block.settings.left_h }}</div>
              <div class="s">{{ block.settings.left_s }}</div>
            </div>
            <div class="compare-cell right">
              <div class="h">{{ block.settings.right_h }}</div>
              <div class="s">{{ block.settings.right_s }}</div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Sprout — Comparison",
  "tag": "section",
  "class": "section--sprout-compare",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "WHY UPGRADE" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "SPROUT MAKER" },
    { "type": "text", "id": "heading_em", "label": "Heading (highlighted)", "default": "VS TRADITIONAL CLOTH." },
    { "type": "textarea", "id": "intro", "label": "Intro paragraph" },
    { "type": "image_picker", "id": "left_image", "label": "Left image (cloth method)" },
    { "type": "image_picker", "id": "right_image", "label": "Right image (sprout maker)" },
    { "type": "text", "id": "left_emoji", "label": "Left emoji fallback", "default": "🧺" },
    { "type": "text", "id": "right_emoji", "label": "Right emoji fallback", "default": "🫙" },
    { "type": "text", "id": "left_label", "label": "Left column label", "default": "CLOTH METHOD" },
    { "type": "text", "id": "right_label", "label": "Right column label", "default": "SPROUT MAKER" }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Row",
      "settings": [
        { "type": "text", "id": "left_h", "label": "Left heading" },
        { "type": "textarea", "id": "left_s", "label": "Left subtext" },
        { "type": "text", "id": "right_h", "label": "Right heading" },
        { "type": "textarea", "id": "right_s", "label": "Right subtext" }
      ]
    }
  ],
  "presets": [{ "name": "Sprout — Comparison" }]
}
{% endschema %}
