<section class="judgeme-section" id="judgeme-reviews" data-kit="sprouts">
  <div class="container">
    <div class="section-header centered">
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h2>
        {%- if product.metafields.custom.review_count -%}
          {{ product.metafields.custom.review_count }}
        {%- endif %} {{ section.settings.heading }}<br><em>{{ section.settings.heading_em }}</em>
      </h2>
    </div>
    {%- if section.settings.embed_code != blank -%}
      {{ section.settings.embed_code }}
    {%- else -%}
      <div class="jdgm-widget jdgm-review-widget" data-id="{{ product.id }}"></div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Sprout — Judge.me",
  "tag": "section",
  "class": "section--sprout-judgeme",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "ALL REVIEWS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "VERIFIED" },
    { "type": "text", "id": "heading_em", "label": "Heading (highlighted)", "default": "CUSTOMER REVIEWS." },
    { "type": "html", "id": "embed_code", "label": "Custom embed (optional)" }
  ],
  "presets": [{ "name": "Sprout — Judge.me" }]
}
{% endschema %}
