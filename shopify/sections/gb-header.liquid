<script>
  (function () {
    function syncHeaderHeights() {
      var header = document.querySelector('.gb-site-header');
      if (!header) return;
      var h = header.offsetHeight;
      // Match the CSS variable names Shopify Horizon uses elsewhere in the theme.
      document.body.style.setProperty('--header-height', h + 'px');
      document.body.style.setProperty('--header-group-height', h + 'px');
      document.body.style.setProperty('--top-row-height', h + 'px');
    }
    function init(scope) {
      var root = scope || document;
      // ---------- Mega menu (desktop) ----------
      var triggers = root.querySelectorAll ? root.querySelectorAll('.nav-trigger') : [];
      var menus    = root.querySelectorAll ? root.querySelectorAll('.mega-menu') : [];
      function closeAll() {
        menus.forEach(function (m) { m.classList.remove('open'); });
        triggers.forEach(function (t) { t.classList.remove('open', 'active'); t.setAttribute('aria-expanded', 'false'); });
      }
      triggers.forEach(function (trigger) {
        if (trigger.dataset.bound) return;
        trigger.dataset.bound = '1';
        trigger.addEventListener('click', function (e) {
          e.stopPropagation();
          var targetId = trigger.dataset.trigger;
          var menu = document.querySelector('.mega-menu[data-menu="' + targetId + '"]');
          var wasOpen = trigger.classList.contains('open');
          closeAll();
          if (!wasOpen && menu) {
            menu.classList.add('open');
            trigger.classList.add('open', 'active');
            trigger.setAttribute('aria-expanded', 'true');
          }
        });
      });
      // close on outside click + Escape
      if (!document.body.dataset.gbHeaderBound) {
        document.body.dataset.gbHeaderBound = '1';
        document.addEventListener('click', function (e) {
          if (!e.target.closest('.primary-nav') && !e.target.closest('.mega-menu')) closeAll();
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') { closeAll(); closeMobileMenu(); }
        });
        // close on link click in mega-menu
        document.querySelectorAll('.mega-menu a').forEach(function (link) {
          link.addEventListener('click', function () { closeAll(); });
        });
      }

      // ---------- Mobile drawer ----------
      var drawer = document.getElementById('mobile-drawer');
      var toggle = document.getElementById('mobile-menu-toggle');
      function openMobileMenu() { if (drawer) { drawer.classList.add('open'); drawer.setAttribute('aria-hidden', 'false'); document.body.style.overflow = 'hidden'; } }
      function closeMobileMenu() { if (drawer) { drawer.classList.remove('open'); drawer.setAttribute('aria-hidden', 'true'); document.body.style.overflow = ''; } }
      window.openMobileMenu = openMobileMenu;
      window.closeMobileMenu = closeMobileMenu;
      if (toggle && !toggle.dataset.bound) { toggle.dataset.bound = '1'; toggle.addEventListener('click', openMobileMenu); }
      document.querySelectorAll('[data-md-close]').forEach(function (el) {
        if (el.dataset.bound) return;
        el.dataset.bound = '1';
        el.addEventListener('click', closeMobileMenu);
      });

      syncHeaderHeights();
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', function () { init(); }); else init();
    document.addEventListener('shopify:section:load', function (e) { init(e.target); });
    window.addEventListener('resize', syncHeaderHeights);
    window.addEventListener('load', syncHeaderHeights);
  })();
</script>

{% schema %}
{
  "name": "GB Header (v1)",
  "tag": "div",
