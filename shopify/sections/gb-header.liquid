  "settings": [
    { "type": "header", "content": "Branding" },
    { "type": "image_picker", "id": "logo", "label": "Logo", "info": "PNG/SVG, recommended height 40px" },
    { "type": "header", "content": "Mobile drawer" },
    { "type": "text", "id": "foot_text", "label": "Footer text (mobile drawer)", "default": "FSSAI License: 10021021000439" }
  ],
  "presets": [{ "name": "GB Header (v1)" }]
}
{% endschema %}
