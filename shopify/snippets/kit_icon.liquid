{%- comment -%}
  Renders a kit icon. SVGs are injected inline at runtime so CSS can
  recolor `fill` and `stroke` separately:
    stroke → kit accent color (var --kit-color)
    fill   → light tile color  (var --kit-color-soft)
  Raster files (PNG/JPG/WebP/GIF) render as <img> with native colors.

  SVG AUTHORING CONVENTION
  ────────────────────────
  Outline strokes:  <path stroke="..." fill="none" />
  Filled shapes:    <path fill="..." />        (no stroke OR stroke="none")
  CSS overrides any explicit colors at runtime.

  Params:
    - icon  (required): file_reference value
    - size  (default 24): pixel size for both rendering and CDN width
    - alt   (optional): alt text for raster <img>
    - extra (optional): extra class added to the rendered element
{%- endcomment -%}
{%- if icon != blank -%}
  {%- assign sz = size | default: 24 -%}
  {%- assign icon_url = icon | image_url: width: sz | default: icon.url | default: icon.src | default: icon.preview_image.src -%}
  {%- if icon_url contains '.svg' -%}
    <span class="kit-icon-svg{% if extra %} {{ extra }}{% endif %}"
          data-svg-src="{{ icon_url }}"
          aria-hidden="true"></span>
  {%- else -%}
    <img class="kit-icon-img{% if extra %} {{ extra }}{% endif %}" src="{{ icon_url }}" alt="{{ alt | default: '' | escape }}" loading="lazy" width="{{ sz }}" height="{{ sz }}">
  {%- endif -%}
{%- endif -%}
