{%- comment -%}
  Renders one cross-sell card.
  Params: p (Product, required), eyebrow (optional), description (optional), attrs (shopify_attributes string, optional)
{%- endcomment -%}
<div class="cs-card" {{ attrs }}>
  <a href="{{ p.url }}" class="cs-img">
    {%- if p.featured_media -%}
      {{ p.featured_media | image_url: width: 800 | image_tag: loading: 'lazy', alt: p.title }}
    {%- else -%}🌱{%- endif -%}
  </a>
  <div class="cs-body">
    <div class="cs-eyebrow">{{ eyebrow | default: p.type | default: 'PAIR WITH' | upcase }}</div>
    <a href="{{ p.url }}" class="cs-h">{{ p.title }}</a>
    <div class="cs-d">{{ description | default: p.metafields.custom.short_description | default: p.description | strip_html | truncatewords: 18 }}</div>
    <div class="cs-foot">
      <div class="cs-price">{{ p.price | money }}</div>
      {%- form 'product', p, class: 'cs-atc-form' -%}
        <input type="hidden" name="id" value="{{ p.selected_or_first_available_variant.id }}">
        <button type="submit" class="cs-atc">Add to cart</button>
      {%- endform -%}
    </div>
  </div>
</div>
