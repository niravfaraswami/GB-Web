{%- render 'leo_kit_chrome' -%}

{%- assign rel_blocks = section.blocks | where: 'type', 'related_recipe' -%}

{%- if rel_blocks.size > 0 -%}
  <section class="related-recipes" {%- render 'leo_kit_attrs' -%}>
    <div class="container">
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
      <div class="related-recipe-grid">
        {%- for block in rel_blocks -%}
          {%- assign rel_article = block.settings.article -%}
          {%- assign url = rel_article.url | default: block.settings.url | default: '#' -%}
          {%- assign title = rel_article.title | default: block.settings.title -%}
          {%- assign meta = block.settings.meta | default: rel_article.metafields.custom.cuisine -%}
          {%- assign color = block.settings.cat_color | default: '#FF7300' -%}
          <a href="{{ url }}" class="related-recipe-card" {{ block.shopify_attributes }}>
            <div class="related-recipe-cat" style="background: {{ color }};"></div>
            <div class="related-recipe-title">{{ title }}</div>
            {%- if meta != blank -%}<div class="related-recipe-meta">{{ meta }}</div>{%- endif -%}
          </a>
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "GB · Learn Recipe Related",
  "tag": "section",
  "class": "gb-learn-recipe-related-wrap",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "More recipes from this kit" },
    { "type": "header", "content": "Spacing & Typography" },
    { "type": "range", "id": "pad_top_d", "label": "Padding top — desktop (px)", "min": 0, "max": 200, "step": 4, "default": 64 },
    { "type": "range", "id": "pad_bot_d", "label": "Padding bottom — desktop (px)", "min": 0, "max": 200, "step": 4, "default": 64 },
    { "type": "range", "id": "pad_top_m", "label": "Padding top — mobile (px)", "min": 0, "max": 120, "step": 4, "default": 48 },
    { "type": "range", "id": "pad_bot_m", "label": "Padding bottom — mobile (px)", "min": 0, "max": 120, "step": 4, "default": 48 }
  ],
  "blocks": [
    { "type": "related_recipe", "name": "Related recipe", "limit": 4, "settings": [
      { "type": "article", "id": "article", "label": "Recipe article" },
      { "type": "text", "id": "title", "label": "Title override" },
      { "type": "url", "id": "url", "label": "URL override" },
      { "type": "text", "id": "meta", "label": "Meta line", "default": "Indian · Vegan" },
      { "type": "color", "id": "cat_color", "label": "Category dot color", "default": "#FF7300" }
    ]}
  ],
  "presets": [{ "name": "GB · Learn Recipe Related" }]
}
{% endschema %}
