{%- render 'leo_kit_chrome' -%}

{%- assign feat_blocks = section.blocks | where: 'type', 'feature' -%}

{%- if feat_blocks.size > 0 -%}
  <section class="coll-intro" {%- render 'leo_kit_attrs' -%}>
    <div class="container">
      <div class="intro-grid">
        {%- for block in feat_blocks -%}
          <div class="intro-feature" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != blank -%}<div class="if-icon">{{ block.settings.icon }}</div>{%- endif -%}
            <div class="if-h">{{ block.settings.heading }}</div>
            {%- if block.settings.body != blank -%}<div class="if-p">{{ block.settings.body }}</div>{%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "GB · Collection Intro",
  "tag": "section",
  "class": "gb-coll-intro-wrap",
  "settings": [
    { "type": "header", "content": "Spacing & Typography" },
    { "type": "range", "id": "pad_top_d", "label": "Padding top — desktop (px)", "min": 0, "max": 200, "step": 4, "default": 64 },
    { "type": "range", "id": "pad_bot_d", "label": "Padding bottom — desktop (px)", "min": 0, "max": 200, "step": 4, "default": 64 },
    { "type": "range", "id": "pad_top_m", "label": "Padding top — mobile (px)", "min": 0, "max": 120, "step": 4, "default": 48 },
    { "type": "range", "id": "pad_bot_m", "label": "Padding bottom — mobile (px)", "min": 0, "max": 120, "step": 4, "default": 48 }
  ],
  "blocks": [
    { "type": "feature", "name": "Intro feature", "limit": 4, "settings": [
      { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "🫙" },
      { "type": "text", "id": "heading", "label": "Heading" },
      { "type": "textarea", "id": "body", "label": "Body" }
    ]}
  ],
  "presets": [{ "name": "GB · Collection Intro" }]
}
{% endschema %}
