{%- render 'leo_kit_chrome' -%}

{%- liquid
  assign p = product
  assign mf_journey_eyebrow = p.metafields.custom.journey_eyebrow
  assign mf_journey_heading = p.metafields.custom.journey_heading
  assign mf_journey_sub = p.metafields.custom.journey_sub
  assign mf_cross_sell = p.metafields.custom.cross_sell_products.value
  assign stage_blocks = section.blocks | where: 'type', 'stage'
  assign jn_eyebrow = mf_journey_eyebrow | default: section.settings.eyebrow
  assign jn_heading = mf_journey_heading | default: section.settings.heading
  assign jn_intro = mf_journey_sub | default: section.settings.intro
  assign has_mf_cross = false
  if mf_cross_sell and mf_cross_sell.size > 0
    assign has_mf_cross = true
  endif
-%}

{%- if has_mf_cross or stage_blocks.size > 0 or jn_heading != blank -%}
  <section class="gb-journey-section ferment-pdp-leo" {%- render 'leo_kit_attrs' -%}>
    <div class="container">
      <div class="section-header centered">
        {%- if jn_eyebrow != blank -%}<div class="eyebrow">{{ jn_eyebrow }}</div>{%- endif -%}
        {%- if jn_heading != blank -%}<h2>{{ jn_heading }} <em>{{ section.settings.heading_em }}</em></h2>{%- endif -%}
        {%- if jn_intro != blank -%}<p>{{ jn_intro }}</p>{%- endif -%}
      </div>

      <div class="gb-journey-grid">
        {%- if has_mf_cross -%}
          {%- for cs in mf_cross_sell -%}
            <div class="gb-journey-card">
              {%- if cs.featured_image != blank -%}
                <div class="gb-journey-img"><img src="{{ cs.featured_image | image_url: width: 600 }}" alt="{{ cs.title | escape }}" loading="lazy" width="400" height="400"></div>
              {%- endif -%}
              <div class="gb-journey-product">{{ cs.title }}</div>
              {%- assign cs_tag = cs.metafields.custom.hero_tagline -%}
              {%- if cs_tag != blank -%}<div class="gb-journey-tag">{{ cs_tag }}</div>{%- endif -%}
              <div class="gb-journey-price">{{ cs.price | money }}</div>
              <a class="gb-journey-cta" href="{{ cs.url }}">Shop →</a>
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for block in stage_blocks -%}
            <div class="gb-journey-card{% if block.settings.featured %} gb-journey-featured{% endif %}" {{ block.shopify_attributes }}>
              {%- if block.settings.stage_label != blank -%}<div class="gb-journey-stage">{{ block.settings.stage_label }}</div>{%- endif -%}
              {%- if block.settings.image != blank -%}
                <div class="gb-journey-img"><img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.product_name | escape }}" loading="lazy" width="400" height="400"></div>
              {%- endif -%}
              {%- if block.settings.product_name != blank -%}<div class="gb-journey-product">{{ block.settings.product_name }}</div>{%- endif -%}
              {%- if block.settings.tag != blank -%}<div class="gb-journey-tag">{{ block.settings.tag }}</div>{%- endif -%}
              {%- if block.settings.bullets != blank -%}
                <ul class="gb-journey-points">
                  {%- assign lines = block.settings.bullets | newline_to_br | split: '<br />' -%}
                  {%- for line in lines -%}{%- assign t = line | strip -%}{%- if t != blank -%}<li>{{ t }}</li>{%- endif -%}{%- endfor -%}
                </ul>
              {%- endif -%}
              {%- if block.settings.price != blank -%}<div class="gb-journey-price">{{ block.settings.price }}</div>{%- endif -%}
              {%- if block.settings.cta_label != blank -%}
                <a class="gb-journey-cta" href="{{ block.settings.cta_url | default: '#' }}">{{ block.settings.cta_label }}</a>
              {%- endif -%}
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "GB · Journey (v2)",
  "tag": "section",
  "class": "gb-journey-wrap",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "YOUR JOURNEY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FROM"
    },
    {
      "type": "text",
      "id": "heading_em",
      "label": "Heading (highlighted)",
      "default": "BEGINNER TO ADVANCED."
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro"
    },
    {
      "type": "header",
      "content": "Spacing & Typography"
    },
    {
      "type": "range",
      "id": "pad_top_d",
      "label": "Padding top — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_bot_d",
      "label": "Padding bottom — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_top_m",
      "label": "Padding top — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "pad_bot_m",
      "label": "Padding bottom — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "mar_top_d",
      "label": "Margin top — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_d",
      "label": "Margin bottom — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_top_m",
      "label": "Margin top — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_m",
      "label": "Margin bottom — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "eyebrow_size_d",
      "label": "Eyebrow font size — desktop (px)",
      "min": 9,
      "max": 32,
      "step": 1,
      "default": 22
    },
    {
      "type": "range",
      "id": "eyebrow_size_m",
      "label": "Eyebrow font size — mobile (px)",
      "min": 9,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "heading_size_d",
      "label": "Heading font size — desktop (px)",
      "min": 18,
      "max": 80,
      "step": 2,
      "default": 44
    },
    {
      "type": "range",
      "id": "heading_size_m",
      "label": "Heading font size — mobile (px)",
      "min": 16,
      "max": 60,
      "step": 2,
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "stage",
      "name": "Stage",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "stage_label",
          "label": "Stage label",
          "default": "BEGINNER"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product image"
        },
        {
          "type": "text",
          "id": "product_name",
          "label": "Product name"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Tag (sub-label)",
          "default": "Easy on gut"
        },
        {
          "type": "textarea",
          "id": "bullets",
          "label": "Bullets (one per line)"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price (display string)"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA label",
          "default": "Shop →"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "CTA URL"
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Featured (highlighted)",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GB · Journey (v2)"
    }
  ]
}
{% endschema %}
