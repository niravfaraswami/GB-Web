{%- render 'leo_kit_chrome' -%}

{%- assign app_blocks = section.blocks | where: 'type', '@app' -%}

{%- if app_blocks.size > 0 or section.settings.heading != blank -%}
  <section class="reels-section ferment-pdp-leo" {%- render 'leo_kit_attrs' -%}>
    <div class="container">
      {%- if section.settings.heading != blank or section.settings.eyebrow != blank -%}
        <div class="section-header centered">
          {%- if section.settings.eyebrow != blank -%}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
          {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }} <em>{{ section.settings.heading_em }}</em></h2>{%- endif -%}
        </div>
      {%- endif -%}
      {%- for block in app_blocks -%}
        {% render block %}
      {%- endfor -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Leo · UGC Reels",
  "tag": "section",
  "class": "leo-reels-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "REAL PEOPLE" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Real People, Real Ferments," },
    { "type": "text", "id": "heading_em", "label": "Heading (highlighted)", "default": "Real Magic" },
    { "type": "paragraph", "content": "Add Quinn UGC reels (or any other app block) below. Click 'Add block' and select the app." }
  ],
  "blocks": [
    { "type": "@app" }
  ],
  "presets": [{ "name": "Leo · UGC Reels" }]
}
{% endschema %}