{%- render 'leo_kit_chrome' -%}

{%- liquid
  assign p = product
  assign mf_reels = p.metafields.custom.featured_reels.value
  assign mf_reels_h = p.metafields.custom.reels_h
  assign app_blocks = section.blocks | where: 'type', '@app'
  assign has_mf = false
  if mf_reels and mf_reels.size > 0
    assign has_mf = true
  endif
-%}

{%- if has_mf or app_blocks.size > 0 or section.settings.heading != blank or mf_reels_h != blank -%}
  <section class="reels-section ferment-pdp-leo" {%- render 'leo_kit_attrs' -%}>
    <div class="container">
      {%- if mf_reels_h != blank or section.settings.heading != blank or section.settings.eyebrow != blank -%}
        <div class="section-header centered">
          {%- if section.settings.eyebrow != blank -%}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
          {%- if mf_reels_h != blank -%}
            <h2>{{ mf_reels_h }}</h2>
          {%- elsif section.settings.heading != blank -%}
            <h2>{{ section.settings.heading }} <em>{{ section.settings.heading_em }}</em></h2>
          {%- endif -%}
        </div>
      {%- endif -%}
      {%- if has_mf -%}
        <div class="reels-grid">
          {%- for r in mf_reels -%}
            <div class="reel-tile">
              {%- if r.video != blank -%}
                {%- if r.video.sources or r.video.media_type == 'video' -%}
                  {{ r.video | video_tag: image_size: '600x', controls: false, loop: true, muted: true, autoplay: true }}
                {%- else -%}
                  {%- assign reel_src = r.video.url | default: r.video.src -%}
                  {%- if reel_src != blank -%}
                    <video src="{{ reel_src }}" autoplay loop muted playsinline preload="metadata" style="width:100%;height:100%;object-fit:cover;"></video>
                  {%- endif -%}
                {%- endif -%}
              {%- elsif r.poster != blank -%}
                <img src="{{ r.poster | image_url: width: 600 }}" alt="{{ r.caption | default: r.author_handle | default: 'Customer reel' | escape }}" loading="lazy" width="600" height="1067">
              {%- else -%}📷{%- endif -%}
              {%- if r.author_handle != blank -%}
                <span class="reel-handle">{{ r.author_handle }}</span>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      {%- else -%}
        {%- for block in app_blocks -%}
          {% render block %}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Leo · UGC Reels",
  "tag": "section",
  "class": "leo-reels-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "REAL PEOPLE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real People, Real Ferments,"
    },
    {
      "type": "text",
      "id": "heading_em",
      "label": "Heading (highlighted)",
      "default": "Real Magic"
    },
    {
      "type": "paragraph",
      "content": "Add Quinn UGC reels (or any other app block) below. Click 'Add block' and select the app."
    },
    {
      "type": "header",
      "content": "Spacing & Typography"
    },
    {
      "type": "range",
      "id": "pad_top_d",
      "label": "Padding top — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "pad_bot_d",
      "label": "Padding bottom — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "pad_top_m",
      "label": "Padding top — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "pad_bot_m",
      "label": "Padding bottom — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "mar_top_d",
      "label": "Margin top — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_d",
      "label": "Margin bottom — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_top_m",
      "label": "Margin top — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_m",
      "label": "Margin bottom — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "eyebrow_size_d",
      "label": "Eyebrow font size — desktop (px)",
      "min": 9,
      "max": 32,
      "step": 1,
      "default": 22
    },
    {
      "type": "range",
      "id": "eyebrow_size_m",
      "label": "Eyebrow font size — mobile (px)",
      "min": 9,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "heading_size_d",
      "label": "Heading font size — desktop (px)",
      "min": 18,
      "max": 80,
      "step": 2,
      "default": 44
    },
    {
      "type": "range",
      "id": "heading_size_m",
      "label": "Heading font size — mobile (px)",
      "min": 16,
      "max": 60,
      "step": 2,
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Leo · UGC Reels"
    }
  ]
}
{% endschema %}
