{%- liquid
  assign p = product
  assign mf_compare_rows = p.metafields.custom.featured_comparison_rows.value
  assign mf_myth_eyebrow = p.metafields.custom.myth_eyebrow
  assign mf_myth_h1 = p.metafields.custom.myth_h1
  assign mf_myth_h2 = p.metafields.custom.myth_h2
  assign mf_compare_intro = p.metafields.custom.comparison_intro
  assign mf_compare_left_label = p.metafields.custom.compare_left_label
  assign mf_compare_right_label = p.metafields.custom.compare_right_label
  assign mf_compare_left_image = p.metafields.custom.comparison_left_image
  assign mf_compare_right_image = p.metafields.custom.comparison_right_image
  assign mf_myth_pill = p.metafields.custom.myth_pill_text
  assign mf_fact_pill = p.metafields.custom.fact_pill_text
-%}
{%- if section.settings.show_section -%}
  {%- if mf_compare_rows == blank or mf_compare_rows.size == 0 -%}
    {%- comment -%} No comparison rows — hide section {%- endcomment -%}
  {%- else -%}
    <section class="fk-page ferment-pdp fk-myth-section myth-section" style="background:{{ section.settings.section_bg }}">
      {%- render 'fk-color-cascade' -%}
      <div class="container">
        <div class="myth-header">
          <div class="eyebrow">{{ mf_myth_eyebrow | default: section.settings.compare_eyebrow | default: 'TRADITIONAL VS AIRLOCK' }}</div>
          {%- if mf_myth_h1 != blank or mf_myth_h2 != blank -%}
            <h2>{{ mf_myth_h1 }}<br><em>{{ mf_myth_h2 }}</em></h2>
          {%- else -%}
            <h2>{{ section.settings.compare_heading | default: 'CLOTH METHOD' }}<br><em>{{ section.settings.compare_heading_em | default: 'VS AIRLOCK.' }}</em></h2>
          {%- endif -%}
          {%- if mf_compare_intro != blank -%}<p style="margin-top:18px;">{{ mf_compare_intro }}</p>{%- endif -%}
        </div>
        <div class="compare-block">
          <div class="compare-images">
            <div class="compare-image">
              {%- if mf_compare_left_image != blank -%}
                <img src="{{ mf_compare_left_image | image_url: width: 800 }}" alt="{{ mf_compare_left_label | default: 'Traditional' }}" loading="lazy" width="800" height="600">
              {%- else -%}🧺{%- endif -%}
              {%- if mf_myth_pill != blank -%}<span class="myth-pill myth-pill--myth">{{ mf_myth_pill }}</span>{%- endif -%}
            </div>
            <div class="compare-image">
              {%- if mf_compare_right_image != blank -%}
                <img src="{{ mf_compare_right_image | image_url: width: 800 }}" alt="{{ mf_compare_right_label | default: 'Airlock' }}" loading="lazy" width="800" height="600">
              {%- else -%}🫙{%- endif -%}
              {%- if mf_fact_pill != blank -%}<span class="myth-pill myth-pill--fact">{{ mf_fact_pill }}</span>{%- endif -%}
            </div>
          </div>
          <div class="compare-labels">
            <span>{{ mf_compare_left_label | default: section.settings.compare_left_label | default: 'TRADITIONAL METHOD' }}</span>
            <span>{{ mf_compare_right_label | default: section.settings.compare_right_label | default: 'GUTBASKET KIT' }}</span>
          </div>
          <div class="compare-table">
            {%- for row in mf_compare_rows -%}
              <div class="compare-row">
                <div class="compare-cell left">
                  <div class="h">{{ row.left_heading }}</div>
                  <div class="s">{{ row.left_subtext }}</div>
                </div>
                <div class="compare-cell right">
                  <div class="h">{{ row.right_heading }}</div>
                  <div class="s">{{ row.right_subtext }}</div>
                </div>
              </div>
            {%- endfor -%}
          </div>
        </div>
      </div>
    </section>
  {%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "FK — Myth / Compare",
  "tag": "section",
  "class": "fk-myth-section",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show section", "default": true },
    { "type": "color", "id": "section_bg", "label": "Section background", "default": "#ffffff" },
    { "type": "text", "id": "compare_eyebrow", "label": "Eyebrow fallback", "default": "TRADITIONAL VS AIRLOCK" },
    { "type": "text", "id": "compare_heading", "label": "Heading fallback", "default": "CLOTH METHOD" },
    { "type": "text", "id": "compare_heading_em", "label": "Heading (em) fallback", "default": "VS AIRLOCK." },
    { "type": "text", "id": "compare_left_label", "label": "Left column label fallback", "default": "TRADITIONAL METHOD" },
    { "type": "text", "id": "compare_right_label", "label": "Right column label fallback", "default": "GUTBASKET KIT" }
  ],
  "presets": [ { "name": "FK — Myth / Compare" } ],
  "enabled_on": { "templates": ["product"] }
}
{% endschema %}
