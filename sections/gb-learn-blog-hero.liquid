{%- render 'leo_kit_chrome' -%}

{%- liquid
  assign cat_label = article.metafields.custom.category_label | default: section.settings.fallback_category
  assign subtitle = article.excerpt | default: article.metafields.custom.subtitle | default: section.settings.fallback_subtitle
  assign author_role = article.metafields.custom.author_role | default: 'Brand Editorial'
  assign read_time = article.metafields.custom.read_time | default: section.settings.fallback_read_time
  assign hero_emoji = article.metafields.custom.hero_emoji | default: section.settings.fallback_emoji
-%}

<section class="article-hero" {%- render 'leo_kit_attrs' -%}>
  <div class="container">
    {%- if cat_label != blank -%}
      <div class="cat-pill">
        <span class="dot"></span>
        <span>{{ cat_label }}</span>
      </div>
    {%- endif -%}
    <h1>{{ article.title | default: section.settings.fallback_title }}</h1>
    {%- if subtitle != blank -%}
      <p class="article-subtitle">{{ subtitle }}</p>
    {%- endif -%}
    <div class="article-meta-row">
      <span class="article-author">{{ article.author | default: 'GutBasket Team' }}</span>
      <span class="dot">·</span>
      <span>{{ author_role }}</span>
      <span class="dot">·</span>
      <span>{{ article.published_at | date: '%B %d, %Y' | default: 'Today' }}</span>
      {%- if read_time != blank -%}
        <span class="dot">·</span>
        <span>{{ read_time }}</span>
      {%- endif -%}
    </div>
    {%- if article.image -%}
      <div class="article-feature article-feature-image">
        <img src="{{ article.image | image_url: width: 1600 }}" alt="{{ article.title | escape }}" loading="eager" width="1600" height="900">
      </div>
    {%- elsif hero_emoji != blank -%}
      <div class="article-feature">{{ hero_emoji }}</div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "GB · Learn Blog Hero",
  "tag": "section",
  "class": "gb-learn-blog-hero-wrap",
  "settings": [
    { "type": "text", "id": "fallback_title", "label": "Fallback title (when article.title is empty)", "default": "Article title" },
    { "type": "textarea", "id": "fallback_subtitle", "label": "Fallback subtitle" },
    { "type": "text", "id": "fallback_category", "label": "Fallback category label", "default": "FERMENTATION 101" },
    { "type": "text", "id": "fallback_read_time", "label": "Fallback read time", "default": "8 min read" },
    { "type": "text", "id": "fallback_emoji", "label": "Fallback hero emoji (when article.image is empty)", "default": "🫙" },
    { "type": "header", "content": "Spacing & Typography" },
    { "type": "range", "id": "pad_top_d", "label": "Padding top — desktop (px)", "min": 0, "max": 200, "step": 4, "default": 56 },
    { "type": "range", "id": "pad_bot_d", "label": "Padding bottom — desktop (px)", "min": 0, "max": 200, "step": 4, "default": 48 },
    { "type": "range", "id": "pad_top_m", "label": "Padding top — mobile (px)", "min": 0, "max": 120, "step": 4, "default": 40 },
    { "type": "range", "id": "pad_bot_m", "label": "Padding bottom — mobile (px)", "min": 0, "max": 120, "step": 4, "default": 32 },
    { "type": "range", "id": "mar_top_d", "label": "Margin top — desktop (px)", "min": 0, "max": 100, "step": 4, "default": 0 },
    { "type": "range", "id": "mar_bot_d", "label": "Margin bottom — desktop (px)", "min": 0, "max": 100, "step": 4, "default": 0 },
    { "type": "range", "id": "mar_top_m", "label": "Margin top — mobile (px)", "min": 0, "max": 80, "step": 4, "default": 0 },
    { "type": "range", "id": "mar_bot_m", "label": "Margin bottom — mobile (px)", "min": 0, "max": 80, "step": 4, "default": 0 },
    { "type": "range", "id": "heading_size_d", "label": "Heading H1 size — desktop (px)", "min": 24, "max": 80, "step": 2, "default": 48 },
    { "type": "range", "id": "heading_size_m", "label": "Heading H1 size — mobile (px)", "min": 20, "max": 60, "step": 2, "default": 32 }
  ],
  "presets": [{ "name": "GB · Learn Blog Hero" }]
}
{% endschema %}
