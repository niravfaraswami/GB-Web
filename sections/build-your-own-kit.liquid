{%- comment -%}
  build-your-own-kit.liquid
  =========================================================================
  GutBasket · Build Your Own Kit (v2) — page section
  Template: page.byok.json → routes here.

  V1 CONTENT STRATEGY (NO METAOBJECTS):
  -----------------------------------------------------------------
  Per the user's decision, this v1 hardcodes all section/tile/sub-option
  data inline. Product-backed tiles are rendered via inline for-loops over
  pipe/tilde-delimited data strings — no external snippet dependency.
  Ferment tiles (logical groupings) are rendered as static markup.

  Data row format (handle~title~bg~emoji~badge~eager):
    eager=1 → loading="eager" (first jar tile only, perf §16)
    badge   → empty string for tools/books (no badge over image)

  PRODUCT HANDLES referenced (catalog drift check during QA):
    Jars   : a-fermentation-jars, fermentation-jar-wide-mouth-2-litre,
             fermentation-jar-wide-mouth-4-litre, kombucha-jar,
             fermentation-jar-narrow-mouth-hdpe-8-litre, glass-carboy-4-litre
    Ferment chips :
             kanji-supplies-starter-pack, kanji-supplies-value-pack,
             kanji-supplies-mega-pack,
             aam-panna-supplies-value-pack-includes-aam-panna-spice-mix-pack-of-5-ferment-boost-pack-of-5,
             achaar-making-supplies-6-batch-refill-pack,
             kimchi-making-paste
    Tools  : a-glass-weight, grommet-washer-for-fermentation-lid-set-of-3,
             a-ph-strip, stick-on-thermometer-strip-1
    Books  : kanji-recipe-book, probiotic-achaar-recipe-book,
             kimchi-recipe-book, vegetable-fermentation-recipe-book,
             kombucha-recipe-book

  If a product is nil (drift), the for-loop skips the tile (per spec §14.2
  — never emit a broken tile).
{%- endcomment -%}

{{ 'byok.css' | asset_url | stylesheet_tag }}
<script src="{{ 'byok.js' | asset_url }}" defer></script>

{%- liquid
  # ============== TILE DATA (handle~title~bg~emoji~badge~eager) ==============
  assign jars_primary_data  = 'a-fermentation-jars~1 Litre~#FBF4E2~🫙~1 L~1|fermentation-jar-wide-mouth-2-litre~2 Litre~#F4E9C8~🫙~2 L~0|fermentation-jar-wide-mouth-4-litre~4 Litre~#EDDDA9~🫙~4 L~0'
  assign jars_more_data     = 'kombucha-jar~Kombucha Jar~#E8E4D7~🫙~4 L · Kombucha~0|fermentation-jar-narrow-mouth-hdpe-8-litre~Plastic Carboy~#E2E0D6~🛢️~8 L · HDPE~0|glass-carboy-4-litre~Amber Carboy~#D8C9A8~🍯~4 L · Glass~0'
  assign tools_data         = 'a-glass-weight~Glass Weight~#F5EDD8~⚪~~0|grommet-washer-for-fermentation-lid-set-of-3~Grommet · 3~#EBE7D4~⭕~~0|a-ph-strip~pH Strip~#E8E4D7~📏~~0|stick-on-thermometer-strip-1~Temp Strip~#F0E8CD~🌡️~~0'
  assign books_primary_data = 'kanji-recipe-book~Kanji Book~#F4D8E1~📕~~0|probiotic-achaar-recipe-book~Achaar Book~#FFE4D1~📙~~0|kimchi-recipe-book~Kimchi Book~#FBDED6~📕~~0|vegetable-fermentation-recipe-book~Veg Ferment~#E2EEDC~📗~~0'
  assign books_more_data    = 'kombucha-recipe-book~Kombucha Book~#E8E4D7~📘~~0'

  # ============== FERMENT SUB-OPTIONS (batch chips) ==============
  assign p_kanji_3   = all_products['kanji-supplies-starter-pack']
  assign p_kanji_5   = all_products['kanji-supplies-value-pack']
  assign p_kanji_10  = all_products['kanji-supplies-mega-pack']
  assign p_aam_5     = all_products['aam-panna-supplies-value-pack-includes-aam-panna-spice-mix-pack-of-5-ferment-boost-pack-of-5']
  assign p_achaar_6  = all_products['achaar-making-supplies-6-batch-refill-pack']
  assign p_kimchi_1  = all_products['kimchi-making-paste']
-%}

<div id="byok-page" class="byok">
  <div class="page-wrap">

    <header class="page-head">
      <div class="page-eyebrow">CRAFT YOUR FERMENTATION SETUP</div>
      <h1 class="page-h1">Build your own <em>fermentation kit</em></h1>
      <p class="page-sub">Mix and match across categories. Pick one item from a section, or several — your kit, your way.</p>
    </header>

    <div class="builder-grid">

      <div class="builder-stack">

        {%- comment -%} ============ STEP 1 · JARS ============ {%- endcomment -%}
        <section class="bs" id="bs-jar">
          <div class="bs-head">
            <span class="bs-num" aria-hidden="true">1</span>
            <div class="bs-title-block">
              <h2 class="bs-title">Choose jars</h2>
              <p class="bs-desc"><strong>Pick one or more sizes</strong> — different jars for different ferments.</p>
            </div>
          </div>

          <div class="tiles cols-3" data-group="jar">
            {%- for raw in jars_primary_data | split: '|' -%}
              {%- assign f = raw | split: '~' -%}
              {%- assign p = all_products[f[0]] -%}
              {%- if p != blank -%}
                {%- assign v = p.selected_or_first_available_variant -%}
                {%- assign img = p.featured_image -%}
                {%- assign price_money = v.price | money_without_trailing_zeros -%}
                {%- assign was_money = '' -%}
                {%- if v.compare_at_price and v.compare_at_price > v.price -%}
                  {%- assign was_money = v.compare_at_price | money_without_trailing_zeros -%}
                {%- endif -%}
                {%- assign loading_attr = 'lazy' -%}
                {%- if f[5] == '1' -%}{%- assign loading_attr = 'eager' -%}{%- endif -%}
                <button type="button" class="tile" data-id="tile-jar-{{ p.handle }}" data-handle="{{ p.handle }}" data-variant-id="{{ v.id }}" data-price="{{ v.price }}" data-was="{% if v.compare_at_price and v.compare_at_price > v.price %}{{ v.compare_at_price }}{% endif %}" data-label="{{ f[1] | escape }}" data-section="jar" aria-pressed="false">
                  <div class="tile-img" style="background:{{ f[2] }};">
                    {%- if img -%}
                      <img src="{{ img | image_url: width: 300 }}" srcset="{{ img | image_url: width: 200 }} 200w, {{ img | image_url: width: 300 }} 300w, {{ img | image_url: width: 400 }} 400w" sizes="(max-width: 600px) 33vw, 150px" loading="{{ loading_attr }}" decoding="async" alt="{{ f[1] | escape }}" width="300" height="300">
                    {%- else -%}
                      {{ f[3] }}
                    {%- endif -%}
                    {%- if f[4] != '' -%}<span class="img-badge">{{ f[4] }}</span>{%- endif -%}
                  </div>
                  <div class="tile-body">
                    <div class="tile-title">{{ f[1] }}</div>
                    <div class="tile-price">
                      {%- if was_money != '' -%}<span class="tile-was">{{ was_money }}</span>{%- endif -%}
                      {{ price_money }}
                    </div>
                  </div>
                  <span class="tile-check" aria-hidden="true">✓</span>
                </button>
              {%- endif -%}
            {%- endfor -%}
          </div>

          <button type="button" class="more-toggle" data-more="jar" aria-expanded="false">+ Brewing vessels (Kombucha jar, Carboy)</button>
          <div class="more-content" data-more-content="jar">
            <div class="tiles cols-3" data-group="jar">
              {%- for raw in jars_more_data | split: '|' -%}
                {%- assign f = raw | split: '~' -%}
                {%- assign p = all_products[f[0]] -%}
                {%- if p != blank -%}
                  {%- assign v = p.selected_or_first_available_variant -%}
                  {%- assign img = p.featured_image -%}
                  {%- assign price_money = v.price | money_without_trailing_zeros -%}
                  {%- assign was_money = '' -%}
                  {%- if v.compare_at_price and v.compare_at_price > v.price -%}
                    {%- assign was_money = v.compare_at_price | money_without_trailing_zeros -%}
                  {%- endif -%}
                  <button type="button" class="tile" data-id="tile-jar-{{ p.handle }}" data-handle="{{ p.handle }}" data-variant-id="{{ v.id }}" data-price="{{ v.price }}" data-was="{% if v.compare_at_price and v.compare_at_price > v.price %}{{ v.compare_at_price }}{% endif %}" data-label="{{ f[1] | escape }}" data-section="jar" aria-pressed="false">
                    <div class="tile-img" style="background:{{ f[2] }};">
                      {%- if img -%}
                        <img src="{{ img | image_url: width: 300 }}" srcset="{{ img | image_url: width: 200 }} 200w, {{ img | image_url: width: 300 }} 300w, {{ img | image_url: width: 400 }} 400w" sizes="(max-width: 600px) 33vw, 150px" loading="lazy" decoding="async" alt="{{ f[1] | escape }}" width="300" height="300">
                      {%- else -%}
                        {{ f[3] }}
                      {%- endif -%}
                      {%- if f[4] != '' -%}<span class="img-badge">{{ f[4] }}</span>{%- endif -%}
                    </div>
                    <div class="tile-body">
                      <div class="tile-title">{{ f[1] }}</div>
                      <div class="tile-price">
                        {%- if was_money != '' -%}<span class="tile-was">{{ was_money }}</span>{%- endif -%}
                        {{ price_money }}
                      </div>
                    </div>
                    <span class="tile-check" aria-hidden="true">✓</span>
                  </button>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        </section>

        {%- comment -%} ============ STEP 2 · FERMENTS ============ {%- endcomment -%}
        <section class="bs" id="bs-ferment">
          <div class="bs-head">
            <span class="bs-num" aria-hidden="true">2</span>
            <div class="bs-title-block">
              <h2 class="bs-title">Pick your ferments</h2>
              <p class="bs-desc"><strong>Pick one or more</strong> — each comes pre-spiced and sized to your batches.</p>
            </div>
          </div>

          <div class="tiles cols-4" data-group="ferment">
            <button type="button" class="tile" data-id="tile-ferment-kanji" data-ferment="kanji" data-label="Kanji" data-section="ferment" data-color="kanji" aria-pressed="false">
              <div class="tile-img" style="background:#F4D8E1; color:#8B1F40;">🥕</div>
              <div class="tile-body">
                <div class="tile-title">Kanji</div>
                <div class="tile-sub">Probiotic drink</div>
              </div>
              <span class="tile-check" aria-hidden="true">✓</span>
            </button>
            <button type="button" class="tile" data-id="tile-ferment-aampanna" data-ferment="aampanna" data-label="Aam Panna" data-section="ferment" data-color="aam-panna" aria-pressed="false">
              <div class="tile-img" style="background:#FAEFCB; color:#8C6916;">🥭</div>
              <div class="tile-body">
                <div class="tile-title">Aam Panna</div>
                <div class="tile-sub">Summer drink</div>
              </div>
              <span class="tile-check" aria-hidden="true">✓</span>
            </button>
            <button type="button" class="tile" data-id="tile-ferment-achaar" data-ferment="achaar" data-label="Achaar" data-section="ferment" data-color="achaar" aria-pressed="false">
              <div class="tile-img" style="background:#FFE4D1; color:#C84A24;">🥒</div>
              <div class="tile-body">
                <div class="tile-title">Achaar</div>
                <div class="tile-sub">Indian pickle</div>
              </div>
              <span class="tile-check" aria-hidden="true">✓</span>
            </button>
            <button type="button" class="tile" data-id="tile-ferment-kimchi" data-ferment="kimchi" data-label="Kimchi" data-section="ferment" data-color="kimchi" aria-pressed="false">
              <div class="tile-img" style="background:#FBDED6; color:#B23A23;">🥬</div>
              <div class="tile-body">
                <div class="tile-title">Kimchi</div>
                <div class="tile-sub">Korean staple</div>
              </div>
              <span class="tile-check" aria-hidden="true">✓</span>
            </button>
          </div>

          <div class="selected-ferments" id="selected-ferments"></div>
        </section>

        {%- comment -%} ============ STEP 3 · TOOLS ============ {%- endcomment -%}
        <section class="bs" id="bs-tools">
          <div class="bs-head">
            <span class="bs-num" aria-hidden="true">3</span>
            <div class="bs-title-block">
              <h2 class="bs-title">Add tools</h2>
              <p class="bs-desc"><strong>Add any that help</strong> — small pieces that make fermentation foolproof.</p>
            </div>
          </div>

          <div class="tiles cols-4" data-group="tools">
            {%- for raw in tools_data | split: '|' -%}
              {%- assign f = raw | split: '~' -%}
              {%- assign p = all_products[f[0]] -%}
              {%- if p != blank -%}
                {%- assign v = p.selected_or_first_available_variant -%}
                {%- assign img = p.featured_image -%}
                {%- assign price_money = v.price | money_without_trailing_zeros -%}
                {%- assign was_money = '' -%}
                {%- if v.compare_at_price and v.compare_at_price > v.price -%}
                  {%- assign was_money = v.compare_at_price | money_without_trailing_zeros -%}
                {%- endif -%}
                <button type="button" class="tile" data-id="tile-tools-{{ p.handle }}" data-handle="{{ p.handle }}" data-variant-id="{{ v.id }}" data-price="{{ v.price }}" data-was="{% if v.compare_at_price and v.compare_at_price > v.price %}{{ v.compare_at_price }}{% endif %}" data-label="{{ f[1] | escape }}" data-section="tools" aria-pressed="false">
                  <div class="tile-img" style="background:{{ f[2] }};">
                    {%- if img -%}
                      <img src="{{ img | image_url: width: 300 }}" srcset="{{ img | image_url: width: 200 }} 200w, {{ img | image_url: width: 300 }} 300w, {{ img | image_url: width: 400 }} 400w" sizes="(max-width: 600px) 25vw, 150px" loading="lazy" decoding="async" alt="{{ f[1] | escape }}" width="300" height="300">
                    {%- else -%}
                      {{ f[3] }}
                    {%- endif -%}
                    {%- if f[4] != '' -%}<span class="img-badge">{{ f[4] }}</span>{%- endif -%}
                  </div>
                  <div class="tile-body">
                    <div class="tile-title">{{ f[1] }}</div>
                    <div class="tile-price">
                      {%- if was_money != '' -%}<span class="tile-was">{{ was_money }}</span>{%- endif -%}
                      {{ price_money }}
                    </div>
                  </div>
                  <span class="tile-check" aria-hidden="true">✓</span>
                </button>
              {%- endif -%}
            {%- endfor -%}
          </div>

          <div class="context-hint" id="hint-veg">
            Glass weight added — your kit can now ferment vegetables too (sauerkraut, kimchi, achaar).
          </div>
        </section>

        {%- comment -%} ============ STEP 4 · BOOKS ============ {%- endcomment -%}
        <section class="bs" id="bs-book">
          <div class="bs-head">
            <span class="bs-num" aria-hidden="true">4</span>
            <div class="bs-title-block">
              <h2 class="bs-title">Add recipe books</h2>
              <p class="bs-desc"><strong>Add any</strong> — print companions for your shelf.</p>
            </div>
          </div>

          <div class="tiles cols-4" data-group="books">
            {%- for raw in books_primary_data | split: '|' -%}
              {%- assign f = raw | split: '~' -%}
              {%- assign p = all_products[f[0]] -%}
              {%- if p != blank -%}
                {%- assign v = p.selected_or_first_available_variant -%}
                {%- assign img = p.featured_image -%}
                {%- assign price_money = v.price | money_without_trailing_zeros -%}
                {%- assign was_money = '' -%}
                {%- if v.compare_at_price and v.compare_at_price > v.price -%}
                  {%- assign was_money = v.compare_at_price | money_without_trailing_zeros -%}
                {%- endif -%}
                <button type="button" class="tile" data-id="tile-books-{{ p.handle }}" data-handle="{{ p.handle }}" data-variant-id="{{ v.id }}" data-price="{{ v.price }}" data-was="{% if v.compare_at_price and v.compare_at_price > v.price %}{{ v.compare_at_price }}{% endif %}" data-label="{{ f[1] | escape }}" data-section="books" aria-pressed="false">
                  <div class="tile-img" style="background:{{ f[2] }};">
                    {%- if img -%}
                      <img src="{{ img | image_url: width: 300 }}" srcset="{{ img | image_url: width: 200 }} 200w, {{ img | image_url: width: 300 }} 300w, {{ img | image_url: width: 400 }} 400w" sizes="(max-width: 600px) 25vw, 150px" loading="lazy" decoding="async" alt="{{ f[1] | escape }}" width="300" height="300">
                    {%- else -%}
                      {{ f[3] }}
                    {%- endif -%}
                    {%- if f[4] != '' -%}<span class="img-badge">{{ f[4] }}</span>{%- endif -%}
                  </div>
                  <div class="tile-body">
                    <div class="tile-title">{{ f[1] }}</div>
                    <div class="tile-price">
                      {%- if was_money != '' -%}<span class="tile-was">{{ was_money }}</span>{%- endif -%}
                      {{ price_money }}
                    </div>
                  </div>
                  <span class="tile-check" aria-hidden="true">✓</span>
                </button>
              {%- endif -%}
            {%- endfor -%}
          </div>

          <button type="button" class="more-toggle" data-more="books" aria-expanded="false">+ More books (Kombucha)</button>
          <div class="more-content" data-more-content="books">
            <div class="tiles cols-4" data-group="books">
              {%- for raw in books_more_data | split: '|' -%}
                {%- assign f = raw | split: '~' -%}
                {%- assign p = all_products[f[0]] -%}
                {%- if p != blank -%}
                  {%- assign v = p.selected_or_first_available_variant -%}
                  {%- assign img = p.featured_image -%}
                  {%- assign price_money = v.price | money_without_trailing_zeros -%}
                  {%- assign was_money = '' -%}
                  {%- if v.compare_at_price and v.compare_at_price > v.price -%}
                    {%- assign was_money = v.compare_at_price | money_without_trailing_zeros -%}
                  {%- endif -%}
                  <button type="button" class="tile" data-id="tile-books-{{ p.handle }}" data-handle="{{ p.handle }}" data-variant-id="{{ v.id }}" data-price="{{ v.price }}" data-was="{% if v.compare_at_price and v.compare_at_price > v.price %}{{ v.compare_at_price }}{% endif %}" data-label="{{ f[1] | escape }}" data-section="books" aria-pressed="false">
                    <div class="tile-img" style="background:{{ f[2] }};">
                      {%- if img -%}
                        <img src="{{ img | image_url: width: 300 }}" srcset="{{ img | image_url: width: 200 }} 200w, {{ img | image_url: width: 300 }} 300w, {{ img | image_url: width: 400 }} 400w" sizes="(max-width: 600px) 25vw, 150px" loading="lazy" decoding="async" alt="{{ f[1] | escape }}" width="300" height="300">
                      {%- else -%}
                        {{ f[3] }}
                      {%- endif -%}
                      {%- if f[4] != '' -%}<span class="img-badge">{{ f[4] }}</span>{%- endif -%}
                    </div>
                    <div class="tile-body">
                      <div class="tile-title">{{ f[1] }}</div>
                      <div class="tile-price">
                        {%- if was_money != '' -%}<span class="tile-was">{{ was_money }}</span>{%- endif -%}
                        {{ price_money }}
                      </div>
                    </div>
                    <span class="tile-check" aria-hidden="true">✓</span>
                  </button>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        </section>

        <div class="reset-row">
          <button type="button" class="reset-btn" id="reset-btn">↻ Start over</button>
        </div>

      </div>{%- comment -%} /builder-stack {%- endcomment -%}

      {% render 'byok-bundle-sidebar' %}

    </div>{%- comment -%} /builder-grid {%- endcomment -%}
  </div>{%- comment -%} /page-wrap {%- endcomment -%}

  {% render 'byok-mobile-bar' %}

  {%- comment -%}
    Ferment sub-option data — emitted server-side so JS knows variant IDs,
    labels, prices, and compare-at prices for each chip.
  {%- endcomment -%}
  <script type="application/json" id="byok-data">
    {
      "ferments": {
        "kanji": {
          "name": "Kanji",
          "color": "kanji",
          "chips": [
            {%- if p_kanji_3 != blank -%}
              {
                "id": "kanji-3",
                "label": "Pack of 3",
                "handle": "{{ p_kanji_3.handle }}",
                "variantId": {{ p_kanji_3.selected_or_first_available_variant.id }},
                "price": {{ p_kanji_3.selected_or_first_available_variant.price }},
                "was": {% if p_kanji_3.selected_or_first_available_variant.compare_at_price %}{{ p_kanji_3.selected_or_first_available_variant.compare_at_price }}{% else %}null{% endif %}
              }{% if p_kanji_5 != blank or p_kanji_10 != blank %},{% endif %}
            {%- endif -%}
            {%- if p_kanji_5 != blank -%}
              {
                "id": "kanji-5",
                "label": "Pack of 5",
                "handle": "{{ p_kanji_5.handle }}",
                "variantId": {{ p_kanji_5.selected_or_first_available_variant.id }},
                "price": {{ p_kanji_5.selected_or_first_available_variant.price }},
                "was": {% if p_kanji_5.selected_or_first_available_variant.compare_at_price %}{{ p_kanji_5.selected_or_first_available_variant.compare_at_price }}{% else %}null{% endif %}
              }{% if p_kanji_10 != blank %},{% endif %}
            {%- endif -%}
            {%- if p_kanji_10 != blank -%}
              {
                "id": "kanji-10",
                "label": "Pack of 10",
                "handle": "{{ p_kanji_10.handle }}",
                "variantId": {{ p_kanji_10.selected_or_first_available_variant.id }},
                "price": {{ p_kanji_10.selected_or_first_available_variant.price }},
                "was": {% if p_kanji_10.selected_or_first_available_variant.compare_at_price %}{{ p_kanji_10.selected_or_first_available_variant.compare_at_price }}{% else %}null{% endif %}
              }
            {%- endif -%}
          ]
        },
        "aampanna": {
          "name": "Aam Panna",
          "color": "aam-panna",
          "chips": [
            {%- if p_aam_5 != blank -%}
              {
                "id": "aampanna-5",
                "label": "Pack of 5",
                "handle": "{{ p_aam_5.handle }}",
                "variantId": {{ p_aam_5.selected_or_first_available_variant.id }},
                "price": {{ p_aam_5.selected_or_first_available_variant.price }},
                "was": {% if p_aam_5.selected_or_first_available_variant.compare_at_price %}{{ p_aam_5.selected_or_first_available_variant.compare_at_price }}{% else %}null{% endif %}
              }
            {%- endif -%}
          ]
        },
        "achaar": {
          "name": "Achaar",
          "color": "achaar",
          "chips": [
            {%- if p_achaar_6 != blank -%}
              {
                "id": "achaar-6",
                "label": "6-Batch Refill",
                "handle": "{{ p_achaar_6.handle }}",
                "variantId": {{ p_achaar_6.selected_or_first_available_variant.id }},
                "price": {{ p_achaar_6.selected_or_first_available_variant.price }},
                "was": {% if p_achaar_6.selected_or_first_available_variant.compare_at_price %}{{ p_achaar_6.selected_or_first_available_variant.compare_at_price }}{% else %}null{% endif %}
              }
            {%- endif -%}
          ]
        },
        "kimchi": {
          "name": "Kimchi",
          "color": "kimchi",
          "chips": [
            {%- if p_kimchi_1 != blank -%}
              {
