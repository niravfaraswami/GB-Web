{%- liquid
  assign p = product
  assign mf_faqs = p.metafields.custom.featured_faqs.value
  assign mf_faq_h = p.metafields.custom.faq_h
  assign mf_faq_eyebrow = p.metafields.custom.faq_eyebrow
-%}
{%- if section.settings.show_section -%}
  {%- if mf_faqs == blank or mf_faqs.size == 0 -%}
    {%- comment -%} No FAQs — hide section {%- endcomment -%}
  {%- else -%}
    <section class="fk-page ferment-pdp fk-faq-section faq-section" style="background:{{ section.settings.section_bg }}">
      {%- render 'fk-color-cascade' -%}
      <div class="container">
        <div class="section-header centered">
          <div class="eyebrow">{{ mf_faq_eyebrow | default: section.settings.faq_eyebrow | default: 'QUESTIONS?' }}</div>
          {%- if mf_faq_h != blank -%}
            <h2>{{ mf_faq_h }}</h2>
          {%- else -%}
            <h2>{{ section.settings.faq_heading | default: 'COMMON' }} <em>{{ section.settings.faq_heading_em | default: 'QUESTIONS' }}</em></h2>
          {%- endif -%}
        </div>
        <div class="faq-list">
          {%- for f in mf_faqs -%}
            <div class="faq-item {% if forloop.first %}open{% endif %}" data-faq>
              <div class="faq-q"><span>{{ f.question }}</span><span class="faq-toggle">+</span></div>
              <div class="faq-a">{{ f.answer | newline_to_br }}</div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "FK — FAQ",
  "tag": "section",
  "class": "fk-faq-section",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show section", "default": true },
    { "type": "color", "id": "section_bg", "label": "Section background", "default": "#ffffff" },
    { "type": "text", "id": "faq_eyebrow", "label": "Eyebrow fallback", "default": "QUESTIONS?" },
    { "type": "text", "id": "faq_heading", "label": "Heading fallback", "default": "COMMON" },
    { "type": "text", "id": "faq_heading_em", "label": "Heading (em) fallback", "default": "QUESTIONS" }
  ],
  "presets": [ { "name": "FK — FAQ" } ],
  "enabled_on": { "templates": ["product"] }
}
{% endschema %}
