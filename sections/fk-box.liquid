{%- liquid
  assign p = product
  assign mf_components = p.metafields.custom.featured_components.value
  assign mf_box_h1 = p.metafields.custom.box_h1
  assign mf_box_h2 = p.metafields.custom.box_h2
  assign mf_box_image = p.metafields.custom.box_image
  assign mf_box_note = p.metafields.custom.box_note
-%}
{%- if section.settings.show_section -%}
  {%- if mf_components == blank or mf_components.size == 0 -%}
    {%- comment -%} No box components — hide section {%- endcomment -%}
  {%- else -%}
    <section class="fk-page ferment-pdp fk-box-section box-section" style="background:{{ section.settings.section_bg }}">
      {%- render 'fk-color-cascade' -%}
      <div class="container">
        <div class="section-header">
          <div class="eyebrow">{{ section.settings.box_eyebrow | default: "WHAT'S IN THE BOX" }}</div>
          {%- if mf_box_h1 != blank or mf_box_h2 != blank -%}
            <h2>{{ mf_box_h1 }}<br><em>{{ mf_box_h2 }}</em></h2>
          {%- else -%}
            <h2>{{ section.settings.box_heading | default: 'EVERYTHING YOU NEED' }}<br><em>{{ section.settings.box_heading_em | default: 'TO FERMENT.' }}</em></h2>
          {%- endif -%}
        </div>
        <div class="box-grid">
          <div class="box-image">
            {%- if mf_box_image != blank -%}
              <img src="{{ mf_box_image | image_url: width: 1200 }}" alt="What is in the box" loading="lazy" width="1200" height="750">
            {%- else -%}🫙{%- endif -%}
          </div>
          <div>
            <div class="box-pills">
              {%- for c in mf_components -%}
                <div class="box-pill">
                  <span class="bp-icon">
                    {%- if c.icon != blank -%}
                      {%- render 'kit_icon', icon: c.icon, size: 28, extra: 'bp-icon-img' -%}
                    {%- else -%}{{ forloop.index }}{%- endif -%}
                  </span>
                  <span class="bp-name">{{ c.name }}</span>
                  <span class="bp-sub">{{ c.description }}</span>
                </div>
              {%- endfor -%}
            </div>
            {%- if mf_box_note != blank -%}<p class="box-note">{{ mf_box_note }}</p>{%- endif -%}
          </div>
        </div>
      </div>
    </section>
  {%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "FK — Box",
  "tag": "section",
  "class": "fk-box-section",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show section", "default": true },
    { "type": "color", "id": "section_bg", "label": "Section background", "default": "#ffffff" },
    { "type": "text", "id": "box_eyebrow", "label": "Eyebrow", "default": "WHAT'S IN THE BOX" },
    { "type": "text", "id": "box_heading", "label": "Heading fallback", "default": "EVERYTHING YOU NEED" },
    { "type": "text", "id": "box_heading_em", "label": "Heading (em) fallback", "default": "TO FERMENT." }
  ],
  "presets": [ { "name": "FK — Box" } ],
  "enabled_on": { "templates": ["product"] }
}
{% endschema %}
