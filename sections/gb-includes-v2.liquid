    {
      "type": "header",
      "content": "Right block (Needed)"
    },
    {
      "type": "text",
      "id": "right_pill",
      "label": "Right pill label",
      "default": "YOU'LL NEED"
    },
    {
      "type": "text",
      "id": "right_heading",
      "label": "Right heading",
      "default": "What you'll need at home"
