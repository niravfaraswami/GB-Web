    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "EVERYTHING IN"
    },
    {
      "type": "text",
      "id": "heading_em",
      "label": "Heading (highlighted)",
      "default": "THE BAG."
    },
    {
      "type": "header",
      "content": "Left block (Included)"
    },
    {
      "type": "text",
      "id": "left_pill",
      "label": "Left pill label",
