{%- render 'leo_kit_chrome' -%}

{%- if section.settings.sci_h != blank -%}
  <section class="science-stag-section ferment-pdp-leo" {%- render 'leo_kit_attrs' -%}>
    <div class="container">
      <div class="section-header centered">
        <div class="eyebrow">{{ section.settings.sci_eyebrow }}</div>
        <h2>{{ section.settings.sci_h }} <em>{{ section.settings.sci_h_em }}</em></h2>
      </div>

      <div class="science-stag-grid">
        {%- assign stat_idx = 1 -%}
        {%- assign img_idx = 1 -%}
        {%- assign order = 'stat,img,stat,img,img,stat,img,stat' | split: ',' -%}
        {%- for kind in order -%}
          {%- if kind == 'stat' -%}
            {%- assign num_key = 'sci_stat' | append: stat_idx | append: '_num' -%}
            {%- assign unit_key = 'sci_stat' | append: stat_idx | append: '_unit' -%}
            {%- assign h_key = 'sci_stat' | append: stat_idx | append: '_h' -%}
            {%- assign d_key = 'sci_stat' | append: stat_idx | append: '_d' -%}
            {%- assign img_key = 'sci_stat' | append: stat_idx | append: '_img' -%}
            {%- assign s_num = section.settings[num_key] -%}
            {%- assign s_unit = section.settings[unit_key] -%}
            {%- assign s_h = section.settings[h_key] -%}
            {%- assign s_d = section.settings[d_key] -%}
            {%- assign s_img = section.settings[img_key] -%}
            {%- if s_num != blank or s_h != blank -%}
              <div class="science-stag-card sci-stat">
                {%- if s_img != blank -%}<img class="sci-stat-bg" src="{{ s_img | image_url: width: 800 }}" alt="{{ s_h | escape }}" loading="lazy" width="600" height="450">{%- endif -%}
                <div class="sci-stat-eyebrow">{{ section.settings.sci_stat_eyebrow | default: 'REPORTED' }}</div>
                <div>
                  <div class="sci-stat-num">{{ s_num }}{%- if s_unit != blank %}<span>{{ s_unit }}</span>{%- endif -%}</div>
                  <div class="sci-stat-h">{{ s_h }}</div>
                  <div class="sci-stat-d">{{ s_d }}</div>
                </div>
              </div>
            {%- endif -%}
            {%- assign stat_idx = stat_idx | plus: 1 -%}
          {%- else -%}
            {%- assign img_key2 = 'sci_img' | append: img_idx -%}
            {%- assign s_img2 = section.settings[img_key2] -%}
            {%- if s_img2 != blank -%}
              <div class="science-stag-card sci-image">
                <img src="{{ s_img2 | image_url: width: 800 }}" alt="Science image {{ img_idx }}" loading="lazy" width="600" height="450">
              </div>
            {%- endif -%}
            {%- assign img_idx = img_idx | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if section.settings.sci_caption != blank -%}<div class="science-stag-caption">{{ section.settings.sci_caption }}</div>{%- endif -%}
      {%- if section.settings.sci_disclaimer != blank -%}<div class="science-stag-disclaimer">{{ section.settings.sci_disclaimer }}</div>{%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Leo · Science",
  "tag": "section",
  "class": "leo-science-section",
  "settings": [
    { "type": "text", "id": "sci_eyebrow", "label": "Eyebrow", "default": "THE SCIENCE" },
    { "type": "text", "id": "sci_h", "label": "Heading", "default": "WHAT FERMENTED DRINKS DO" },
    { "type": "text", "id": "sci_h_em", "label": "Heading (highlighted)", "default": "FOR YOU." },
    { "type": "text", "id": "sci_stat_eyebrow", "label": "Stat-card eyebrow", "default": "REPORTED" },
    { "type": "image_picker", "id": "sci_stat1_img", "label": "Stat 1 — background image" },
    { "type": "text", "id": "sci_stat1_num", "label": "Stat 1 — number", "default": "47" },
    { "type": "text", "id": "sci_stat1_unit", "label": "Stat 1 — unit", "default": "%" },
    { "type": "text", "id": "sci_stat1_h", "label": "Stat 1 — heading", "default": "Better Mood" },
    { "type": "textarea", "id": "sci_stat1_d", "label": "Stat 1 — description", "default": "After adding fermented drinks for just 14 days." },
    { "type": "image_picker", "id": "sci_stat2_img", "label": "Stat 2 — background image" },
    { "type": "text", "id": "sci_stat2_num", "label": "Stat 2 — number", "default": "56" },
    { "type": "text", "id": "sci_stat2_unit", "label": "Stat 2 — unit", "default": "%" },
    { "type": "text", "id": "sci_stat2_h", "label": "Stat 2 — heading", "default": "More Energy" },
    { "type": "textarea", "id": "sci_stat2_d", "label": "Stat 2 — description", "default": "Without supplements or lifestyle changes." },
    { "type": "image_picker", "id": "sci_stat3_img", "label": "Stat 3 — background image" },
    { "type": "text", "id": "sci_stat3_num", "label": "Stat 3 — number", "default": "42" },
    { "type": "text", "id": "sci_stat3_unit", "label": "Stat 3 — unit", "default": "%" },
    { "type": "text", "id": "sci_stat3_h", "label": "Stat 3 — heading", "default": "Less Bloating" },
    { "type": "textarea", "id": "sci_stat3_d", "label": "Stat 3 — description", "default": "From everyday fermented drinks like kanji." },
    { "type": "image_picker", "id": "sci_stat4_img", "label": "Stat 4 — background image" },
    { "type": "text", "id": "sci_stat4_num", "label": "Stat 4 — number", "default": "52" },
    { "type": "text", "id": "sci_stat4_unit", "label": "Stat 4 — unit", "default": "%" },
    { "type": "text", "id": "sci_stat4_h", "label": "Stat 4 — heading", "default": "Less Hunger" },
    { "type": "textarea", "id": "sci_stat4_d", "label": "Stat 4 — description", "default": "Linked to improved gut health." },
    { "type": "image_picker", "id": "sci_img1", "label": "Filler image 1" },
    { "type": "image_picker", "id": "sci_img2", "label": "Filler image 2" },
    { "type": "image_picker", "id": "sci_img3", "label": "Filler image 3" },
    { "type": "image_picker", "id": "sci_img4", "label": "Filler image 4" },
    { "type": "richtext", "id": "sci_caption", "label": "Caption", "default": "<p>Based on a <strong>5,400+ person</strong> study on fermented drink intake.</p>" },
    { "type": "textarea", "id": "sci_disclaimer", "label": "Disclaimer", "default": "*Results from observational studies on fermented drink intake. Individual results vary." }
  ],
  "presets": [{ "name": "Leo · Science" }]
}
{% endschema %}