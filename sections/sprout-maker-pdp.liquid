<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=DM+Sans:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
{{ 'sprout-maker.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  SEO overrides (custom.seo_title_override, custom.seo_description_override)
  are intentionally NOT rendered here — sections render inside <body>, so
  they can't influence <head>. To wire these up, add this to theme.liquid:

    <title>{%- if request.page_type == 'product' and product.metafields.custom.seo_title_override != blank -%}
      {{ product.metafields.custom.seo_title_override }}
    {%- else -%}{{ page_title }}{%- endif -%}</title>

    <meta name="description" content="{%- if request.page_type == 'product' and product.metafields.custom.seo_description_override != blank -%}
      {{ product.metafields.custom.seo_description_override | escape }}
    {%- else -%}{{ page_description | escape }}{%- endif -%}">

  Until then, use Shopify's built-in SEO fields on each product
  (Edit website SEO) — they end up in page_title / page_description.
{%- endcomment -%}

{%- liquid
  assign p = product
  assign tagline = p.metafields.custom.hero_tagline | default: 'Fresh, crunchy sprouts in 2–3 days. No smell. No mess. Just water and a jar.'
  assign save_badge = p.metafields.custom.discount_badge
  assign rating = p.metafields.custom.rating | default: 4.85
  assign review_count = p.metafields.custom.review_count | default: 0
  assign jar_capacity = p.metafields.custom.jar_capacity | default: p.metafields.custom.capacity | default: '700ml'
  assign size_chart   = p.metafields.custom.jar_size_chart_image | default: p.metafields.custom.size_chart_image
  assign companion = p.metafields.custom.companion_size_product.value
  assign hero_trust = p.metafields.custom.hero_trust_strip.value
  assign activity = p.metafields.custom.activity_items.value
  assign benefits = p.metafields.custom.benefits_items.value
  assign cross_sell_products = p.metafields.custom.cross_sell_products.value
  assign days_subtitle = p.metafields.custom.days_subtitle
  assign days_to_ferment = p.metafields.custom.days_to_ferment

  assign mf_compare_left  = p.metafields.custom.comparison_left_image
  assign mf_compare_right = p.metafields.custom.comparison_right_image
  assign mf_compare_intro = p.metafields.custom.comparison_intro
  assign mf_box_image     = p.metafields.custom.box_image
  assign mf_box_note      = p.metafields.custom.box_note
  assign mf_how_video     = p.metafields.custom.how_to_make_video
  assign mf_hero_icons    = p.metafields.custom.hero_benefits_icons.value
  assign mf_benefit_icons = p.metafields.custom.benefits_icons.value
  assign mf_trust_icons   = p.metafields.custom.trust_strip_icons.value
  assign mf_step_icons    = p.metafields.custom.step_icons.value
  assign mf_reviews       = p.metafields.custom.featured_reviews.value
  assign mf_faqs          = p.metafields.custom.featured_faqs.value
  assign mf_steps         = p.metafields.custom.featured_steps.value
  assign mf_components    = p.metafields.custom.featured_components.value
  assign mf_trust_cards   = p.metafields.custom.featured_trust_cards.value
  assign mf_quick_bens    = p.metafields.custom.featured_quick_benefits.value
  assign mf_compare_rows  = p.metafields.custom.featured_comparison_rows.value
  assign mf_reels         = p.metafields.custom.featured_reels.value
-%}

<div data-kit="sprouts" class="sprout-pdp">

  <pre id="gb-debug-panel" style="display:none;position:fixed;bottom:0;left:0;right:0;max-height:50vh;overflow:auto;background:#1f1f1d;color:#e8f4dc;font:11px/1.4 monospace;padding:14px;z-index:99999;border-top:3px solid #ff7300;white-space:pre-wrap;word-break:break-all;">[GB DEBUG · ?gbdebug=1]
featured_reviews exists?              {% if p.metafields.custom.featured_reviews %}YES{% else %}NO{% endif %}
featured_reviews.type               = {{ p.metafields.custom.featured_reviews.type | default: 'nil' }}
featured_reviews.value.size         = {{ p.metafields.custom.featured_reviews.value.size | default: 0 }}
mf_reviews assigned blank?          = {% if mf_reviews == blank %}YES (won't render){% else %}NO{% endif %}

featured_reviews.value (first entry):
  type:    {{ p.metafields.custom.featured_reviews.value.first.type | default: 'nil' }}
  handle:  {{ p.metafields.custom.featured_reviews.value.first.system.handle | default: 'nil' }}
  quote:   {{ p.metafields.custom.featured_reviews.value.first.quote | default: '(empty)' }}
  name:    {{ p.metafields.custom.featured_reviews.value.first.name | default: '(empty)' }}
  meta:    {{ p.metafields.custom.featured_reviews.value.first.meta | default: '(empty)' }}
  photo:   {% if p.metafields.custom.featured_reviews.value.first.photo %}{{ p.metafields.custom.featured_reviews.value.first.photo | image_url: width: 80 }}{% else %}(empty){% endif %}

All product custom metafields with non-empty values:
{%- for mf in p.metafields.custom -%}
  {%- if mf[1] != blank %}
  • custom.{{ mf[0] }} ({{ mf[1].type }}) — list size: {{ mf[1].value.size | default: '—' }}
  {%- endif -%}
{%- endfor %}
</pre>
  <script>
    if (location.search.indexOf('gbdebug=1') !== -1) {
      var p = document.getElementById('gb-debug-panel');
      if (p) p.style.display = 'block';
    }
  </script>

  {%- comment %} ============== 1. HERO ============== {% endcomment -%}
  <section class="pdp-hero">
    <div class="container">
      {%- if section.settings.show_breadcrumb -%}
        {%- render 'gb-breadcrumb' -%}
      {%- endif -%}

      <div class="hero-title-block">
        <h1 class="product-name">{{ p.title }}</h1>
        <p class="product-tagline">{{ tagline }}</p>
      </div>

      <div class="hero-grid">
        <div class="gallery-stack">
          <div class="gallery-main">
            {%- if p.featured_image -%}
              <img class="gallery-main-img"
                   src="{{ p.featured_image | image_url: width: 1200 }}"
                   srcset="{{ p.featured_image | image_url: width: 600 }} 600w, {{ p.featured_image | image_url: width: 1200 }} 1200w, {{ p.featured_image | image_url: width: 1800 }} 1800w"
                   sizes="(min-width: 768px) 50vw, 100vw"
                   alt="{{ p.featured_image.alt | default: p.title | escape }}"
                   loading="eager"
                   width="{{ p.featured_image.width }}"
                   height="{{ p.featured_image.height }}">
            {%- else -%}
              <div class="gallery-illustration">🌱</div>
            {%- endif -%}
            {%- if p.images.size > 1 -%}
              <button class="gallery-nav gallery-nav--prev" type="button" data-gallery-prev aria-label="Previous image">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
              </button>
              <button class="gallery-nav gallery-nav--next" type="button" data-gallery-next aria-label="Next image">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>
              </button>
            {%- endif -%}
          </div>
          {%- if p.images.size > 1 -%}
            <div class="gallery-thumbs">
              {%- for image in p.images limit: 8 -%}
                <button class="gallery-thumb {% if forloop.first %}active{% endif %}" type="button"
                        data-full-src="{{ image | image_url: width: 1200 }}"
                        data-full-alt="{{ image.alt | default: p.title | escape }}"
                        aria-label="View image {{ forloop.index }}">
                  <img src="{{ image | image_url: width: 180 }}"
                       alt="{{ image.alt | default: p.title | escape }}"
                       loading="lazy" width="90" height="90">
                </button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>

        <div class="product-info">
          {%- if review_count > 0 -%}
            <div class="rating-row">
              <span class="stars" aria-label="{{ rating }} out of 5">★★★★★</span>
              <a href="#judgeme-reviews" class="rating-link">{{ rating }} ({{ review_count }} reviews)</a>
            </div>
          {%- endif -%}

          <div class="activity-row">
            {%- render 'gb-bought-today' -%}
            {%- if days_to_ferment != blank -%}
              <div class="item"><span>⚡</span><span>{{ days_subtitle | default: 'Sprouts ready in' }} <strong>{{ days_to_ferment }} days</strong></span></div>
            {%- endif -%}
            {%- if activity != blank -%}
              {%- for item in activity -%}
                {%- assign parts = item | split: '|' -%}
                <div class="item"><span>{{ parts[0] }}</span><span>{{ parts[1] }}</span></div>
              {%- endfor -%}
            {%- endif -%}
          </div>

          {%- if benefits != blank -%}
            <div class="benefits-block">
              <div class="label">Why this kit</div>
              <div class="benefits-grid">
                {%- for b in benefits -%}
                  {%- assign parts = b | split: '|' -%}
                  {%- comment -%} Shopify file_reference list Drops don't support [i] indexing — pluck via nested loop {%- endcomment -%}
                  {%- assign target_idx = forloop.index0 -%}
                  {%- assign mf_icon = nil -%}
                  {%- if mf_hero_icons -%}
                    {%- for ic in mf_hero_icons -%}
                      {%- if forloop.index0 == target_idx -%}{%- assign mf_icon = ic -%}{%- endif -%}
                    {%- endfor -%}
                  {%- endif -%}
                  {%- assign icon_src = mf_icon | image_url: width: 56 -%}
                  {%- if icon_src == blank -%}{%- assign icon_src = mf_icon.url -%}{%- endif -%}
                  {%- if icon_src == blank -%}{%- assign icon_src = mf_icon.src -%}{%- endif -%}
                  <div class="benefit-item">
                    <span class="benefit-icon{% if icon_src != blank %} benefit-icon--img{% endif %}">
                      {%- if icon_src != blank -%}
                        <span class="kit-icon-svg" data-svg-src="{{ icon_src }}" aria-hidden="true"></span>
                        <img class="kit-icon-img" src="{{ icon_src }}" alt="" loading="lazy" width="24" height="24">
                      {%- else -%}
                        {{ parts[0] }}
                      {%- endif -%}
                    </span>
                    <span>{{ parts[1] }}</span>
                  </div>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}

          {%- form 'product', p, id: 'sprout-product-form' -%}
            <div class="variant-block">
              {%- assign opt_name = p.options.first | default: 'Pack' -%}
              <div class="variant-label">Select {{ opt_name }}</div>
              <div class="variant-grid">
                {%- for variant in p.variants -%}
                  {%- assign v_tag = variant.metafields.custom.tag -%}
                  {%- assign v_best = variant.metafields.custom.best_for -%}
                  {%- assign is_selected = false -%}
                  {%- if variant == p.selected_or_first_available_variant -%}{%- assign is_selected = true -%}{%- endif -%}
                  <label class="variant{% if is_selected %} active{% endif %}{% unless variant.available %} sold-out{% endunless %}"
                         data-variant-id="{{ variant.id }}"
                         data-variant-price="{{ variant.price | money }}"
                         data-variant-price-cents="{{ variant.price }}"
                         data-variant-compare-cents="{{ variant.compare_at_price }}">
                    <input type="radio" name="id" value="{{ variant.id }}" class="variant-input"
                           {% if is_selected %}checked{% endif %}
                           {% unless variant.available %}disabled{% endunless %}>
                    {%- if v_tag != blank -%}<span class="variant-tag">{{ v_tag }}</span>{%- endif -%}
                    <span class="variant-radio"></span>
                    <div class="variant-pack">{{ variant.title | upcase }}</div>
                    {%- if v_best != blank -%}
                      <div class="variant-rationale">
                        <div class="vr-row"><span class="vr-label">BEST FOR</span><span class="vr-text">{{ v_best }}</span></div>
                      </div>
                    {%- endif -%}
                    <div class="variant-price">
                      <span>{{ variant.price | money }}</span>
                      {%- if variant.compare_at_price > variant.price -%}
                        <span class="variant-compare">{{ variant.compare_at_price | money }}</span>
                      {%- endif -%}
                    </div>
                    {%- if variant.compare_at_price > variant.price -%}
                      <span class="variant-save">You save {{ variant.compare_at_price | minus: variant.price | money }}</span>
                    {%- endif -%}
                    {%- unless variant.available -%}
                      <span class="variant-sold-out">Sold out</span>
                    {%- endunless -%}
                  </label>
                {%- endfor -%}
              </div>

              {%- if size_chart != blank or p.metafields.custom.help_note != blank -%}
                <div class="variant-help-note">
                  <span class="vhn-text">{{ p.metafields.custom.help_note | default: 'Choose the pack that fits your household.' }}</span>
                  {%- if size_chart != blank -%}
                    <button type="button" class="vhn-link" data-open-size-modal>Jar Size Chart →</button>
                  {%- endif -%}
                </div>
              {%- endif -%}

              {%- if companion -%}
                {%- assign other_capacity = companion.metafields.custom.jar_capacity | default: 'other capacity' -%}
                <a href="{{ companion.url }}" class="companion-link">
                  Looking for the {{ other_capacity }} jar? View {{ companion.title }} →
                </a>
              {%- endif -%}
            </div>

            <button type="submit" name="add" class="atc-btn" data-atc
                    data-product-id="{{ p.id }}"
                    data-product-title="{{ p.title | escape }}"
                    data-product-image="{{ p.featured_image | image_url: width: 200 }}"
                    data-product-price="{{ p.price }}"
                    data-product-url="{{ p.url }}"
                    {% unless p.available %}disabled{% endunless %}>
              {%- if p.available -%}ADD TO CART{%- else -%}SOLD OUT{%- endif -%}
            </button>
          {%- endform -%}

          <div class="trust-strip">
            {%- if hero_trust != blank -%}
              {%- for t in hero_trust -%}
                <div class="item"><span class="check">✓</span> {{ t }}</div>
              {%- endfor -%}
            {%- else -%}
              <div class="item"><span class="check">✓</span> Free Shipping</div>
              <div class="item"><span class="check">✓</span> Sprouting-grade seeds</div>
              <div class="item"><span class="check">✓</span> FSSAI Licensed</div>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  </section>

  {%- comment %} ============== BLOCK-DRIVEN SECTIONS ============== {% endcomment -%}
  {%- liquid
    assign trust_blocks = section.blocks | where: 'type', 'trust_card'
    assign step_blocks = section.blocks | where: 'type', 'step'
    assign compare_blocks = section.blocks | where: 'type', 'comparison_row'
    assign benefit_blocks = section.blocks | where: 'type', 'benefit'
    assign reel_blocks = section.blocks | where: 'type', 'reel'
    assign component_blocks = section.blocks | where: 'type', 'box_component'
    assign review_blocks = section.blocks | where: 'type', 'review'
    assign faq_blocks = section.blocks | where: 'type', 'faq'
    assign cross_blocks = section.blocks | where: 'type', 'cross_sell_product'
  -%}

  {%- comment %} 2. TRUST ROW — metaobject list overrides blocks {% endcomment -%}
  {%- if mf_trust_cards != blank or trust_blocks.size > 0 -%}
    <section class="trust-row-section">
      <div class="container">
        <div class="trust-row-grid">
          {%- if mf_trust_cards != blank -%}
            {%- for tc in mf_trust_cards -%}
              <div class="tr-card">
                <div class="tr-icon">
                  {%- if tc.icon != blank -%}
                    <img src="{{ tc.icon | image_url: width: 88 }}" alt="{{ tc.heading | escape }}" loading="lazy" width="44" height="44" class="tr-icon-img">
                  {%- endif -%}
                </div>
                <div class="tr-h">{{ tc.heading }}</div>
                <div class="tr-d">{{ tc.description }}</div>
              </div>
            {%- endfor -%}
          {%- else -%}
            {%- for block in trust_blocks -%}
              {%- assign target_idx = forloop.index0 -%}
              {%- assign mf_icon = nil -%}
              {%- if mf_trust_icons -%}{%- for ic in mf_trust_icons -%}{%- if forloop.index0 == target_idx -%}{%- assign mf_icon = ic -%}{%- endif -%}{%- endfor -%}{%- endif -%}
              <div class="tr-card" {{ block.shopify_attributes }}>
                <div class="tr-icon">
                  {%- if mf_icon != blank -%}
                    <img src="{{ mf_icon | image_url: width: 88 }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="44" height="44" class="tr-icon-img">
                  {%- elsif block.settings.icon_image != blank -%}
                    <img src="{{ block.settings.icon_image | image_url: width: 88 }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="44" height="44" class="tr-icon-img">
                  {%- else -%}
                    {{ block.settings.icon }}
                  {%- endif -%}
                </div>
                <div class="tr-h">{{ block.settings.heading }}</div>
                <div class="tr-d">{{ block.settings.description }}</div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment %} 3. HOW TO MAKE — metaobject list overrides blocks {% endcomment -%}
  {%- if mf_steps != blank or step_blocks.size > 0 -%}
    <section class="how-make-section">
      <div class="container">
        <div class="section-header centered">
          <div class="eyebrow">{{ section.settings.how_eyebrow }}</div>
          <h2>{{ section.settings.how_heading }}<br><em>{{ section.settings.how_heading_em }}</em></h2>
        </div>
        {%- assign how_video = mf_how_video | default: section.settings.how_video -%}
        <div class="how-make-grid">
          <div class="hm-video-hero">
            {%- if how_video != blank -%}
              {{ how_video | video_tag: image_size: '1100x', controls: true, loop: true, muted: true, autoplay: false }}
            {%- elsif section.settings.how_poster != blank -%}
              <img src="{{ section.settings.how_poster | image_url: width: 1200 }}" alt="How to make sprouts" loading="lazy" width="1200" height="1200">
            {%- endif -%}
            {%- if section.settings.how_pill != blank -%}
              <span class="hm-watch-pill">{{ section.settings.how_pill }}</span>
            {%- endif -%}
          </div>
          <div class="hm-steps">
            {%- if mf_steps != blank -%}
              {%- for step in mf_steps -%}
                <div class="hm-step">
                  <div class="hm-num">
                    {%- if step.icon != blank -%}
                      <img src="{{ step.icon | image_url: width: 72 }}" alt="{{ step.title | escape }}" loading="lazy" width="36" height="36" class="hm-num-img">
                    {%- else -%}
                      {{ forloop.index }}
                    {%- endif -%}
                  </div>
                  <div class="hm-step-body">
                    <div class="hm-title">{{ step.title }}</div>
                    <div class="hm-desc">{{ step.description }}</div>
                  </div>
                </div>
              {%- endfor -%}
            {%- else -%}
              {%- for block in step_blocks -%}
                {%- assign target_idx = forloop.index0 -%}
                {%- assign mf_icon = nil -%}
                {%- if mf_step_icons -%}{%- for ic in mf_step_icons -%}{%- if forloop.index0 == target_idx -%}{%- assign mf_icon = ic -%}{%- endif -%}{%- endfor -%}{%- endif -%}
                <div class="hm-step" {{ block.shopify_attributes }}>
                  <div class="hm-num">
                    {%- if mf_icon != blank -%}
                      <img src="{{ mf_icon | image_url: width: 72 }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="36" height="36" class="hm-num-img">
                    {%- elsif block.settings.icon_image != blank -%}
                      <img src="{{ block.settings.icon_image | image_url: width: 72 }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="36" height="36" class="hm-num-img">
                    {%- else -%}
                      {{ forloop.index }}
                    {%- endif -%}
                  </div>
                  <div class="hm-step-body">
                    <div class="hm-title">{{ block.settings.title }}</div>
                    <div class="hm-desc">{{ block.settings.description }}</div>
                  </div>
                </div>
              {%- endfor -%}
            {%- endif -%}
          </div>
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment %} 4. COMPARISON — metaobject list overrides blocks {% endcomment -%}
  {%- if mf_compare_rows != blank or compare_blocks.size > 0 -%}
    <section class="myth-section">
      <div class="container">
        <div class="myth-header">
          <div class="eyebrow">{{ section.settings.compare_eyebrow }}</div>
          <h2>{{ section.settings.compare_heading }}<br><em>{{ section.settings.compare_heading_em }}</em></h2>
          {%- assign compare_intro = mf_compare_intro | default: section.settings.compare_intro -%}
          {%- if compare_intro != blank -%}
            <p style="margin-top:18px;">{{ compare_intro }}</p>
          {%- endif -%}
        </div>
        {%- assign cmp_left  = mf_compare_left  | default: section.settings.compare_left_image -%}
        {%- assign cmp_right = mf_compare_right | default: section.settings.compare_right_image -%}
        <div class="compare-block">
          <div class="compare-images">
            <div class="compare-image">
              {%- if cmp_left != blank -%}
                <img src="{{ cmp_left | image_url: width: 800 }}" alt="{{ section.settings.compare_left_label }}" loading="lazy" width="800" height="600">
              {%- else -%}{{ section.settings.compare_left_emoji }}{%- endif -%}
            </div>
            <div class="compare-image">
              {%- if cmp_right != blank -%}
                <img src="{{ cmp_right | image_url: width: 800 }}" alt="{{ section.settings.compare_right_label }}" loading="lazy" width="800" height="600">
              {%- else -%}{{ section.settings.compare_right_emoji }}{%- endif -%}
            </div>
          </div>
          <div class="compare-labels">
            <span>{{ section.settings.compare_left_label }}</span>
            <span>{{ section.settings.compare_right_label }}</span>
          </div>
          <div class="compare-table">
            {%- if mf_compare_rows != blank -%}
              {%- for row in mf_compare_rows -%}
                <div class="compare-row">
                  <div class="compare-cell left">
                    <div class="h">{{ row.left_heading }}</div>
                    <div class="s">{{ row.left_subtext }}</div>
                  </div>
                  <div class="compare-cell right">
                    <div class="h">{{ row.right_heading }}</div>
                    <div class="s">{{ row.right_subtext }}</div>
                  </div>
                </div>
              {%- endfor -%}
            {%- else -%}
              {%- for block in compare_blocks -%}
                <div class="compare-row" {{ block.shopify_attributes }}>
                  <div class="compare-cell left">
                    <div class="h">{{ block.settings.left_h }}</div>
                    <div class="s">{{ block.settings.left_s }}</div>
                  </div>
                  <div class="compare-cell right">
                    <div class="h">{{ block.settings.right_h }}</div>
                    <div class="s">{{ block.settings.right_s }}</div>
                  </div>
                </div>
              {%- endfor -%}
            {%- endif -%}
          </div>
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment %} 5. QUICK BENEFITS — metaobject list overrides blocks {% endcomment -%}
  {%- if mf_quick_bens != blank or benefit_blocks.size > 0 -%}
    <section class="outcomes-section">
      <div class="container">
        <div class="section-header centered">
          <div class="eyebrow">{{ section.settings.benefits_eyebrow }}</div>
          <h2>{{ section.settings.benefits_heading }}<br><em>{{ section.settings.benefits_heading_em }}</em></h2>
        </div>
        <div class="qb-grid">
          {%- if mf_quick_bens != blank -%}
            {%- for qb in mf_quick_bens -%}
