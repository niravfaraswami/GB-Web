    { "type": "range", "id": "cta_padding_x", "label": "CTA horizontal padding", "min": 14, "max": 48, "step": 1, "default": 24, "unit": "px" },
    { "type": "range", "id": "cta_font_size", "label": "CTA font size", "min": 11, "max": 18, "step": 1, "default": 13, "unit": "px" }
