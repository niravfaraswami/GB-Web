{%- comment -%}
  Section 10 · Reviews — cream, 3 review cards + rating pill
  Source ref: gutbasket-home-page.html lines 2455-2491
{%- endcomment -%}

<section class="gb-reviews">
  <div class="gb-reviews-container">
    <div class="gb-reviews-header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="gb-reviews-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="gb-reviews-h2">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.show_rating_pill -%}
        <div class="gb-reviews-rating">
          <span class="gb-reviews-stars">★★★★★</span>
          <span><strong>{{ section.settings.average_rating }}</strong> based on <strong>{{ section.settings.review_count }}</strong> {{ section.settings.review_count_label | default: 'verified reviews' }}</span>
        </div>
      {%- endif -%}
    </div>

    <div class="gb-reviews-grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign avatar_theme = block.settings.avatar_theme | default: 'kanji'
          assign rating = block.settings.rating | default: 5
        -%}
        <div class="gb-review-card" {{ block.shopify_attributes }}>
          <div class="gb-review-stars">
            {%- for i in (1..5) -%}{%- if i <= rating -%}★{%- else -%}☆{%- endif -%}{%- endfor -%}
          </div>
          <p class="gb-review-text">{{ block.settings.text }}</p>
          <div class="gb-review-author">
            <div class="gb-review-avatar gb-review-avatar--{{ avatar_theme }}">{{ block.settings.avatar_letter | default: 'A' }}</div>
            <div>
              <strong>{{ block.settings.name }}</strong>
              <span>{{ block.settings.meta }}</span>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
.gb-reviews {
  --c-white: #FFFFFF;
  --c-cream: #FFF9EE;
  --c-text: #1F1F1D;
  --c-text-muted: #5C4D3F;
  --c-border: #E8E3D5;
  --c-border-soft: #F0EBDD;
  --c-ink: #1F1F1D;
  --c-aam-panna: #DDA738;
  --c-kanji: #8B1F40;
  --c-sprout: #3F7754;
  background: var(--c-cream);
  padding: 64px 0;
}
.gb-reviews-container { max-width: 1180px; margin: 0 auto; padding: 0 24px; }
.gb-reviews-header { text-align: center; margin: 0 auto 36px; max-width: 720px; }
.gb-reviews-eyebrow {
  display: inline-block;
  font-family: 'DM Mono', monospace;
  font-size: 11px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  color: var(--c-text-muted);
  margin-bottom: 10px;
}
.gb-reviews-h2 {
  font-family: 'Montserrat', sans-serif;
  font-weight: 800;
  font-size: clamp(28px, 3.4vw, 38px);
  margin: 0 0 12px;
  letter-spacing: -0.02em;
  color: var(--c-text);
}
.gb-reviews-h2 em { font-style: italic; font-weight: 700; color: var(--c-kanji); }
.gb-reviews-rating {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  background: var(--c-white);
  border: 1px solid var(--c-border);
  padding: 10px 18px;
  border-radius: 999px;
  margin-top: 8px;
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  color: var(--c-text-muted);
}
.gb-reviews-rating strong { color: var(--c-text); font-weight: 700; }
.gb-reviews-stars { color: var(--c-aam-panna); font-size: 13px; letter-spacing: 1px; }
.gb-reviews-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 22px;
}
.gb-review-card {
  background: var(--c-white);
  border-radius: 14px;
  padding: 28px 26px;
  border: 1px solid var(--c-border-soft);
  display: flex;
  flex-direction: column;
}
.gb-review-stars {
  color: var(--c-aam-panna);
  font-size: 14px;
  letter-spacing: 1px;
  margin-bottom: 14px;
}
.gb-review-text {
  font-family: 'DM Sans', sans-serif;
  font-size: 14.5px;
  color: var(--c-text);
  line-height: 1.55;
  margin: 0 0 22px;
  flex: 1;
}
.gb-review-author { display: flex; align-items: center; gap: 12px; }
.gb-review-avatar {
  width: 38px; height: 38px;
  border-radius: 50%;
  color: var(--c-cream);
  display: flex; align-items: center; justify-content: center;
  font-family: 'Montserrat', sans-serif;
  font-weight: 800;
  font-size: 14px;
}
.gb-review-avatar--kanji  { background: var(--c-kanji);  color: var(--c-cream); }
.gb-review-avatar--sprout { background: var(--c-sprout); color: var(--c-cream); }
.gb-review-avatar--mustard { background: var(--c-aam-panna); color: var(--c-ink); }
.gb-review-author strong {
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 14px;
  display: block;
  color: var(--c-text);
}
.gb-review-author span {
  font-family: 'DM Sans', sans-serif;
  font-size: 12px;
  color: var(--c-text-muted);
}
@media (max-width: 768px) {
  .gb-reviews-grid { grid-template-columns: 1fr; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "GB · Home Reviews",
  "tag": "section",
  "class": "gb-reviews-wrap",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Real fermenters · real results" },
    { "type": "text", "id": "heading", "label": "Heading (use <em>)", "default": "Loved by <em>25,000+</em> kitchens." },
    { "type": "checkbox", "id": "show_rating_pill", "label": "Show rating pill", "default": true },
    { "type": "text", "id": "average_rating", "label": "Average rating", "default": "4.8" },
    { "type": "text", "id": "review_count", "label": "Review count", "default": "1,046" },
    { "type": "text", "id": "review_count_label", "label": "Review count label", "default": "verified reviews" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "limit": 12,
      "settings": [
        { "type": "range", "id": "rating", "label": "Stars", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "text", "label": "Review text", "default": "Great product." },
        { "type": "text", "id": "name", "label": "Name", "default": "Customer" },
        { "type": "text", "id": "meta", "label": "Location · product", "default": "City · Kit name" },
        { "type": "text", "id": "avatar_letter", "label": "Avatar letter", "default": "A" },
        { "type": "select", "id": "avatar_theme", "label": "Avatar color",
          "options": [
            { "value": "kanji",   "label": "Maroon" },
            { "value": "sprout",  "label": "Green" },
            { "value": "mustard", "label": "Mustard" }
          ],
          "default": "kanji" }
      ]
    }
  ],
  "presets": [
    {
      "name": "GB · Home Reviews",
      "blocks": [
        { "type": "review", "settings": { "rating": 5, "name": "Archana",     "meta": "Ahmedabad · Achaar kit", "avatar_letter": "A", "avatar_theme": "kanji",   "text": "\"Made raw mango achaar at home after a long time using this. The spice mix gives proper homemade taste, did not miss the oil at all.\"" } },
        { "type": "review", "settings": { "rating": 5, "name": "Ebe Chesney", "meta": "Mumbai · Vegetable kit", "avatar_letter": "E", "avatar_theme": "sprout",  "text": "\"I couldn't eat cruciferous vegetables and beans. With GutBasket's kit and instant guidance I made yummy fermented cauliflower. So fun, especially for an octogenarian like me.\"" } },
        { "type": "review", "settings": { "rating": 5, "name": "Nirav P.",    "meta": "Pune · Kanji kit",       "avatar_letter": "N", "avatar_theme": "mustard", "text": "\"The instructions were incredibly clear, with a step-by-step guide that even beginners can follow. The kit demystifies fermentation and makes it approachable.\"" } }
      ]
    }
  ]
}
{% endschema %}
