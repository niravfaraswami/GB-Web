{%- comment -%}
  Section 07 · How it works — 3 steps with dotted connector
  Source ref: gutbasket-home-page.html lines 2342-2366
{%- endcomment -%}

<section class="gb-how">
  <div class="gb-how-container">
    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <div class="gb-how-header">
        {%- if section.settings.eyebrow != blank -%}
          <span class="gb-how-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="gb-how-h2">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="gb-how-grid">
      {%- for block in section.blocks -%}
        <div class="gb-how-step" {{ block.shopify_attributes }}>
          <div class="gb-how-num">{{ forloop.index }}</div>
          <h4 class="gb-how-title">{{ block.settings.title }}</h4>
          <p class="gb-how-desc">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
.gb-how {
  --c-cream: #FFF9EE;
  --c-text: #1F1F1D;
  --c-text-muted: #5C4D3F;
  --c-border: #E8E3D5;
  --c-ink: #1F1F1D;
  --c-kanji: #8B1F40;
  background: #fff;
  padding: 64px 0;
}
.gb-how-container { max-width: 1180px; margin: 0 auto; padding: 0 24px; }
.gb-how-header { text-align: center; margin: 0 auto 36px; max-width: 720px; }
.gb-how-eyebrow {
  display: inline-block;
  font-family: 'DM Mono', monospace;
  font-size: 11px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  color: var(--c-text-muted);
  margin-bottom: 10px;
}
.gb-how-h2 {
  font-family: 'Montserrat', sans-serif;
  font-weight: 800;
  font-size: clamp(28px, 3.4vw, 38px);
  margin: 0;
  letter-spacing: -0.02em;
  color: var(--c-text);
}
.gb-how-h2 em { font-style: italic; font-weight: 700; color: var(--c-kanji); }
.gb-how-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  position: relative;
}
.gb-how-grid::before {
  content: '';
  position: absolute;
  top: 60px;
  left: 18%;
  right: 18%;
  height: 2px;
  background: repeating-linear-gradient(90deg, var(--c-border) 0 6px, transparent 6px 12px);
  z-index: 0;
}
.gb-how-step {
  position: relative;
  background: var(--c-cream);
  border-radius: 16px;
  padding: 32px 28px;
  text-align: center;
  z-index: 1;
}
.gb-how-num {
  width: 52px; height: 52px;
  border-radius: 50%;
  background: var(--c-ink);
  color: var(--c-cream);
  display: flex; align-items: center; justify-content: center;
  font-family: 'Montserrat', sans-serif;
  font-weight: 800;
  font-size: 22px;
  margin: 0 auto 20px;
}
.gb-how-title {
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 18px;
  margin: 0 0 8px;
  color: var(--c-text);
}
.gb-how-desc {
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  color: var(--c-text-muted);
  line-height: 1.5;
  margin: 0;
}
@media (max-width: 768px) {
  .gb-how-grid { grid-template-columns: 1fr; }
  .gb-how-grid::before { display: none; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "GB · Home How",
  "tag": "section",
  "class": "gb-how-wrap",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Make probiotics at home" },
    { "type": "text", "id": "heading", "label": "Heading (use <em>)", "default": "Three steps. <em>Five days.</em> One jar." }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Step title" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Description text" }
      ]
    }
  ],
  "presets": [
    {
      "name": "GB · Home How",
      "blocks": [
        { "type": "step", "settings": { "title": "Add ingredients", "description": "Open the kit, follow the recipe card, drop the spice mix into your fermentation jar." } },
        { "type": "step", "settings": { "title": "Let it ferment",  "description": "Seal with the airlock lid. Mold-free, set-and-forget. Cultures do the work for 3–5 days." } },
        { "type": "step", "settings": { "title": "Enjoy",           "description": "Refrigerate, pour, eat. One jar gives you 7–10 servings of live probiotic ferment." } }
      ]
    }
  ]
}
{% endschema %}
