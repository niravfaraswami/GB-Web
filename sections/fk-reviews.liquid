{%- liquid
  assign p = product
  assign mf_reviews = p.metafields.custom.featured_reviews.value
  assign mf_reviews_h = p.metafields.custom.reviews_h
-%}
{%- if section.settings.show_section -%}
  {%- if mf_reviews == blank or mf_reviews.size == 0 -%}
    {%- comment -%} No reviews — hide section {%- endcomment -%}
  {%- else -%}
    <section class="fk-page ferment-pdp fk-reviews-section reviews-section" style="background:{{ section.settings.section_bg }}">
      {%- render 'fk-color-cascade' -%}
      <div class="container">
        <div class="section-header">
          <div class="eyebrow">{{ section.settings.reviews_eyebrow | default: 'REAL RESULTS' }}</div>
          {%- if mf_reviews_h != blank -%}
            <h2>{{ mf_reviews_h }}</h2>
          {%- else -%}
            <h2>{{ section.settings.reviews_heading | default: 'WHAT OUR' }} <em>{{ section.settings.reviews_heading_em | default: 'CUSTOMERS SAY' }}</em></h2>
          {%- endif -%}
        </div>
        <div class="reviews-grid">
          {%- for r in mf_reviews -%}
            <div class="review-card">
              <div class="rev-content">
                <h3 class="rev-title">"{{ r.quote }}"</h3>
                <div class="rev-foot">
                  <div class="rev-stars">★★★★★</div>
                  <div class="rev-name">{{ r.name }}</div>
                  <div class="rev-meta">{{ r.meta }}</div>
                </div>
              </div>
              <div class="rev-photo">
                {%- if r.photo != blank -%}
                  <img src="{{ r.photo | image_url: width: 800 }}" alt="{{ r.name | escape }}" loading="lazy" width="800" height="800">
                {%- else -%}
                  <span class="photo-placeholder">📷</span>
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "FK — Reviews",
  "tag": "section",
  "class": "fk-reviews-section",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show section", "default": true },
    { "type": "color", "id": "section_bg", "label": "Section background", "default": "#ffffff" },
    { "type": "text", "id": "reviews_eyebrow", "label": "Eyebrow", "default": "REAL RESULTS" },
    { "type": "text", "id": "reviews_heading", "label": "Heading fallback", "default": "WHAT OUR" },
    { "type": "text", "id": "reviews_heading_em", "label": "Heading (em) fallback", "default": "CUSTOMERS SAY" }
  ],
  "presets": [ { "name": "FK — Reviews" } ],
  "enabled_on": { "templates": ["product"] }
}
{% endschema %}
