{%- render 'leo_kit_chrome' -%}

{%- liquid
  # Per-collection metafields take precedence so each collection can
  # carry its own follow-on callout. Section settings act as a generic
  # fallback for any collection that hasn't authored the metafields.
  assign mf_target  = collection.metafields.custom.cross_cta_target_collection
  assign mf_url     = collection.metafields.custom.cross_cta_url
  assign mf_label   = collection.metafields.custom.cross_cta_label
  assign mf_eyebrow = collection.metafields.custom.cross_cta_eyebrow
  assign mf_title   = collection.metafields.custom.cross_cta_title
  assign mf_desc    = collection.metafields.custom.cross_cta_desc

  assign eyebrow = mf_eyebrow | default: section.settings.eyebrow
  assign title   = mf_title   | default: section.settings.title
  assign desc    = mf_desc    | default: section.settings.desc

  assign target = mf_target | default: section.settings.target_collection
  assign cta_url   = mf_url   | default: target.url | default: section.settings.cta_url | default: '#'
  assign cta_label = mf_label | default: section.settings.cta_label | default: target.title
-%}

{%- if title != blank -%}
  <section class="cross-cta-section" {%- render 'leo_kit_attrs' -%}>
    <div class="container">
      <div class="cross-cta-card">
        <div>
          {%- if eyebrow != blank -%}<div class="cross-cta-eyebrow">{{ eyebrow }}</div>{%- endif -%}
          <div class="cross-cta-title">{{ title }}</div>
          {%- if desc != blank -%}<div class="cross-cta-desc">{{ desc }}</div>{%- endif -%}
        </div>
        <a href="{{ cta_url }}" class="cross-cta-btn">{{ cta_label | default: 'Shop now' }} →</a>
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "GB · Cross-collection CTA",
  "tag": "section",
  "class": "gb-coll-cross-cta-wrap",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "EXPLORE MORE" },
    { "type": "text", "id": "title", "label": "Title", "default": "Once you've nailed fermentation, level up to prebiotic powders." },
    { "type": "textarea", "id": "desc", "label": "Description" },
    { "type": "collection", "id": "target_collection", "label": "Target collection (CTA links here)" },
    { "type": "url", "id": "cta_url", "label": "Manual URL override (only if no collection set)" },
    { "type": "text", "id": "cta_label", "label": "Button label override" },
    { "type": "header", "content": "Spacing & Typography" },
    { "type": "range", "id": "pad_top_d", "label": "Padding top — desktop (px)", "min": 0, "max": 200, "step": 4, "default": 64 },
    { "type": "range", "id": "pad_bot_d", "label": "Padding bottom — desktop (px)", "min": 0, "max": 200, "step": 4, "default": 64 },
    { "type": "range", "id": "pad_top_m", "label": "Padding top — mobile (px)", "min": 0, "max": 120, "step": 4, "default": 48 },
    { "type": "range", "id": "pad_bot_m", "label": "Padding bottom — mobile (px)", "min": 0, "max": 120, "step": 4, "default": 48 }
  ],
  "presets": [{ "name": "GB · Cross-collection CTA" }]
}
{% endschema %}
