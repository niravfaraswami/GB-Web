{%- comment -%}
  Section 06 · Why GutBasket — 3 proof points + visual jar
  Source ref: gutbasket-home-page.html lines 2299-2337
{%- endcomment -%}

<section class="gb-why">
  <div class="gb-why-container">
    <div class="gb-why-grid">
      <div class="gb-why-visual">
        {%- if section.settings.before_label != blank -%}
          <div class="gb-why-label gb-why-label--before">{{ section.settings.before_label }}</div>
        {%- endif -%}
        {%- if section.settings.after_label != blank -%}
          <div class="gb-why-label gb-why-label--after">{{ section.settings.after_label }}</div>
        {%- endif -%}
        {%- if section.settings.visual_image -%}
          <img class="gb-why-img" src="{{ section.settings.visual_image | image_url: width: 800 }}" alt="" loading="lazy">
        {%- else -%}
          <div class="gb-why-jar">{{ section.settings.jar_label | default: 'FERMENT' }}</div>
        {%- endif -%}
      </div>
      <div class="gb-why-text">
        {%- if section.settings.eyebrow != blank -%}
          <span class="gb-why-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="gb-why-h2">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.lead != blank -%}
          <div class="gb-why-lead">{{ section.settings.lead }}</div>
        {%- endif -%}
        {%- if section.blocks.size > 0 -%}
          <ul class="gb-why-list">
            {%- for block in section.blocks -%}
              <li class="gb-why-item" {{ block.shopify_attributes }}>
                <div class="gb-why-icon">{{ block.settings.icon | default: '✓' }}</div>
                <div class="gb-why-content">
                  <strong>{{ block.settings.title }}</strong>
                  <span>{{ block.settings.description }}</span>
                </div>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
.gb-why {
  --c-cream: #FFF9EE;
  --c-text: #1F1F1D;
  --c-text-muted: #5C4D3F;
  --c-border: #E8E3D5;
  --c-ink: #1F1F1D;
  --c-kanji: #8B1F40;
  --c-kanji-soft: #F4DBE2;
  --c-sprout-soft: #DCEBDF;
  --c-aam-panna: #DDA738;
  --kit-soft: #F4DBE2;
  --kit-color: #8B1F40;
  background: var(--c-cream);
  padding: 64px 0;
}
.gb-why-container { max-width: 1180px; margin: 0 auto; padding: 0 24px; }
.gb-why-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}
.gb-why-visual {
  aspect-ratio: 1/1;
  background: linear-gradient(135deg, var(--c-kanji-soft) 0%, var(--c-sprout-soft) 100%);
  border-radius: 18px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  /* Desktop: text on the left, image on the right. The visual block
     comes first in DOM order (kept so mobile single-column stays
     image-above-text); `order` flips them on desktop only. The mobile
     breakpoint below resets these to 0 so DOM order takes over. */
  order: 2;
  overflow: hidden;
}
.gb-why-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.gb-why-jar {
  width: 60%;
  aspect-ratio: 0.7/1;
  background: linear-gradient(180deg, var(--c-aam-panna) 0%, var(--c-kanji) 100%);
  border-radius: 14px;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 30px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 800;
  font-size: 18px;
  color: var(--c-cream);
  letter-spacing: 0.05em;
  position: relative;
  box-shadow: 0 4px 12px rgba(43, 31, 26, 0.06), 0 12px 32px rgba(43, 31, 26, 0.08);
}
.gb-why-jar::before {
  content: '';
  position: absolute;
  top: -14px;
  left: 50%;
  transform: translateX(-50%);
  width: 38%;
  height: 24px;
  background: var(--c-ink);
  border-radius: 4px 4px 0 0;
}
.gb-why-label {
  position: absolute;
  top: 16px;
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  background: var(--c-ink);
  color: var(--c-cream);
  padding: 5px 11px;
  border-radius: 4px;
  z-index: 2;
}
.gb-why-label--before { left: 16px; }
.gb-why-label--after  { right: 16px; }
.gb-why-text { order: 1; }
.gb-why-eyebrow {
  display: inline-block;
  font-family: 'DM Mono', monospace;
  font-size: 11px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  color: var(--c-text-muted);
  margin-bottom: 10px;
}
.gb-why-h2 {
  font-family: 'Montserrat', sans-serif;
  font-weight: 800;
  font-size: clamp(30px, 4vw, 42px);
  margin: 0 0 18px;
  letter-spacing: -0.02em;
  color: var(--c-text);
}
.gb-why-h2 em { font-style: italic; font-weight: 700; color: var(--c-kanji); }
.gb-why-lead {
  font-family: 'DM Sans', sans-serif;
  font-size: 17px;
  color: var(--c-text-muted);
  margin: 0 0 32px;
  line-height: 1.55;
}
.gb-why-list { list-style: none; padding: 0; margin: 0; }
.gb-why-item {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  padding: 18px 0;
  border-bottom: 1px solid var(--c-border);
}
.gb-why-item:last-child { border-bottom: none; }
.gb-why-icon {
  width: 38px; height: 38px;
  border-radius: 50%;
  background: var(--kit-soft);
  color: var(--kit-color);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  font-family: 'Montserrat', sans-serif;
  font-weight: 800;
  font-size: 15px;
}
.gb-why-content strong {
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 15px;
  display: block;
  margin-bottom: 3px;
  color: var(--c-text);
}
.gb-why-content span {
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  color: var(--c-text-muted);
}
@media (max-width: 968px) {
  .gb-why-grid { grid-template-columns: 1fr; gap: 36px; }
  .gb-why-visual { max-width: 380px; margin: 0 auto; order: 0; }
  .gb-why-text { order: 0; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "GB · Home Why",
  "tag": "section",
  "class": "gb-why-wrap",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why ferment" },
    { "type": "text", "id": "heading", "label": "Heading (use <em>)", "default": "Real probiotics. <em>Live cultures.</em> Made by you." },
    { "type": "richtext", "id": "lead", "label": "Lead paragraph", "default": "<p>Three things happen in the jar between day 1 and day 5 — and none of them happen in store-bought \"probiotic\" drinks.</p>" },
    { "type": "header", "content": "Visual panel (left)" },
    { "type": "image_picker", "id": "visual_image", "label": "Visual image (overrides jar mock)" },
    { "type": "text", "id": "before_label", "label": "Before label", "default": "Before" },
    { "type": "text", "id": "after_label", "label": "After label", "default": "After" },
    { "type": "text", "id": "jar_label", "label": "Jar label (when no image)", "default": "FERMENT" }
  ],
  "blocks": [
    {
      "type": "proof",
      "name": "Proof point",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon character", "default": "B" },
        { "type": "text", "id": "title", "label": "Title", "default": "Title" },
        { "type": "text", "id": "description", "label": "Description", "default": "Description" }
      ]
    }
  ],
  "presets": [
    {
      "name": "GB · Home Why",
      "blocks": [
        { "type": "proof", "settings": { "icon": "B", "title": "Billions of good bacteria, naturally", "description": "Live Lactobacillus grown in your kitchen, not powdered in a lab." } },
        { "type": "proof", "settings": { "icon": "N", "title": "30+ nutrients released",               "description": "Vitamins, antioxidants, and bioavailable minerals locked in fresh produce." } },
        { "type": "proof", "settings": { "icon": "∅", "title": "Zero preservatives",                   "description": "Salt, spice, and time. The way your grandmother made it." } }
      ]
    }
  ]
}
{% endschema %}
