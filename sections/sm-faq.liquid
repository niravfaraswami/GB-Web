{{ 'sprout-maker.css' | asset_url | stylesheet_tag }}
{{ 'sprout-maker-v2.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign p = product
  assign mf_faqs = p.metafields.custom.featured_faqs.value
  assign faq_blocks = section.blocks | where: 'type', 'faq'
-%}

{%- if mf_faqs != blank or faq_blocks.size > 0 -%}
  <section class="faq-section sprout-pdp-v2" data-kit="sprouts">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow">{{ section.settings.faq_eyebrow }}</div>
        <h2>{{ section.settings.faq_heading }}<br><em>{{ section.settings.faq_heading_em }}</em></h2>
      </div>
      <div class="faq-list">
        {%- if mf_faqs != blank -%}
          {%- for f in mf_faqs -%}
            <div class="faq-item {% if forloop.first %}open{% endif %}" data-faq>
              <div class="faq-q">
                <span>{{ f.question }}</span>
                <span class="faq-toggle">+</span>
              </div>
              <div class="faq-a">{{ f.answer | newline_to_br }}</div>
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for block in faq_blocks -%}
            <div class="faq-item {% if forloop.first %}open{% endif %}" data-faq {{ block.shopify_attributes }}>
              <div class="faq-q">
                <span>{{ block.settings.question }}</span>
                <span class="faq-toggle">+</span>
              </div>
              <div class="faq-a">{{ block.settings.answer }}</div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "SM v2 · FAQ",
  "tag": "section",
  "class": "section--sm-v2-faq",
  "max_blocks": 16,
  "settings": [
    { "type": "text", "id": "faq_eyebrow", "label": "Eyebrow", "default": "QUESTIONS?" },
    { "type": "text", "id": "faq_heading", "label": "Heading", "default": "COMMON" },
    { "type": "text", "id": "faq_heading_em", "label": "Heading (highlighted)", "default": "QUESTIONS." }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [{ "name": "SM v2 · FAQ" }]
}
{% endschema %}
