{%- liquid
  assign p = product
  assign mf_quick_bens = p.metafields.custom.featured_quick_benefits.value
  assign mf_outcome_stats = p.metafields.custom.featured_outcomes_stats.value
  assign mf_benefit_icons = p.metafields.custom.benefits_icons.value
  assign mf_outcomes_h = p.metafields.custom.outcomes_h
  assign benefit_blocks = section.blocks | where: 'type', 'benefit'
-%}
{%- if mf_quick_bens != blank or benefit_blocks.size > 0 or mf_outcome_stats != blank -%}
  <div data-kit="fermentation" class="ferment-pdp fkv3-outcomes-wrap" {%- render 'fkv3-section-attrs' -%}>
    {%- render 'fkv3-color-cascade' -%}
    <section class="outcomes-section">
      <div class="container">
        <div class="section-header centered">
          <div class="eyebrow">{{ section.settings.benefits_eyebrow }}</div>
          {%- if mf_outcomes_h != blank -%}<h2>{{ mf_outcomes_h }}</h2>
          {%- else -%}<h2>{{ section.settings.benefits_heading }}<br><em>{{ section.settings.benefits_heading_em }}</em></h2>{%- endif -%}
        </div>
        {%- if mf_quick_bens != blank or benefit_blocks.size > 0 -%}
          <div class="qb-grid">
            {%- if mf_quick_bens != blank -%}
              {%- for qb in mf_quick_bens -%}
                <div class="qb-card">
                  <div class="qb-icon">{%- if qb.icon != blank -%}{%- render 'kit_icon', icon: qb.icon, size: 56, alt: qb.heading, extra: 'qb-icon-img' -%}{%- endif -%}</div>
                  <div class="qb-h">{{ qb.heading }}</div>
                  <div class="qb-d">{{ qb.description }}</div>
                </div>
              {%- endfor -%}
            {%- else -%}
              {%- for block in benefit_blocks -%}
                {%- assign target_idx = forloop.index0 -%}
                {%- assign mf_icon = nil -%}
                {%- if mf_benefit_icons -%}{%- for ic in mf_benefit_icons -%}{%- if forloop.index0 == target_idx -%}{%- assign mf_icon = ic -%}{%- endif -%}{%- endfor -%}{%- endif -%}
                <div class="qb-card" {{ block.shopify_attributes }}>
                  <div class="qb-icon">{%- if mf_icon != blank -%}{%- render 'kit_icon', icon: mf_icon, size: 56, extra: 'qb-icon-img' -%}
                  {%- elsif block.settings.icon_image != blank -%}{%- render 'kit_icon', icon: block.settings.icon_image, size: 56, extra: 'qb-icon-img' -%}
                  {%- else -%}{{ block.settings.icon }}{%- endif -%}</div>
                  <div class="qb-h">{{ block.settings.heading }}</div>
                  <div class="qb-d">{{ block.settings.description }}</div>
                </div>
              {%- endfor -%}
            {%- endif -%}
          </div>
        {%- endif -%}
        {%- if mf_outcome_stats != blank -%}
          <div class="indians-strip">
            {%- for s in mf_outcome_stats limit: 2 -%}
              <div class="indians-cell {% if forloop.first %}left{% else %}right{% endif %}">
                <div class="indians-stat">{{ s.value }}</div>
                <div class="indians-cap">{{ s.caption }}</div>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </section>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "FK v3 — Outcomes",
  "tag": "section",
  "class": "fkv3-outcomes-wrap",
  "settings": [
    { "type": "color", "id": "section_bg", "label": "Section background", "default": "#ffffff" },
    { "type": "text", "id": "benefits_eyebrow", "label": "Eyebrow", "default": "QUICK BENEFITS" },
    { "type": "text", "id": "benefits_heading", "label": "Heading", "default": "WHY DAILY FERMENTS" },
    { "type": "text", "id": "benefits_heading_em", "label": "Heading (em)", "default": "CHANGE YOUR GUT." }
  ,
    { "type": "header", "content": "Typography — desktop" },
    { "type": "range", "id": "eyebrow_size_d", "label": "Eyebrow size (px)", "min": 8, "max": 28, "step": 1, "default": 11 },
    { "type": "range", "id": "heading_size_d", "label": "Heading size (px)", "min": 18, "max": 80, "step": 2, "default": 44 },
    { "type": "range", "id": "sub_size_d", "label": "Sub-heading / body size (px)", "min": 12, "max": 28, "step": 1, "default": 16 },
    { "type": "header", "content": "Typography — mobile" },
    { "type": "range", "id": "eyebrow_size_m", "label": "Eyebrow size (px)", "min": 8, "max": 22, "step": 1, "default": 11 },
    { "type": "range", "id": "heading_size_m", "label": "Heading size (px)", "min": 16, "max": 60, "step": 2, "default": 28 },
    { "type": "range", "id": "sub_size_m", "label": "Sub-heading / body size (px)", "min": 12, "max": 22, "step": 1, "default": 14 }],
  "blocks": [
    { "type": "benefit", "name": "Quick benefit", "limit": 6, "settings": [
      { "type": "image_picker", "id": "icon_image", "label": "Icon image" },
      { "type": "text", "id": "icon", "label": "Icon (emoji fallback)" },
      { "type": "text", "id": "heading", "label": "Heading" },
      { "type": "textarea", "id": "description", "label": "Description" }
    ]}
  ],
  "presets": [ { "name": "FK v3 — Outcomes" } ],
  "enabled_on": { "templates": ["product"] }
}
{% endschema %}
