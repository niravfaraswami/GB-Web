{%- render 'leo_kit_chrome' -%}

{%- liquid
  assign p = product
  assign cross_sell = p.metafields.custom.cross_sell_products.value
  assign cross_blocks = section.blocks | where: 'type', 'cross_sell_product'
  assign show = false
  if cross_sell != blank or cross_blocks.size > 0 or section.settings.cross_collection != blank
    assign show = true
  endif
-%}

{%- if show -%}
  <section class="cross-section ferment-pdp-leo" {%- render 'leo_kit_attrs' -%}>
    <div class="container">
      <div class="section-header centered">
        <div class="eyebrow">{{ section.settings.cross_eyebrow }}</div>
        <h2>{{ section.settings.cross_heading }}</h2>
      </div>
      <div class="cross-grid">
        {%- if cross_sell != blank -%}
          {%- for cp in cross_sell limit: 3 -%}{%- render 'ferment_cross_card', p: cp -%}{%- endfor -%}
        {%- elsif cross_blocks.size > 0 -%}
          {%- for block in cross_blocks -%}{%- if block.settings.product != blank -%}{%- render 'ferment_cross_card', p: block.settings.product, attrs: block.shopify_attributes -%}{%- endif -%}{%- endfor -%}
        {%- elsif section.settings.cross_collection.products.size > 0 -%}
          {%- for cp in section.settings.cross_collection.products limit: 3 -%}{%- render 'ferment_cross_card', p: cp -%}{%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Leo · Cross-sell",
  "tag": "section",
  "class": "leo-cross-section",
  "settings": [
    {
      "type": "text",
      "id": "cross_eyebrow",
      "label": "Eyebrow",
      "default": "PAIR IT WITH"
    },
    {
      "type": "text",
      "id": "cross_heading",
      "label": "Heading",
      "default": "CUSTOMERS ALSO BOUGHT"
    },
    {
      "type": "collection",
      "id": "cross_collection",
      "label": "Fallback collection"
    },
    {
      "type": "header",
      "content": "Spacing & Typography"
    },
    {
      "type": "range",
      "id": "pad_top_d",
      "label": "Padding top — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_bot_d",
      "label": "Padding bottom — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_top_m",
      "label": "Padding top — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "pad_bot_m",
      "label": "Padding bottom — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "mar_top_d",
      "label": "Margin top — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_d",
      "label": "Margin bottom — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_top_m",
      "label": "Margin top — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_m",
      "label": "Margin bottom — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "eyebrow_size_d",
      "label": "Eyebrow font size — desktop (px)",
      "min": 9,
      "max": 32,
      "step": 1,
      "default": 22
    },
    {
      "type": "range",
      "id": "eyebrow_size_m",
      "label": "Eyebrow font size — mobile (px)",
      "min": 9,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "heading_size_d",
      "label": "Heading font size — desktop (px)",
      "min": 18,
      "max": 80,
      "step": 2,
      "default": 44
    },
    {
      "type": "range",
      "id": "heading_size_m",
      "label": "Heading font size — mobile (px)",
      "min": 16,
      "max": 60,
      "step": 2,
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "cross_sell_product",
      "name": "Cross-sell product",
      "limit": 6,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Leo · Cross-sell"
    }
  ]
}
{% endschema %}
