{%- render 'leo_kit_chrome' -%}

{%- assign related_blocks = section.blocks | where: 'type', 'related' -%}

{%- if related_blocks.size > 0 -%}
  <section class="related-section" {%- render 'leo_kit_attrs' -%}>
    <div class="container">
      {%- if section.settings.eyebrow != blank -%}<div class="related-eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="related-h">{{ section.settings.heading }}</h2>{%- endif -%}
      <div class="related-grid">
        {%- for block in related_blocks -%}
          {%- assign rel_article = block.settings.article -%}
          {%- assign rel_url = rel_article.url | default: block.settings.url | default: '#' -%}
          {%- assign rel_title = rel_article.title | default: block.settings.title -%}
          {%- assign rel_meta = block.settings.meta | default: rel_article.metafields.custom.read_time -%}
          {%- assign rel_color = block.settings.cat_color | default: '#FF7300' -%}
          <a href="{{ rel_url }}" class="related-card" {{ block.shopify_attributes }}>
            <div class="related-cat" style="background: {{ rel_color }};">●</div>
            <div class="related-title">{{ rel_title }}</div>
            {%- if rel_meta != blank -%}<div class="related-meta">{{ rel_meta }}</div>{%- endif -%}
          </a>
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "GB · Learn Blog Related",
  "tag": "section",
  "class": "gb-learn-blog-related-wrap",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "KEEP READING" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Related articles" },
    { "type": "header", "content": "Spacing & Typography" },
    { "type": "range", "id": "pad_top_d", "label": "Padding top — desktop (px)", "min": 0, "max": 200, "step": 4, "default": 80 },
    { "type": "range", "id": "pad_bot_d", "label": "Padding bottom — desktop (px)", "min": 0, "max": 200, "step": 4, "default": 80 },
    { "type": "range", "id": "pad_top_m", "label": "Padding top — mobile (px)", "min": 0, "max": 120, "step": 4, "default": 56 },
    { "type": "range", "id": "pad_bot_m", "label": "Padding bottom — mobile (px)", "min": 0, "max": 120, "step": 4, "default": 56 }
  ],
  "blocks": [
    { "type": "related", "name": "Related article", "limit": 4, "settings": [
      { "type": "article", "id": "article", "label": "Article (auto-pulls title + URL)" },
      { "type": "text", "id": "title", "label": "Title override (optional)" },
      { "type": "url", "id": "url", "label": "URL override (optional)" },
      { "type": "text", "id": "meta", "label": "Meta line (e.g. '8 min')", "default": "8 min" },
      { "type": "color", "id": "cat_color", "label": "Category dot color", "default": "#FF7300" }
    ]}
  ],
  "presets": [{ "name": "GB · Learn Blog Related" }]
}
{% endschema %}
