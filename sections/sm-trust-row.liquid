{{ 'sprout-maker.css' | asset_url | stylesheet_tag }}
{{ 'sprout-maker-v2.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign p = product
  assign mf_trust_cards = p.metafields.custom.featured_trust_cards.value
  assign mf_trust_icons = p.metafields.custom.trust_strip_icons.value
  assign trust_blocks   = section.blocks | where: 'type', 'trust_card'
-%}

{%- if mf_trust_cards != blank or trust_blocks.size > 0 -%}
  <section class="trust-row-section sprout-pdp-v2" data-kit="sprouts">
    <div class="container">
      <div class="trust-row-grid">
        {%- if mf_trust_cards != blank -%}
          {%- for tc in mf_trust_cards -%}
            <div class="tr-card">
              <div class="tr-icon">
                {%- if tc.icon != blank -%}
                  <img src="{{ tc.icon | image_url: width: 88 }}" alt="{{ tc.heading | escape }}" loading="lazy" width="44" height="44" class="tr-icon-img">
                {%- endif -%}
              </div>
              <div class="tr-h">{{ tc.heading }}</div>
              <div class="tr-d">{{ tc.description }}</div>
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for block in trust_blocks -%}
            {%- assign target_idx = forloop.index0 -%}
            {%- assign mf_icon = nil -%}
            {%- if mf_trust_icons -%}{%- for ic in mf_trust_icons -%}{%- if forloop.index0 == target_idx -%}{%- assign mf_icon = ic -%}{%- endif -%}{%- endfor -%}{%- endif -%}
            <div class="tr-card" {{ block.shopify_attributes }}>
              <div class="tr-icon">
                {%- if mf_icon != blank -%}
                  <img src="{{ mf_icon | image_url: width: 88 }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="44" height="44" class="tr-icon-img">
                {%- elsif block.settings.icon_image != blank -%}
                  <img src="{{ block.settings.icon_image | image_url: width: 88 }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="44" height="44" class="tr-icon-img">
                {%- else -%}
                  {{ block.settings.icon }}
                {%- endif -%}
              </div>
              <div class="tr-h">{{ block.settings.heading }}</div>
              <div class="tr-d">{{ block.settings.description }}</div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "SM v2 · Trust Row",
  "tag": "section",
  "class": "section--sm-v2-trust",
  "max_blocks": 8,
  "settings": [],
  "blocks": [
    {
      "type": "trust_card",
      "name": "Trust card",
      "settings": [
        { "type": "image_picker", "id": "icon_image", "label": "Icon image", "info": "Overrides emoji if set" },
        { "type": "text", "id": "icon", "label": "Icon (emoji fallback)", "default": "🌱" },
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    }
  ],
  "presets": [{ "name": "SM v2 · Trust Row" }]
}
{% endschema %}
