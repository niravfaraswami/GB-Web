{%- render 'leo_kit_chrome' -%}

{%- capture body_html -%}{%- render 'gb-recipe-body-section', section_name: 'ingredients' -%}{%- endcapture -%}
{%- assign body_html = body_html | strip -%}
{%- assign ing_blocks = section.blocks | where: 'type', 'ingredient' -%}
{%- assign has_body = false -%}
{%- if body_html contains '<li' -%}{%- assign has_body = true -%}{%- endif -%}

{%- if has_body or ing_blocks.size > 0 -%}
  <section class="recipe-section" id="{{ section.settings.anchor | default: 'ingredients' }}" {%- render 'leo_kit_attrs' -%}>
    <div class="container">
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.sub != blank -%}<div class="section-sub">{{ section.settings.sub }}</div>{%- endif -%}
      <div class="ingredients-grid">
        {%- if has_body -%}
          {%- render 'gb-recipe-parse-items', html: body_html, style: 'ingredient' -%}
        {%- else -%}
          {%- for block in ing_blocks -%}
            <div class="ingredient-row" {{ block.shopify_attributes }}>
              <div class="ing-amount">{{ block.settings.amount }}</div>
              <div>
                <div class="ing-name">{{ block.settings.name }}</div>
                {%- if block.settings.desc != blank -%}<div class="ing-desc">{{ block.settings.desc }}</div>{%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "GB · Recipe Ingredients",
  "tag": "section",
  "class": "gb-learn-recipe-ingredients-wrap",
  "settings": [
    { "type": "text", "id": "anchor", "label": "Anchor ID", "default": "ingredients" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Ingredients" },
    { "type": "text", "id": "sub", "label": "Sub-heading", "default": "What you'll need to make this." },
    { "type": "header", "content": "Spacing & Typography" },
    { "type": "range", "id": "pad_top_d", "label": "Padding top — desktop (px)", "min": 0, "max": 200, "step": 4, "default": 64 },
    { "type": "range", "id": "pad_bot_d", "label": "Padding bottom — desktop (px)", "min": 0, "max": 200, "step": 4, "default": 64 },
    { "type": "range", "id": "pad_top_m", "label": "Padding top — mobile (px)", "min": 0, "max": 120, "step": 4, "default": 48 },
    { "type": "range", "id": "pad_bot_m", "label": "Padding bottom — mobile (px)", "min": 0, "max": 120, "step": 4, "default": 48 }
  ],
  "blocks": [
    { "type": "ingredient", "name": "Ingredient", "limit": 30, "settings": [
      { "type": "text", "id": "amount", "label": "Amount (e.g. 20g, 1 tsp)", "default": "1 tsp" },
      { "type": "text", "id": "name", "label": "Name", "default": "Salt" },
      { "type": "text", "id": "desc", "label": "Description (optional)" }
    ]}
  ],
  "presets": [{ "name": "GB · Learn Recipe Ingredients" }]
}
{% endschema %}
