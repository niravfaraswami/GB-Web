{%- render 'leo_kit_chrome' -%}

{%- liquid
  assign p = product
  assign mf_recipe_tags = p.metafields.custom.featured_recipe_tags.value
  # `.value` extracts the referenced MediaImage. Without it we end up
  # passing the metafield wrapper object through `image_url`, which
  # doesn't coerce reliably — that's why per-product banner uploads
  # weren't reflecting on the live page.
  assign mf_banner = p.metafields.custom.recipe_banner_image.value
  assign mf_count = p.metafields.custom.recipe_count
  assign mf_h_label = p.metafields.custom.recipe_h_label
  assign mf_h_text = p.metafields.custom.recipe_h_text
  assign recipe_pill_blocks = section.blocks | where: 'type', 'recipe_pill'
  if mf_banner != blank
    assign recipe_banner = mf_banner
  else
    assign recipe_banner = section.settings.recipe_banner
  endif
  assign recipe_count = mf_count | default: section.settings.recipe_count
  assign recipe_h_label = mf_h_label | default: section.settings.recipe_h_label
  assign recipe_h_text = mf_h_text | default: section.settings.recipe_h_text
  assign has_mf_tags = false
  if mf_recipe_tags and mf_recipe_tags.size > 0
    assign has_mf_tags = true
  endif
-%}

{%- if recipe_banner != blank or recipe_count != blank or has_mf_tags or recipe_pill_blocks.size > 0 -%}
  <section class="recipes-section ferment-pdp-leo" {%- render 'leo_kit_attrs' -%}>
    <div class="container">
      <div class="section-header">
        <div class="eyebrow">{{ section.settings.recipes_eyebrow }}</div>
        <div class="recipes-h-row">
          {%- if recipe_count != blank -%}<div class="recipes-num">{{ recipe_count }}</div>{%- endif -%}
          <div class="recipes-h-text"><em>{{ recipe_h_label }}</em> <span>{{ recipe_h_text }}</span></div>
        </div>
      </div>
      {%- if recipe_banner != blank -%}
        <div class="recipes-banner"><img src="{{ recipe_banner | image_url: width: 1600 }}" alt="Recipes" loading="lazy" width="1600" height="700"></div>
      {%- endif -%}
      {%- if has_mf_tags -%}
        <div class="recipe-tags">
          {%- for t in mf_recipe_tags -%}
            {%- if t.url != blank -%}
              <a class="recipe-tag" href="{{ t.url }}"><span class="dot"></span>{%- if t.emoji != blank %}{{ t.emoji }} {% endif -%}{{ t.name }}</a>
            {%- else -%}
              <span class="recipe-tag"><span class="dot"></span>{%- if t.emoji != blank %}{{ t.emoji }} {% endif -%}{{ t.name }}</span>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- elsif recipe_pill_blocks.size > 0 -%}
        <div class="recipe-tags">
          {%- for block in recipe_pill_blocks -%}
            {%- if block.settings.url != blank -%}
              <a class="recipe-tag" href="{{ block.settings.url }}" {{ block.shopify_attributes }}><span class="dot"></span>{%- if block.settings.emoji != blank %}{{ block.settings.emoji }} {% endif -%}{{ block.settings.name }}</a>
            {%- else -%}
              <span class="recipe-tag" {{ block.shopify_attributes }}><span class="dot"></span>{%- if block.settings.emoji != blank %}{{ block.settings.emoji }} {% endif -%}{{ block.settings.name }}</span>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Leo · Recipes",
  "tag": "section",
  "class": "leo-recipes-section",
  "settings": [
    {
      "type": "text",
      "id": "recipes_eyebrow",
      "label": "Eyebrow",
      "default": "ONE KIT. ENDLESS VARIETY."
    },
    {
      "type": "text",
      "id": "recipe_count",
      "label": "Recipe count",
      "default": "7"
    },
    {
      "type": "text",
      "id": "recipe_h_label",
      "label": "Heading label",
      "default": "KANJI"
    },
    {
      "type": "text",
      "id": "recipe_h_text",
      "label": "Heading text",
      "default": "RECIPES INSIDE"
    },
    {
      "type": "image_picker",
      "id": "recipe_banner",
      "label": "Recipes banner image"
    },
    {
      "type": "header",
      "content": "Spacing & Typography"
    },
    {
      "type": "range",
      "id": "pad_top_d",
      "label": "Padding top — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 48
    },
    {
      "type": "range",
      "id": "pad_bot_d",
      "label": "Padding bottom — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 48
    },
    {
      "type": "range",
      "id": "pad_top_m",
      "label": "Padding top — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 32
    },
    {
      "type": "range",
      "id": "pad_bot_m",
      "label": "Padding bottom — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 32
    },
    {
      "type": "range",
      "id": "mar_top_d",
      "label": "Margin top — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_d",
      "label": "Margin bottom — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_top_m",
      "label": "Margin top — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_m",
      "label": "Margin bottom — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "eyebrow_size_d",
      "label": "Eyebrow font size — desktop (px)",
      "min": 9,
      "max": 32,
      "step": 1,
      "default": 22
    },
    {
      "type": "range",
      "id": "eyebrow_size_m",
      "label": "Eyebrow font size — mobile (px)",
      "min": 9,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "heading_size_d",
