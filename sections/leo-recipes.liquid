    {
      "type": "range",
      "id": "heading_size_m",
      "label": "Heading font size — mobile (px)",
      "min": 16,
      "max": 60,
      "step": 2,
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "recipe_pill",
      "name": "Recipe pill",
      "limit": 12,
      "settings": [
        {
          "type": "text",
          "id": "emoji",
          "label": "Emoji (optional)"
        },
        {
