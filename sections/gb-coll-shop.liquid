{%- render 'leo_kit_chrome' -%}

{%- liquid
  assign products = collection.products
  assign all_subcats = products | map: 'product_type' | uniq
  assign filterable_tags_meta = collection.metafields.custom.filterable_tags
  assign default_show_tags = section.settings.default_show_tags | default: 'Vegan|Gluten-free|No oil|Top seller|Sugar-free|Diabetic-safe'
  assign default_tags_arr = default_show_tags | split: '|'
-%}

<section class="coll-shop" {%- render 'leo_kit_attrs' -%}>
  <div class="container">
    <aside class="filter-sidebar" data-gb-coll-sidebar>
      <div class="filter-toggle-close" style="display:none">
        <button type="button" data-gb-coll-close>Apply &amp; Close</button>
      </div>
      <div class="filter-h">
        <span>Filters</span>
        <button type="button" class="filter-clear" data-gb-coll-clear>Clear all</button>
      </div>
      <div class="filter-active-count" data-gb-coll-active-count>0 active</div>

      {%- if all_subcats.size > 0 -%}
        <div class="filter-group">
          <div class="filter-group-h">Category</div>
          {%- for sc in all_subcats -%}
            <label class="filter-check">
              <input type="checkbox" data-filter="subcategory" value="{{ sc }}">
              <span class="fc-box"></span>
              <span class="fc-label">{{ sc }}</span>
              <span class="fc-count" data-count-subcategory="{{ sc | escape }}">0</span>
            </label>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="filter-group">
        <div class="filter-group-h">Price</div>
        {%- assign buckets = 'Under ₹500|₹500–₹1,000|₹1,000–₹2,000|₹2,000+' | split: '|' -%}
        {%- for b in buckets -%}
          <label class="filter-check">
            <input type="checkbox" data-filter="bucket" value="{{ b }}">
            <span class="fc-box"></span>
            <span class="fc-label">{{ b }}</span>
            <span class="fc-count" data-count-bucket="{{ b | escape }}">0</span>
          </label>
        {%- endfor -%}
      </div>

      {%- assign tag_list = default_tags_arr -%}
      {%- if filterable_tags_meta != blank -%}
        {%- assign tag_list = filterable_tags_meta -%}
      {%- endif -%}
      {%- if tag_list.size > 0 -%}
        <div class="filter-group">
          <div class="filter-group-h">Tags</div>
          {%- for t in tag_list -%}
            <label class="filter-check">
              <input type="checkbox" data-filter="tag" value="{{ t }}">
              <span class="fc-box"></span>
              <span class="fc-label">{{ t }}</span>
              <span class="fc-count" data-count-tag="{{ t | escape }}">0</span>
            </label>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="filter-group">
        <div class="filter-group-h">Availability</div>
        <label class="filter-check">
          <input type="checkbox" data-filter="instock" value="1">
          <span class="fc-box"></span>
          <span class="fc-label">In stock</span>
        </label>
      </div>
    </aside>

    <div>
      <div class="grid-toolbar">
        <div class="grid-count" data-gb-coll-count>Showing <strong>{{ products.size }}</strong> of {{ products.size }} products</div>
        <div style="display: flex; gap: 8px; align-items: center;">
          <button type="button" class="filter-toggle" data-gb-coll-open>
            <span>Filters</span>
            <span class="badge" data-gb-coll-active-badge>0</span>
          </button>
          <div class="sort-dropdown">
            <span>Sort:</span>
            <select data-gb-coll-sort>
              <option value="popular">Most popular</option>
              <option value="newest">Newest</option>
              <option value="rating">Highest rated</option>
              <option value="price-asc">Price (low → high)</option>
              <option value="price-desc">Price (high → low)</option>
            </select>
          </div>
        </div>
      </div>

      <div class="product-grid" data-gb-coll-grid>
        {%- for p in products -%}
          {%- assign p_price = p.price | divided_by: 100 -%}
          {%- assign p_bucket = 'Under ₹500' -%}
          {%- if p_price >= 500 -%}{%- assign p_bucket = '₹500–₹1,000' -%}{%- endif -%}
          {%- if p_price >= 1000 -%}{%- assign p_bucket = '₹1,000–₹2,000' -%}{%- endif -%}
          {%- if p_price >= 2000 -%}{%- assign p_bucket = '₹2,000+' -%}{%- endif -%}
          {%- assign p_color = p.metafields.custom.theme_accent | default: p.metafields.custom.color | default: 'var(--kit-color)' -%}
          {%- assign p_emoji = p.metafields.custom.emoji | default: section.settings.fallback_emoji -%}
          {%- assign p_badge = p.metafields.custom.badge -%}
          {%- assign p_subcat = p.metafields.custom.subcategory | default: p.product_type -%}
          {%- assign p_rating = p.metafields.custom.rating | default: 4.8 -%}
          {%- assign p_reviews = p.metafields.custom.review_count | default: 0 -%}
          {%- assign p_tags = p.tags | join: '|' -%}
          {%- assign instock = 0 -%}
          {%- if p.available -%}{%- assign instock = 1 -%}{%- endif -%}
          {%- assign days = 'now' | date: '%s' | minus: p.published_at | date: '%s' | divided_by: 86400 -%}
          <article class="prod-card"
                   data-id="{{ p.handle }}"
                   data-subcat="{{ p_subcat | escape }}"
                   data-tags="{{ p_tags | escape }}"
                   data-price="{{ p_price }}"
                   data-bucket="{{ p_bucket | escape }}"
                   data-rating="{{ p_rating }}"
                   data-reviews="{{ p_reviews }}"
                   data-days="{{ days }}"
                   data-instock="{{ instock }}">
            <a href="{{ p.url }}" class="prod-img" style="background: {{ p_color }};">
              {%- if p.featured_image -%}
                <img src="{{ p.featured_image | image_url: width: 600 }}" alt="{{ p.title | escape }}" loading="lazy" width="400" height="300" style="width:100%; height:100%; object-fit:cover;">
              {%- else -%}
                <span class="prod-emoji">{{ p_emoji }}</span>
              {%- endif -%}
              {%- if p_badge != blank -%}<span class="prod-badge">{{ p_badge }}</span>{%- endif -%}
              {%- unless p.available -%}<span class="prod-oos">SOLD OUT</span>{%- endunless -%}
            </a>
            <div class="prod-body">
              {%- if p_reviews > 0 -%}
                <div class="prod-rating">
                  <span class="stars">★★★★★</span>
                  <span class="rcount">{{ p_rating }} · ({{ p_reviews }})</span>
                </div>
              {%- endif -%}
              <a href="{{ p.url }}" style="text-decoration:none;color:inherit;"><div class="prod-name">{{ p.title }}</div></a>
              {%- if p_subcat != blank -%}<div class="prod-subcat">{{ p_subcat }}</div>{%- endif -%}
              <div class="prod-prices">
                <span class="prod-price-now">{{ p.price | money }}</span>
                {%- if p.compare_at_price > p.price -%}
                  <span class="prod-price-old">{{ p.compare_at_price | money }}</span>
                  {%- assign save_pct = p.compare_at_price | minus: p.price | times: 100 | divided_by: p.compare_at_price -%}
                  <span class="prod-save">SAVE {{ save_pct | round }}%</span>
                {%- endif -%}
              </div>
              <form action="{{ routes.cart_add_url }}" method="post">
                <input type="hidden" name="id" value="{{ p.selected_or_first_available_variant.id }}">
                <button type="submit" class="prod-add" {% unless p.available %}disabled{% endunless %}>{% if p.available %}Quick Add +{% else %}Sold Out{% endif %}</button>
              </form>
            </div>
          </article>
        {%- else -%}
          <p>No products in this collection yet.</p>
        {%- endfor -%}
      </div>

      <div class="grid-empty" data-gb-coll-empty>
        <div class="grid-empty-h">No products match your filters.</div>
        <div class="grid-empty-p">Try clearing some filters and looking again.</div>
        <button type="button" class="grid-empty-btn" data-gb-coll-clear>Clear all filters</button>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "GB · Collection Shop",
  "tag": "section",
  "class": "gb-coll-shop-wrap",
  "settings": [
    { "type": "text", "id": "default_show_tags", "label": "Tag filter list (pipe-separated, fallback if no metafield)", "default": "Vegan|Gluten-free|No oil|Top seller|Sugar-free|Diabetic-safe", "info": "Override per-collection by setting collection.metafields.custom.filterable_tags (list of single-line text)." },
    { "type": "text", "id": "fallback_emoji", "label": "Fallback product emoji", "default": "🫙" },
    { "type": "header", "content": "Spacing & Typography" },
    { "type": "range", "id": "pad_top_d", "label": "Padding top — desktop (px)", "min": 0, "max": 200, "step": 4, "default": 32 },
    { "type": "range", "id": "pad_bot_d", "label": "Padding bottom — desktop (px)", "min": 0, "max": 200, "step": 4, "default": 96 },
    { "type": "range", "id": "pad_top_m", "label": "Padding top — mobile (px)", "min": 0, "max": 120, "step": 4, "default": 24 },
    { "type": "range", "id": "pad_bot_m", "label": "Padding bottom — mobile (px)", "min": 0, "max": 120, "step": 4, "default": 64 }
  ],
  "presets": [{ "name": "GB · Collection Shop" }]
}
{% endschema %}
