{%- render 'leo_kit_chrome' -%}

{%- liquid
  assign p = product
  assign mf_steps = p.metafields.custom.featured_steps.value
  assign step_blocks = section.blocks | where: 'type', 'step_card'
  assign has_mf = false
  if mf_steps and mf_steps.size > 0
    assign has_mf = true
  endif
-%}

{%- if has_mf or step_blocks.size > 0 or section.settings.heading != blank -%}
  <section class="gb-step-cards-section ferment-pdp-leo" {%- render 'leo_kit_attrs' -%}>
    <div class="container">
      <div class="section-header centered">
        {%- if section.settings.eyebrow != blank -%}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }} <em>{{ section.settings.heading_em }}</em></h2>{%- endif -%}
        {%- if section.settings.intro != blank -%}<p>{{ section.settings.intro }}</p>{%- endif -%}
      </div>

      <div class="gb-step-cards-grid">
        {%- if has_mf -%}
          {%- for s in mf_steps -%}
            {%- assign s_h = s.title | default: s.heading -%}
            {%- assign s_d = s.description | default: s.body -%}
            <div class="gb-step-card">
              <div class="gb-step-card-num">{{ forloop.index }}</div>
              <div class="gb-step-card-icon">
                {%- if s.icon != blank -%}<img src="{{ s.icon | image_url: width: 400 }}" alt="{{ s_h | escape }}" loading="lazy" width="200" height="200">
                {%- elsif s.icon_emoji != blank -%}{{ s.icon_emoji }}{%- endif -%}
              </div>
              <div class="gb-step-card-h">{{ s_h }}</div>
              {%- if s_d != blank -%}<div class="gb-step-card-d">{{ s_d }}</div>{%- endif -%}
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for block in step_blocks -%}
            <div class="gb-step-card" {{ block.shopify_attributes }}>
              <div class="gb-step-card-num">{{ forloop.index }}</div>
              <div class="gb-step-card-icon">
                {%- if block.settings.image != blank -%}<img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="200" height="200">
                {%- elsif block.settings.icon_emoji != blank -%}{{ block.settings.icon_emoji }}{%- endif -%}
              </div>
              <div class="gb-step-card-h">{{ block.settings.heading }}</div>
              {%- if block.settings.description != blank -%}<div class="gb-step-card-d">{{ block.settings.description }}</div>{%- endif -%}
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

      {%- if section.settings.tips_heading != blank or section.settings.tips_bullets != blank -%}
        <div class="gb-step-cards-tips">
          {%- if section.settings.tips_heading != blank -%}<div class="gb-step-cards-tips-h">{{ section.settings.tips_heading }}</div>{%- endif -%}
          {%- if section.settings.tips_bullets != blank -%}
            <ul class="gb-step-cards-tips-list">
              {%- assign lines = section.settings.tips_bullets | newline_to_br | split: '<br />' -%}
              {%- for line in lines -%}{%- assign t = line | strip -%}{%- if t != blank -%}<li>{{ t }}</li>{%- endif -%}{%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "GB · Step Cards",
  "tag": "section",
  "class": "gb-step-cards-wrap",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "HOW TO USE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "AS EASY AS"
    },
    {
      "type": "text",
      "id": "heading_em",
      "label": "Heading (highlighted)",
      "default": "1, 2, 3."
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro"
    },
    {
      "type": "header",
      "content": "Tips strip (optional)"
    },
    {
      "type": "text",
      "id": "tips_heading",
      "label": "Tips heading"
    },
    {
      "type": "textarea",
      "id": "tips_bullets",
      "label": "Tips bullets (one per line)"
    },
    {
      "type": "header",
      "content": "Spacing & Typography"
    },
    {
      "type": "range",
      "id": "pad_top_d",
      "label": "Padding top — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_bot_d",
      "label": "Padding bottom — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_top_m",
      "label": "Padding top — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "pad_bot_m",
      "label": "Padding bottom — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "mar_top_d",
      "label": "Margin top — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_d",
      "label": "Margin bottom — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_top_m",
      "label": "Margin top — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_m",
      "label": "Margin bottom — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "eyebrow_size_d",
      "label": "Eyebrow font size — desktop (px)",
      "min": 9,
      "max": 32,
      "step": 1,
      "default": 22
    },
    {
      "type": "range",
      "id": "eyebrow_size_m",
      "label": "Eyebrow font size — mobile (px)",
      "min": 9,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "heading_size_d",
      "label": "Heading font size — desktop (px)",
      "min": 18,
      "max": 80,
      "step": 2,
      "default": 44
    },
    {
      "type": "range",
      "id": "heading_size_m",
      "label": "Heading font size — mobile (px)",
      "min": 16,
      "max": 60,
      "step": 2,
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "step_card",
      "name": "Step card",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (optional)"
        },
        {
          "type": "text",
          "id": "icon_emoji",
          "label": "Icon emoji (fallback)"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GB · Step Cards"
    }
  ]
}
{% endschema %}
