{%- liquid
  assign p = product
  assign mf_reviews = p.metafields.custom.featured_reviews.value
  assign mf_reviews_h = p.metafields.custom.reviews_h
  assign review_blocks = section.blocks | where: 'type', 'review'
-%}
{%- if mf_reviews != blank or review_blocks.size > 0 -%}
  <div data-kit="fermentation" class="ferment-pdp fkv3-reviews-wrap" {%- render 'fkv3-section-attrs' -%}>
    {%- render 'fkv3-color-cascade' -%}
    <section class="reviews-section">
      <div class="container">
        <div class="section-header">
          <div class="eyebrow">{{ section.settings.reviews_eyebrow }}</div>
          {%- if mf_reviews_h != blank -%}<h2>{{ mf_reviews_h }}</h2>
          {%- else -%}<h2>{{ section.settings.reviews_heading }} <em>{{ section.settings.reviews_heading_em }}</em></h2>{%- endif -%}
        </div>
        <div class="reviews-grid">
          {%- if mf_reviews != blank -%}
            {%- for r in mf_reviews -%}
              <div class="review-card">
                <div class="rev-content"><h3 class="rev-title">"{{ r.quote }}"</h3><div class="rev-foot"><div class="rev-stars">★★★★★</div><div class="rev-name">{{ r.name }}</div><div class="rev-meta">{{ r.meta }}</div></div></div>
                <div class="rev-photo">{%- if r.photo != blank -%}<img src="{{ r.photo | image_url: width: 800 }}" alt="{{ r.name | escape }}" loading="lazy" width="800" height="800">{%- else -%}<span class="photo-placeholder">📷</span>{%- endif -%}</div>
              </div>
            {%- endfor -%}
          {%- else -%}
            {%- for block in review_blocks -%}
              <div class="review-card" {{ block.shopify_attributes }}>
                <div class="rev-content"><h3 class="rev-title">"{{ block.settings.quote }}"</h3><div class="rev-foot"><div class="rev-stars">★★★★★</div><div class="rev-name">{{ block.settings.name }}</div><div class="rev-meta">{{ block.settings.meta }}</div></div></div>
                <div class="rev-photo">{%- if block.settings.photo != blank -%}<img src="{{ block.settings.photo | image_url: width: 800 }}" alt="{{ block.settings.name | escape }}" loading="lazy" width="800" height="800">{%- else -%}<span class="photo-placeholder">📷</span>{%- endif -%}</div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    </section>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "FK v3 — Reviews",
  "tag": "section",
  "class": "fkv3-reviews-wrap",
  "settings": [
    { "type": "color", "id": "section_bg", "label": "Section background", "default": "#ffffff" },
    { "type": "text", "id": "reviews_eyebrow", "label": "Eyebrow", "default": "REAL RESULTS" },
    { "type": "text", "id": "reviews_heading", "label": "Heading", "default": "WHAT OUR" },
    { "type": "text", "id": "reviews_heading_em", "label": "Heading (em)", "default": "CUSTOMERS SAY" }
  ,
    { "type": "header", "content": "Typography — desktop" },
    { "type": "range", "id": "eyebrow_size_d", "label": "Eyebrow size (px)", "min": 8, "max": 28, "step": 1, "default": 11 },
    { "type": "range", "id": "heading_size_d", "label": "Heading size (px)", "min": 18, "max": 80, "step": 2, "default": 44 },
    { "type": "range", "id": "sub_size_d", "label": "Sub-heading / body size (px)", "min": 12, "max": 28, "step": 1, "default": 16 },
    { "type": "header", "content": "Typography — mobile" },
    { "type": "range", "id": "eyebrow_size_m", "label": "Eyebrow size (px)", "min": 8, "max": 22, "step": 1, "default": 11 },
    { "type": "range", "id": "heading_size_m", "label": "Heading size (px)", "min": 16, "max": 60, "step": 2, "default": 28 },
    { "type": "range", "id": "sub_size_m", "label": "Sub-heading / body size (px)", "min": 12, "max": 22, "step": 1, "default": 14 }],
  "blocks": [
    { "type": "review", "name": "Review", "limit": 9, "settings": [
      { "type": "textarea", "id": "quote", "label": "Quote" },
      { "type": "text", "id": "name", "label": "Name" },
      { "type": "text", "id": "meta", "label": "Meta" },
      { "type": "image_picker", "id": "photo", "label": "Photo" }
    ]}
  ],
  "presets": [ { "name": "FK v3 — Reviews" } ],
  "enabled_on": { "templates": ["product"] }
}
{% endschema %}
