{%- render 'leo_kit_chrome' -%}

{%- liquid
  assign p = product
  assign mf_title = p.metafields.custom.sub_offer_title
  assign mf_desc = p.metafields.custom.sub_offer_desc
  assign offer_title = mf_title | default: section.settings.title
  assign offer_desc = mf_desc | default: section.settings.description
  assign show_offer = false
  if offer_title != blank or offer_desc != blank
    assign show_offer = true
  endif
-%}

{%- if show_offer -%}
  <section class="gb-subscribe-offer-section ferment-pdp-leo" {%- render 'leo_kit_attrs' -%}>
    <div class="container">
      <div class="gb-subscribe-offer">
        {%- if section.settings.icon_emoji != blank -%}
          <div class="gb-subscribe-offer-icon" aria-hidden="true">{{ section.settings.icon_emoji }}</div>
        {%- endif -%}
        <div class="gb-subscribe-offer-text">
          {%- if offer_title != blank -%}
            <div class="gb-subscribe-offer-title">{{ offer_title }}</div>
          {%- endif -%}
          {%- if offer_desc != blank -%}
            <div class="gb-subscribe-offer-desc">{{ offer_desc }}</div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "GB · Subscribe Offer (v2)",
  "tag": "section",
  "class": "gb-subscribe-offer-wrap",
  "settings": [
    {
      "type": "header",
      "content": "Reads from product metafields: sub_offer_title, sub_offer_desc"
    },
    {
      "type": "text",
      "id": "icon_emoji",
      "label": "Icon emoji (optional)",
      "default": "♻️"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Offer title — Theme Editor fallback",
      "default": "Subscribe & save 15%"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Offer description — Theme Editor fallback",
      "default": "Auto-ship every 4 weeks. Cancel any time."
    },
    {
      "type": "range",
      "id": "pad_top_d",
      "label": "Padding top — desktop (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 32
    },
    {
      "type": "range",
      "id": "pad_bot_d",
      "label": "Padding bottom — desktop (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 32
    },
    {
      "type": "range",
      "id": "pad_top_m",
      "label": "Padding top — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 20
    },
    {
      "type": "range",
      "id": "pad_bot_m",
      "label": "Padding bottom — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "GB · Subscribe Offer (v2)"
    }
  ]
}
{% endschema %}
