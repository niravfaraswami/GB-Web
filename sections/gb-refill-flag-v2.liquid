{%- render 'leo_kit_chrome' -%}

{%- liquid
  assign p = product
  assign mf_companion = p.metafields.custom.companion_size_product.value
  assign mf_parent_label = p.metafields.custom.parent_kit_link_text
  assign mf_kit_label = p.metafields.custom.kit_label_format
  assign parent_url = ''
  if mf_companion != blank
    assign parent_url = mf_companion.url
  endif
  assign show_flag = false
  if mf_parent_label != blank or mf_kit_label != blank or mf_companion != blank
    assign show_flag = true
  endif
-%}

{%- if show_flag -%}
  <section class="gb-refill-flag-section ferment-pdp-leo" {%- render 'leo_kit_attrs' -%}>
    <div class="container">
      <div class="gb-refill-flag">
        {%- if mf_kit_label != blank -%}
          <span class="gb-refill-flag-label">{{ mf_kit_label }}</span>
        {%- endif -%}
        {%- if mf_parent_label != blank and parent_url != blank -%}
          <a class="gb-refill-flag-link" href="{{ parent_url }}">{{ mf_parent_label }}</a>
        {%- elsif mf_parent_label != blank -%}
          <span class="gb-refill-flag-link gb-refill-flag-link--inert">{{ mf_parent_label }}</span>
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "GB · Refill Flag (v2)",
  "tag": "section",
  "class": "gb-refill-flag-wrap",
  "settings": [
    {
      "type": "header",
      "content": "Reads custom.kit_label / companion / parent"
    },
    {
      "type": "range",
      "id": "pad_top_d",
      "label": "Padding top — desktop (px)",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 16
    },
    {
      "type": "range",
      "id": "pad_bot_d",
      "label": "Padding bottom — desktop (px)",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 16
    },
    {
      "type": "range",
      "id": "pad_top_m",
      "label": "Padding top — mobile (px)",
      "min": 0,
      "max": 48,
      "step": 2,
      "default": 12
    },
    {
      "type": "range",
      "id": "pad_bot_m",
      "label": "Padding bottom — mobile (px)",
      "min": 0,
      "max": 48,
      "step": 2,
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "GB · Refill Flag (v2)"
    }
  ]
}
{% endschema %}
