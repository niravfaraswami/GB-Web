{%- render 'leo_kit_chrome' -%}

{%- liquid
  assign p = product
  assign mf_components = p.metafields.custom.featured_components.value
  assign mf_box_image = p.metafields.custom.box_image
  assign mf_box_note = p.metafields.custom.box_note
  assign pill_blocks = section.blocks | where: 'type', 'pill'
  assign has_mf = false
  if mf_components and mf_components.size > 0
    assign has_mf = true
  endif
  assign box_image = mf_box_image | default: section.settings.image
  assign box_note = mf_box_note | default: section.settings.body_note
-%}

{%- if has_mf or pill_blocks.size > 0 or box_image != blank -%}
  <section class="gb-image-pills-section ferment-pdp-leo" data-image-pos="{{ section.settings.image_position | default: 'left' }}" {%- render 'leo_kit_attrs' -%}>
    <div class="container">
      <div class="section-header centered">
        {%- if section.settings.eyebrow != blank -%}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }} <em>{{ section.settings.heading_em }}</em></h2>{%- endif -%}
      </div>

      <div class="gb-image-pills-grid">
        <div class="gb-image-pills-image">
          {%- if box_image != blank -%}
            <img src="{{ box_image | image_url: width: 1200 }}" alt="{{ section.settings.heading | escape }}" loading="lazy" width="1200" height="900">
          {%- endif -%}
        </div>
        <div class="gb-image-pills-body">
          {%- if section.settings.body_heading != blank -%}<div class="gb-image-pills-body-h">{{ section.settings.body_heading }}</div>{%- endif -%}
          <div class="gb-image-pills-list">
            {%- if has_mf -%}
              {%- for c in mf_components -%}
                {%- assign isrc = c.icon | image_url: width: 120 -%}
                {%- if isrc == blank -%}{%- assign isrc = c.icon.url -%}{%- endif -%}
                {%- if isrc == blank -%}{%- assign isrc = c.icon.src -%}{%- endif -%}
                <div class="gb-image-pill">
                  <div class="gb-image-pill-icon">
                    {%- if isrc != blank -%}
                      <span class="kit-icon-svg" data-svg-src="{{ isrc }}" aria-hidden="true"></span>
                      <img class="kit-icon-img" src="{{ isrc }}" alt="{{ c.name | escape }}" loading="lazy" width="60" height="60">
                    {%- elsif c.icon_emoji != blank -%}{{ c.icon_emoji }}{%- endif -%}
                  </div>
                  <div class="gb-image-pill-text">
                    <div class="gb-image-pill-h">{{ c.name | default: c.heading }}</div>
                    {%- assign csub = c.description | default: c.sub -%}
                    {%- if csub != blank -%}<div class="gb-image-pill-sub">{{ csub }}</div>{%- endif -%}
                  </div>
                </div>
              {%- endfor -%}
            {%- else -%}
              {%- for block in pill_blocks -%}
                {%- assign bsrc = block.settings.image | image_url: width: 120 -%}
                {%- if bsrc == blank -%}{%- assign bsrc = block.settings.image.url -%}{%- endif -%}
                {%- if bsrc == blank -%}{%- assign bsrc = block.settings.image.src -%}{%- endif -%}
                <div class="gb-image-pill" {{ block.shopify_attributes }}>
                  <div class="gb-image-pill-icon">
                    {%- if bsrc != blank -%}
                      <span class="kit-icon-svg" data-svg-src="{{ bsrc }}" aria-hidden="true"></span>
                      <img class="kit-icon-img" src="{{ bsrc }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="60" height="60">
                    {%- elsif block.settings.icon_emoji != blank -%}{{ block.settings.icon_emoji }}{%- endif -%}
                  </div>
                  <div class="gb-image-pill-text">
                    <div class="gb-image-pill-h">{{ block.settings.heading }}</div>
                    {%- if block.settings.sub != blank -%}<div class="gb-image-pill-sub">{{ block.settings.sub }}</div>{%- endif -%}
                  </div>
                </div>
              {%- endfor -%}
            {%- endif -%}
          </div>
          {%- if box_note != blank -%}<div class="gb-image-pills-note">{{ box_note }}</div>{%- endif -%}
        </div>
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "GB · Image + Pills (v2)",
  "tag": "section",
  "class": "gb-image-pills-wrap",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "heading_em",
      "label": "Heading (highlighted)"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position (desktop)",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "body_heading",
      "label": "Body heading"
    },
    {
      "type": "textarea",
      "id": "body_note",
      "label": "Note (small print, below pills)"
    },
    {
      "type": "header",
      "content": "Spacing & Typography"
    },
    {
      "type": "range",
      "id": "pad_top_d",
      "label": "Padding top — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_bot_d",
      "label": "Padding bottom — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_top_m",
      "label": "Padding top — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "pad_bot_m",
      "label": "Padding bottom — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "mar_top_d",
      "label": "Margin top — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_d",
      "label": "Margin bottom — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_top_m",
      "label": "Margin top — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_m",
      "label": "Margin bottom — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "eyebrow_size_d",
      "label": "Eyebrow font size — desktop (px)",
      "min": 9,
      "max": 32,
      "step": 1,
      "default": 22
    },
    {
      "type": "range",
      "id": "eyebrow_size_m",
      "label": "Eyebrow font size — mobile (px)",
      "min": 9,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "heading_size_d",
      "label": "Heading font size — desktop (px)",
      "min": 18,
      "max": 80,
      "step": 2,
      "default": 44
    },
    {
      "type": "range",
      "id": "heading_size_m",
      "label": "Heading font size — mobile (px)",
      "min": 16,
      "max": 60,
      "step": 2,
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "pill",
      "name": "Pill",
      "limit": 12,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Pill icon image (optional)"
        },
        {
          "type": "text",
          "id": "icon_emoji",
          "label": "Pill icon emoji (fallback)"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Pill heading"
        },
        {
          "type": "text",
          "id": "sub",
          "label": "Pill sub-text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GB · Image + Pills (v2)"
    }
  ]
}
{% endschema %}
