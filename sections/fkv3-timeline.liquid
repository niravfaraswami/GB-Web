{%- liquid
  assign p = product
  assign mf_timeline = p.metafields.custom.featured_timeline_steps.value
  assign mf_timeline_eyebrow = p.metafields.custom.timeline_eyebrow
  assign mf_timeline_h = p.metafields.custom.timeline_h
  assign mf_timeline_subtitle = p.metafields.custom.timeline_subtitle
  assign timeline_blocks = section.blocks | where: 'type', 'timeline_step'
-%}
{%- if mf_timeline != blank or timeline_blocks.size > 0 -%}
  <div data-kit="fermentation" class="ferment-pdp fkv3-timeline-wrap" {%- render 'fkv3-section-attrs' -%}>
    {%- render 'fkv3-color-cascade' -%}
    <section class="health-timeline-section">
      <div class="container">
        <div class="section-header">
          <div class="eyebrow">{{ mf_timeline_eyebrow | default: section.settings.timeline_eyebrow }}</div>
          {%- if mf_timeline_h != blank -%}<h2>{{ mf_timeline_h }}</h2>
          {%- else -%}<h2>{{ section.settings.timeline_heading | default: "YOUR GUT'S" }}<br><em>{{ section.settings.timeline_heading_em }}</em></h2>{%- endif -%}
          {%- assign tsub = mf_timeline_subtitle | default: section.settings.timeline_subtitle -%}
          {%- if tsub != blank -%}<p class="ht-sub">{{ tsub }}</p>{%- endif -%}
        </div>
        <div class="ht-timeline">
          {%- if mf_timeline != blank -%}
            {%- for t in mf_timeline -%}
              <div class="ht-card"><span class="ht-day">{{ t.period_label }}</span><div class="ht-h">{{ t.heading }}</div><div class="ht-d">{{ t.description }}</div></div>
            {%- endfor -%}
          {%- else -%}
            {%- for block in timeline_blocks -%}
              <div class="ht-card" {{ block.shopify_attributes }}><span class="ht-day">{{ block.settings.period_label }}</span><div class="ht-h">{{ block.settings.heading }}</div><div class="ht-d">{{ block.settings.description }}</div></div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    </section>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "FK v3 — Timeline",
  "tag": "section",
  "class": "fkv3-timeline-wrap",
  "settings": [
    { "type": "color", "id": "section_bg", "label": "Section background", "default": "#ffffff" },
    { "type": "text", "id": "timeline_eyebrow", "label": "Eyebrow", "default": "WHAT TO EXPECT" },
    { "type": "text", "id": "timeline_heading", "label": "Heading", "default": "YOUR GUT'S" },
    { "type": "text", "id": "timeline_heading_em", "label": "Heading (em)", "default": "FIRST 30 DAYS." },
    { "type": "textarea", "id": "timeline_subtitle", "label": "Subtitle" }
  ,
    { "type": "header", "content": "Spacing — desktop" },
    { "type": "range", "id": "pad_top_d", "label": "Padding top (px)", "min": 0, "max": 200, "step": 4, "default": 0 },
    { "type": "range", "id": "pad_bot_d", "label": "Padding bottom (px)", "min": 0, "max": 200, "step": 4, "default": 0 },
    { "type": "range", "id": "mar_top_d", "label": "Margin top (px)", "min": 0, "max": 100, "step": 4, "default": 0 },
    { "type": "range", "id": "mar_bot_d", "label": "Margin bottom (px)", "min": 0, "max": 100, "step": 4, "default": 0 },
    { "type": "header", "content": "Spacing — mobile" },
    { "type": "range", "id": "pad_top_m", "label": "Padding top (px)", "min": 0, "max": 120, "step": 4, "default": 0 },
    { "type": "range", "id": "pad_bot_m", "label": "Padding bottom (px)", "min": 0, "max": 120, "step": 4, "default": 0 },
    { "type": "range", "id": "mar_top_m", "label": "Margin top (px)", "min": 0, "max": 80, "step": 4, "default": 0 },
    { "type": "range", "id": "mar_bot_m", "label": "Margin bottom (px)", "min": 0, "max": 80, "step": 4, "default": 0 },
    { "type": "header", "content": "Typography — desktop" },
    { "type": "range", "id": "eyebrow_size_d", "label": "Eyebrow size (px)", "min": 0, "max": 28, "step": 1, "default": 0 },
    { "type": "range", "id": "heading_size_d", "label": "Heading size (px)", "min": 0, "max": 80, "step": 2, "default": 0 },
    { "type": "range", "id": "sub_size_d", "label": "Sub-heading / body size (px)", "min": 0, "max": 28, "step": 1, "default": 0 },
    { "type": "header", "content": "Typography — mobile" },
    { "type": "range", "id": "eyebrow_size_m", "label": "Eyebrow size (px)", "min": 0, "max": 22, "step": 1, "default": 0 },
    { "type": "range", "id": "heading_size_m", "label": "Heading size (px)", "min": 0, "max": 60, "step": 2, "default": 0 },
    { "type": "range", "id": "sub_size_m", "label": "Sub-heading / body size (px)", "min": 0, "max": 22, "step": 1, "default": 0 }],
  "blocks": [
    { "type": "timeline_step", "name": "Timeline step", "limit": 8, "settings": [
      { "type": "text", "id": "period_label", "label": "Period label", "default": "WEEK 1" },
      { "type": "text", "id": "heading", "label": "Heading" },
      { "type": "textarea", "id": "description", "label": "Description" }
    ]}
  ],
  "presets": [ { "name": "FK v3 — Timeline" } ],
  "enabled_on": { "templates": ["product"] }
}
{% endschema %}
