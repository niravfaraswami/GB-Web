{%- render 'leo_kit_chrome' -%}

{%- assign kp = section.settings.product -%}

{%- if kp or section.settings.title != blank -%}
  <section class="kit-cta-section" {%- render 'leo_kit_attrs' -%}>
    <div class="container">
      <div class="kit-cta-card">
        <div>
          {%- if section.settings.eyebrow != blank -%}<div class="kit-cta-eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
          {%- if section.settings.title != blank -%}<div class="kit-cta-title">{{ section.settings.title }}</div>{%- endif -%}
          {%- if section.settings.desc != blank -%}<div class="kit-cta-desc">{{ section.settings.desc }}</div>{%- endif -%}
        </div>
        <div class="kit-cta-product">
          <div class="kit-cta-img">
            {%- if kp.featured_image -%}
              <img src="{{ kp.featured_image | image_url: width: 200 }}" alt="{{ kp.title | escape }}" width="100" height="100">
            {%- elsif section.settings.emoji != blank -%}
              {{ section.settings.emoji }}
            {%- elsif kp.metafields.custom.emoji != blank -%}
              {{ kp.metafields.custom.emoji }}
            {%- else -%}🫙{%- endif -%}
          </div>
          <div class="kit-cta-info">
            <div class="kit-cta-name">{{ section.settings.name_override | default: kp.title }}</div>
            <div class="kit-cta-price">{{ section.settings.price_override | default: kp.price | money }}</div>
            <a href="{{ kp.url | default: section.settings.cta_url | default: '#' }}" class="kit-cta-button">{{ section.settings.cta_label | default: 'Shop Now →' }}</a>
          </div>
        </div>
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "GB · Learn Recipe Kit CTA",
  "tag": "section",
  "class": "gb-learn-recipe-kit-cta-wrap",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "MAKE THIS RECIPE" },
    { "type": "text", "id": "title", "label": "Title", "default": "Get the kit that does the work for you." },
    { "type": "textarea", "id": "desc", "label": "Description" },
    { "type": "header", "content": "Product (right-side block)" },
    { "type": "product", "id": "product", "label": "Featured product (the kit)" },
    { "type": "text", "id": "name_override", "label": "Product name override (optional)" },
    { "type": "text", "id": "price_override", "label": "Price override (optional)" },
    { "type": "text", "id": "emoji", "label": "Emoji fallback", "default": "🫙" },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Shop Now →" },
    { "type": "url", "id": "cta_url", "label": "Button URL (only if no product set)" },
    { "type": "header", "content": "Spacing & Typography" },
    { "type": "range", "id": "pad_top_d", "label": "Padding top — desktop (px)", "min": 0, "max": 200, "step": 4, "default": 64 },
    { "type": "range", "id": "pad_bot_d", "label": "Padding bottom — desktop (px)", "min": 0, "max": 200, "step": 4, "default": 80 },
    { "type": "range", "id": "pad_top_m", "label": "Padding top — mobile (px)", "min": 0, "max": 120, "step": 4, "default": 48 },
    { "type": "range", "id": "pad_bot_m", "label": "Padding bottom — mobile (px)", "min": 0, "max": 120, "step": 4, "default": 56 }
  ],
  "presets": [{ "name": "GB · Learn Recipe Kit CTA" }]
}
{% endschema %}
