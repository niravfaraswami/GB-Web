{%- render 'leo_kit_chrome' -%}

{%- capture body_html -%}{%- render 'gb-recipe-body-section', section_name: 'notes', section_aliases: 'notes|notes & variations|notes and variations|tips|tips & notes|variations' -%}{%- endcapture -%}
{%- assign body_html = body_html | strip -%}
{%- assign note_blocks = section.blocks | where: 'type', 'note' -%}
{%- assign has_body = false -%}
{%- if body_html != '' -%}{%- assign has_body = true -%}{%- endif -%}

{%- if has_body or note_blocks.size > 0 -%}
  <section class="recipe-section recipe-section--natural" id="{{ section.settings.anchor | default: 'notes' }}" {%- render 'leo_kit_attrs' -%}>
    <div class="container">
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.sub != blank -%}<div class="section-sub">{{ section.settings.sub }}</div>{%- endif -%}
      {%- if has_body -%}
        <div class="recipe-body-content recipe-body-content--notes">{{ body_html }}</div>
      {%- else -%}
        <ul class="notes-list">
          {%- for block in note_blocks -%}
            <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "GB · Learn Recipe Notes",
  "tag": "section",
  "class": "gb-learn-recipe-notes-wrap",
  "settings": [
    { "type": "text", "id": "anchor", "label": "Anchor ID", "default": "notes" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Notes & variations" },
    { "type": "text", "id": "sub", "label": "Sub-heading", "default": "Tweaks, swaps, and what we've learned." },
    { "type": "header", "content": "Spacing & Typography" },
    { "type": "range", "id": "pad_top_d", "label": "Padding top — desktop (px)", "min": 0, "max": 200, "step": 4, "default": 64 },
    { "type": "range", "id": "pad_bot_d", "label": "Padding bottom — desktop (px)", "min": 0, "max": 200, "step": 4, "default": 64 },
    { "type": "range", "id": "pad_top_m", "label": "Padding top — mobile (px)", "min": 0, "max": 120, "step": 4, "default": 48 },
    { "type": "range", "id": "pad_bot_m", "label": "Padding bottom — mobile (px)", "min": 0, "max": 120, "step": 4, "default": 48 }
  ],
  "blocks": [
    { "type": "note", "name": "Note", "limit": 12, "settings": [
      { "type": "richtext", "id": "text", "label": "Note text" }
    ]}
  ],
  "presets": [{ "name": "GB · Learn Recipe Notes" }]
}
{% endschema %}
