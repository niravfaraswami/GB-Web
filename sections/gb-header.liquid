<script>
  (function () {
    function syncHeaderHeights() {
      var header = document.querySelector('.gb-site-header');
      if (!header) return;
      var h = header.offsetHeight;
      // Match the CSS variable names Shopify Horizon uses elsewhere in the theme.
      document.body.style.setProperty('--header-height', h + 'px');
      document.body.style.setProperty('--header-group-height', h + 'px');
      document.body.style.setProperty('--top-row-height', h + 'px');
    }
    function init(scope) {
      var root = scope || document;
      // ---------- Mega menu (desktop) ----------
      var triggers = root.querySelectorAll ? root.querySelectorAll('.nav-trigger') : [];
      var menus    = root.querySelectorAll ? root.querySelectorAll('.mega-menu') : [];
      function closeAll() {
        menus.forEach(function (m) { m.classList.remove('open'); });
        triggers.forEach(function (t) { t.classList.remove('open', 'active'); t.setAttribute('aria-expanded', 'false'); });
      }
      triggers.forEach(function (trigger) {
        if (trigger.dataset.bound) return;
        trigger.dataset.bound = '1';
        trigger.addEventListener('click', function (e) {
          e.stopPropagation();
          var targetId = trigger.dataset.trigger;
          var menu = document.querySelector('.mega-menu[data-menu="' + targetId + '"]');
          var wasOpen = trigger.classList.contains('open');
          closeAll();
          if (!wasOpen && menu) {
            menu.classList.add('open');
            trigger.classList.add('open', 'active');
            trigger.setAttribute('aria-expanded', 'true');
          }
        });
      });
      // close on outside click + Escape
      if (!document.body.dataset.gbHeaderBound) {
        document.body.dataset.gbHeaderBound = '1';
        document.addEventListener('click', function (e) {
          if (!e.target.closest('.primary-nav') && !e.target.closest('.mega-menu')) closeAll();
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') { closeAll(); closeMobileMenu(); }
        });
        // close on link click in mega-menu
        document.querySelectorAll('.mega-menu a').forEach(function (link) {
          link.addEventListener('click', function () { closeAll(); });
        });
      }

      // ---------- Mobile drawer ----------
      var drawer = document.getElementById('mobile-drawer');
      var toggle = document.getElementById('mobile-menu-toggle');
      function openMobileMenu() { if (drawer) { drawer.classList.add('open'); drawer.setAttribute('aria-hidden', 'false'); document.body.style.overflow = 'hidden'; } }
      function closeMobileMenu() { if (drawer) { drawer.classList.remove('open'); drawer.setAttribute('aria-hidden', 'true'); document.body.style.overflow = ''; } }
      window.openMobileMenu = openMobileMenu;
      window.closeMobileMenu = closeMobileMenu;
      if (toggle && !toggle.dataset.bound) { toggle.dataset.bound = '1'; toggle.addEventListener('click', openMobileMenu); }
      document.querySelectorAll('[data-md-close]').forEach(function (el) {
        if (el.dataset.bound) return;
        el.dataset.bound = '1';
        el.addEventListener('click', closeMobileMenu);
      });

      syncHeaderHeights();
    }

    // ---------- Smart sticky header ----------
    // Behavior:
    //  - Page at top (scrollY ≤ 100): header always visible, no shadow
    //  - Past 100px, scrolling down 30px+ accumulated: slide header up
    //  - Scrolling up 15px+ accumulated: slide header back down immediately
    //  - Any drawer/menu open: force-visible so users can close it
    //  - Subtle shadow whenever scrollY > 0
    // Direction-change resets the opposite accumulator so the gestures
    // measure intent within a single scroll direction, not lifetime delta.
    function initSmartSticky() {
      var header = document.querySelector('.gb-site-header');
      if (!header || header.dataset.smartStickyBound) return;
      header.dataset.smartStickyBound = '1';

      var DOWN_THRESHOLD = 30;
      var UP_THRESHOLD = 15;
      var ENGAGE_AFTER = 100;

      var lastY = window.scrollY || window.pageYOffset || 0;
      var accumDown = 0;
      var accumUp = 0;
      var ticking = false;
      var wasHidden = false;
      var wasScrolled = false;

      function anyDrawerOpen() {
        return !!(
          document.querySelector('.mega-menu.open') ||
          document.querySelector('#mobile-drawer.open') ||
          document.querySelector('cart-drawer-component[open]') ||
          document.querySelector('cart-drawer-component.is-open') ||
          document.querySelector('.cart-drawer.is-open') ||
          document.body.classList.contains('cart-drawer-open') ||
          document.body.classList.contains('drawer-open')
        );
      }

      function setHidden(hidden) {
        if (hidden === wasHidden) return;
        wasHidden = hidden;
        header.classList.toggle('is-hidden', hidden);
      }
      function setScrolled(scrolled) {
        if (scrolled === wasScrolled) return;
        wasScrolled = scrolled;
        header.classList.toggle('is-scrolled', scrolled);
      }

      function update() {
        ticking = false;
        var y = window.scrollY || window.pageYOffset || 0;
        var delta = y - lastY;

        setScrolled(y > 0);

        if (y <= ENGAGE_AFTER || anyDrawerOpen()) {
          setHidden(false);
          accumDown = 0; accumUp = 0;
          lastY = y;
          return;
        }

        if (delta > 0) {
          accumDown += delta;
          accumUp = 0;
          if (accumDown >= DOWN_THRESHOLD) setHidden(true);
        } else if (delta < 0) {
          accumUp += -delta;
          accumDown = 0;
          if (accumUp >= UP_THRESHOLD) setHidden(false);
        }

        lastY = y;
      }

      window.addEventListener('scroll', function () {
        if (!ticking) {
          requestAnimationFrame(update);
          ticking = true;
        }
      }, { passive: true });
    }

    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', function () { init(); initSmartSticky(); }); else { init(); initSmartSticky(); }
    document.addEventListener('shopify:section:load', function (e) { init(e.target); initSmartSticky(); });
    window.addEventListener('resize', syncHeaderHeights);
    window.addEventListener('load', syncHeaderHeights);
  })();
</script>

