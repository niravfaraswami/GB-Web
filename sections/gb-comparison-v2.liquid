{%- render 'leo_kit_chrome' -%}

{%- liquid
  assign p = product
  assign mf_rows = p.metafields.custom.featured_comparison_rows.value
  assign mf_compare_eyebrow = p.metafields.custom.compare_eyebrow
  assign mf_compare_heading = p.metafields.custom.compare_heading
  assign mf_compare_left = p.metafields.custom.compare_left_label
  assign mf_compare_right = p.metafields.custom.compare_right_label
  assign cmp_blocks = section.blocks | where: 'type', 'cmp_row'
  assign has_mf = false
  if mf_rows and mf_rows.size > 0
    assign has_mf = true
  endif
  assign cmp_eyebrow = mf_compare_eyebrow | default: section.settings.eyebrow
  assign cmp_heading = mf_compare_heading | default: section.settings.heading
-%}

{%- if has_mf or cmp_blocks.size > 0 or cmp_heading != blank -%}
  {%- assign col_count = section.settings.col_count | default: 3 -%}
  {%- assign cmp_style = section.settings.style | default: 'default' -%}
  {%- assign kit_pos = section.settings.kit_position | default: 'left' -%}
  <section class="gb-comparison-section ferment-pdp-leo" data-cols="{{ col_count }}" data-style="{{ cmp_style }}" data-kit-pos="{{ kit_pos }}" {%- render 'leo_kit_attrs' -%}>
    <div class="container">
      <div class="section-header centered">
        {%- if cmp_eyebrow != blank -%}<div class="eyebrow">{{ cmp_eyebrow }}</div>{%- endif -%}
        {%- if cmp_heading != blank -%}
          {%- assign heading_lines = cmp_heading | newline_to_br | split: '<br />' -%}
          {%- assign non_empty_line_count = 0 -%}
          {%- for l in heading_lines -%}
            {%- assign tl_count = l | strip -%}
            {%- if tl_count != blank -%}{%- assign non_empty_line_count = non_empty_line_count | plus: 1 -%}{%- endif -%}
          {%- endfor -%}
          <h2>
            {%- for line in heading_lines -%}
              {%- assign tl = line | strip -%}
              {%- if tl != blank -%}
                {%- if forloop.first -%}{{ tl }}{%- else -%} <em>{{ tl }}</em>{%- endif -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if non_empty_line_count <= 1 and section.settings.heading_em != blank -%} <em>{{ section.settings.heading_em }}</em>{%- endif -%}
          </h2>
        {%- endif -%}
      </div>

      <div class="gb-cmp-table-wrap">
        <div class="gb-cmp-table">
          <div class="gb-cmp-head">
            <div class="gb-cmp-h-cell gb-cmp-h-label">&nbsp;</div>
            {%- if kit_pos == 'right' -%}
              <div class="gb-cmp-h-cell">{{ mf_compare_right | default: section.settings.col_2_label | default: 'Alternative A' }}</div>
              {%- if col_count == 3 or col_count == '3' -%}
                <div class="gb-cmp-h-cell">{{ section.settings.col_3_label | default: 'Alternative B' }}</div>
              {%- endif -%}
              <div class="gb-cmp-h-cell gb-cmp-h-kit">{{ mf_compare_left | default: section.settings.col_kit_label | default: 'GutBasket' }}</div>
            {%- else -%}
              <div class="gb-cmp-h-cell gb-cmp-h-kit">{{ mf_compare_left | default: section.settings.col_kit_label | default: 'GutBasket' }}</div>
              <div class="gb-cmp-h-cell">{{ mf_compare_right | default: section.settings.col_2_label | default: 'Alternative A' }}</div>
              {%- if col_count == 3 or col_count == '3' -%}
                <div class="gb-cmp-h-cell">{{ section.settings.col_3_label | default: 'Alternative B' }}</div>
              {%- endif -%}
            {%- endif -%}
          </div>

          {%- if has_mf -%}
            {%- for r in mf_rows -%}
              {%- comment -%}
                Field-name resolution for kit_comparison_row metaobjects.
                Prebiotic-v2 metaobjects use: row_label, left_subtext (→ kit / right visual col),
                right_subtext (→ alternative / cream visual col). The data is intentionally
                swapped — preserve this mapping. Falls back to the legacy block-style names
                (label / kit_text / col2_text / col3_text) so anything older still renders.
              {%- endcomment -%}
              {%- assign r_label = r.row_label | default: r.label | default: r.left_heading -%}
              {%- assign r_kit_text = r.left_subtext | default: r.kit_text -%}
              {%- assign r_col2_mark = r.col2_mark | default: r.col3_mark -%}
              {%- assign r_col2_text = r.right_subtext | default: r.col2_text | default: r.col3_text -%}
              {%- assign r_col3_mark = r.col3_mark_2 | default: r.col4_mark -%}
              {%- assign r_col3_text = r.col3_text_2 | default: r.col4_text -%}
              <div class="gb-cmp-row">
                <div class="gb-cmp-cell gb-cmp-cell-label">{{ r_label }}</div>
                {%- if kit_pos == 'right' -%}
                  <div class="gb-cmp-cell gb-cmp-cell-other">
                    {%- if r_col2_mark == 'yes' -%}<span class="gb-cmp-mark gb-cmp-mark-yes"></span>
                    {%- elsif r_col2_mark == 'no' -%}<span class="gb-cmp-mark gb-cmp-mark-no"></span>{%- endif -%}
                    {{ r_col2_text }}
                  </div>
                  {%- if col_count == 3 or col_count == '3' -%}
                    <div class="gb-cmp-cell gb-cmp-cell-other">
                      {%- if r_col3_mark == 'yes' -%}<span class="gb-cmp-mark gb-cmp-mark-yes"></span>
                      {%- elsif r_col3_mark == 'no' -%}<span class="gb-cmp-mark gb-cmp-mark-no"></span>{%- endif -%}
                      {{ r_col3_text }}
                    </div>
                  {%- endif -%}
                  <div class="gb-cmp-cell gb-cmp-cell-kit">
                    {%- if r.kit_mark == 'yes' -%}<span class="gb-cmp-mark gb-cmp-mark-yes"></span>
                    {%- elsif r.kit_mark == 'no' -%}<span class="gb-cmp-mark gb-cmp-mark-no"></span>{%- endif -%}
                    {{ r_kit_text }}
                  </div>
                {%- else -%}
                  <div class="gb-cmp-cell gb-cmp-cell-kit">
                    {%- if r.kit_mark == 'yes' -%}<span class="gb-cmp-mark gb-cmp-mark-yes"></span>
                    {%- elsif r.kit_mark == 'no' -%}<span class="gb-cmp-mark gb-cmp-mark-no"></span>{%- endif -%}
                    {{ r_kit_text }}
                  </div>
                  <div class="gb-cmp-cell gb-cmp-cell-other">
                    {%- if r_col2_mark == 'yes' -%}<span class="gb-cmp-mark gb-cmp-mark-yes"></span>
                    {%- elsif r_col2_mark == 'no' -%}<span class="gb-cmp-mark gb-cmp-mark-no"></span>{%- endif -%}
                    {{ r_col2_text }}
                  </div>
                  {%- if col_count == 3 or col_count == '3' -%}
                    <div class="gb-cmp-cell gb-cmp-cell-other">
                      {%- if r_col3_mark == 'yes' -%}<span class="gb-cmp-mark gb-cmp-mark-yes"></span>
                      {%- elsif r_col3_mark == 'no' -%}<span class="gb-cmp-mark gb-cmp-mark-no"></span>{%- endif -%}
                      {{ r_col3_text }}
                    </div>
                  {%- endif -%}
                {%- endif -%}
              </div>
            {%- endfor -%}
          {%- else -%}
            {%- for block in cmp_blocks -%}
              <div class="gb-cmp-row" {{ block.shopify_attributes }}>
                <div class="gb-cmp-cell gb-cmp-cell-label">{{ block.settings.label }}</div>
                {%- if kit_pos == 'right' -%}
                  <div class="gb-cmp-cell gb-cmp-cell-other">
                    {%- if block.settings.col2_mark == 'yes' -%}<span class="gb-cmp-mark gb-cmp-mark-yes"></span>
                    {%- elsif block.settings.col2_mark == 'no' -%}<span class="gb-cmp-mark gb-cmp-mark-no"></span>{%- endif -%}
                    {{ block.settings.col2_text }}
                  </div>
                  {%- if col_count == 3 or col_count == '3' -%}
                    <div class="gb-cmp-cell gb-cmp-cell-other">
                      {%- if block.settings.col3_mark == 'yes' -%}<span class="gb-cmp-mark gb-cmp-mark-yes"></span>
                      {%- elsif block.settings.col3_mark == 'no' -%}<span class="gb-cmp-mark gb-cmp-mark-no"></span>{%- endif -%}
                      {{ block.settings.col3_text }}
                    </div>
                  {%- endif -%}
                  <div class="gb-cmp-cell gb-cmp-cell-kit">
                    {%- if block.settings.kit_mark == 'yes' -%}<span class="gb-cmp-mark gb-cmp-mark-yes"></span>
                    {%- elsif block.settings.kit_mark == 'no' -%}<span class="gb-cmp-mark gb-cmp-mark-no"></span>{%- endif -%}
                    {{ block.settings.kit_text }}
                  </div>
                {%- else -%}
                  <div class="gb-cmp-cell gb-cmp-cell-kit">
                    {%- if block.settings.kit_mark == 'yes' -%}<span class="gb-cmp-mark gb-cmp-mark-yes"></span>
                    {%- elsif block.settings.kit_mark == 'no' -%}<span class="gb-cmp-mark gb-cmp-mark-no"></span>{%- endif -%}
                    {{ block.settings.kit_text }}
                  </div>
                  <div class="gb-cmp-cell gb-cmp-cell-other">
                    {%- if block.settings.col2_mark == 'yes' -%}<span class="gb-cmp-mark gb-cmp-mark-yes"></span>
                    {%- elsif block.settings.col2_mark == 'no' -%}<span class="gb-cmp-mark gb-cmp-mark-no"></span>{%- endif -%}
                    {{ block.settings.col2_text }}
                  </div>
                  {%- if col_count == 3 or col_count == '3' -%}
                    <div class="gb-cmp-cell gb-cmp-cell-other">
                      {%- if block.settings.col3_mark == 'yes' -%}<span class="gb-cmp-mark gb-cmp-mark-yes"></span>
                      {%- elsif block.settings.col3_mark == 'no' -%}<span class="gb-cmp-mark gb-cmp-mark-no"></span>{%- endif -%}
                      {{ block.settings.col3_text }}
                    </div>
                  {%- endif -%}
                {%- endif -%}
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>

        {%- if section.settings.footer_text != blank or section.settings.footer_cta_label != blank -%}
          <div class="gb-cmp-footnote">
            {%- if section.settings.footer_text != blank -%}<div class="gb-cmp-footnote-text">{{ section.settings.footer_text }}</div>{%- endif -%}
            {%- if section.settings.footer_cta_label != blank -%}
              {%- if section.settings.footer_cta_url != blank -%}
                <a class="gb-cmp-footnote-cta" href="{{ section.settings.footer_cta_url }}">{{ section.settings.footer_cta_label }}</a>
              {%- else -%}
                <span class="gb-cmp-footnote-cta">{{ section.settings.footer_cta_label }}</span>
              {%- endif -%}
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "GB · Comparison (v2)",
  "tag": "section",
  "class": "gb-comparison-wrap",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "VS THE OTHERS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WHY OUR"
    },
    {
      "type": "text",
      "id": "heading_em",
      "label": "Heading (highlighted)",
      "default": "STANDS OUT."
    },
    {
      "type": "select",
      "id": "style",
      "label": "Visual style",
      "options": [
        { "value": "default", "label": "Default (dark header)" },
        { "value": "minimal", "label": "Minimal (mint vs cream)" }
      ],
      "default": "default"
    },
    {
      "type": "select",
      "id": "kit_position",
      "label": "Kit column position",
      "options": [
        { "value": "left",  "label": "Left (after label)" },
        { "value": "right", "label": "Right (last column)" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Footer note (optional)"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer note text"
    },
    {
      "type": "text",
      "id": "footer_cta_label",
      "label": "Footer CTA label"
    },
    {
      "type": "url",
      "id": "footer_cta_url",
      "label": "Footer CTA URL"
    },
    {
      "type": "select",
      "id": "col_count",
      "label": "Number of comparison columns (excluding kit)",
      "options": [
        {
          "value": "2",
          "label": "1 alternative"
        },
        {
          "value": "3",
          "label": "2 alternatives"
        }
      ],
      "default": "2"
    },
    {
      "type": "text",
      "id": "col_kit_label",
      "label": "Kit column label",
      "default": "GutBasket"
    },
    {
      "type": "text",
      "id": "col_2_label",
      "label": "Column 2 label"
    },
    {
      "type": "text",
      "id": "col_3_label",
      "label": "Column 3 label (only if 2 alternatives)"
    },
    {
      "type": "header",
      "content": "Spacing & Typography"
    },
    {
      "type": "range",
      "id": "pad_top_d",
      "label": "Padding top — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_bot_d",
      "label": "Padding bottom — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_top_m",
      "label": "Padding top — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "pad_bot_m",
      "label": "Padding bottom — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "mar_top_d",
      "label": "Margin top — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_d",
      "label": "Margin bottom — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_top_m",
      "label": "Margin top — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_m",
      "label": "Margin bottom — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "eyebrow_size_d",
      "label": "Eyebrow font size — desktop (px)",
      "min": 9,
      "max": 32,
      "step": 1,
      "default": 22
    },
    {
      "type": "range",
      "id": "eyebrow_size_m",
      "label": "Eyebrow font size — mobile (px)",
      "min": 9,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "heading_size_d",
      "label": "Heading font size — desktop (px)",
      "min": 18,
      "max": 80,
      "step": 2,
      "default": 44
    },
    {
      "type": "range",
      "id": "heading_size_m",
      "label": "Heading font size — mobile (px)",
      "min": 16,
      "max": 60,
      "step": 2,
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "cmp_row",
      "name": "Comparison row",
      "limit": 12,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Row label"
        },
        {
          "type": "select",
          "id": "kit_mark",
          "label": "Kit cell mark",
          "options": [
            {
              "value": "none",
              "label": "None"
            },
            {
              "value": "yes",
              "label": "✓"
            },
            {
              "value": "no",
              "label": "✕"
            }
          ],
          "default": "yes"
        },
        {
          "type": "text",
          "id": "kit_text",
          "label": "Kit cell text"
        },
        {
          "type": "select",
          "id": "col2_mark",
          "label": "Col 2 cell mark",
          "options": [
            {
              "value": "none",
              "label": "None"
            },
            {
              "value": "yes",
              "label": "✓"
            },
            {
              "value": "no",
              "label": "✕"
            }
          ],
          "default": "none"
        },
        {
          "type": "text",
          "id": "col2_text",
          "label": "Col 2 cell text"
        },
        {
          "type": "select",
          "id": "col3_mark",
          "label": "Col 3 cell mark",
          "options": [
            {
              "value": "none",
              "label": "None"
            },
            {
              "value": "yes",
              "label": "✓"
            },
            {
              "value": "no",
              "label": "✕"
            }
          ],
          "default": "none"
        },
        {
          "type": "text",
          "id": "col3_text",
          "label": "Col 3 cell text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GB · Comparison (v2)"
    }
  ]
}
{% endschema %}
