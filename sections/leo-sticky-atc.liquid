{%- render 'leo_kit_chrome' -%}

{%- liquid
  assign p = product
  assign name_truncate = section.settings.name_truncate | default: 21
  assign up_threshold = section.settings.up_threshold | default: 30
  assign show_delay = section.settings.show_delay | default: 750
-%}

{%- if section.settings.sticky_show -%}
  <div class="sticky-atc-spacer" aria-hidden="true"></div>
  <div class="sticky-atc"
       data-sticky-atc
       data-up-threshold="{{ up_threshold }}"
       data-show-delay="{{ show_delay }}"
       aria-hidden="true"
       {%- render 'leo_kit_attrs' -%}>
    <div class="sticky-atc-inner">
      <div class="sticky-atc-prod">
        {%- if p.featured_image -%}
          <img class="sticky-atc-img" src="{{ p.featured_image | image_url: width: 160 }}" alt="{{ p.title | escape }}" width="48" height="48">
        {%- endif -%}
        <div class="sticky-atc-name">{{ p.title | truncate: name_truncate }}</div>
      </div>
      <div class="sticky-atc-price"><span data-sticky-price>{{ p.selected_or_first_available_variant.price | money }}</span></div>
      <button type="button" class="sticky-atc-btn" data-sticky-atc-trigger aria-label="Add to cart">
        {{ section.settings.cta_label | default: 'Add to cart' }}
      </button>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Leo · Sticky ATC",
  "tag": "section",
  "class": "leo-sticky-atc-section",
  "settings": [
    { "type": "checkbox", "id": "sticky_show", "label": "Show sticky add-to-cart bar", "default": true },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Add to cart" },
    { "type": "range", "id": "name_truncate", "label": "Truncate product name to (chars)", "min": 12, "max": 40, "step": 1, "default": 21, "info": "Includes 3-char ellipsis. CSS also truncates if the bar is narrower." },
    { "type": "header", "content": "Visibility behaviour" },
    { "type": "range", "id": "up_threshold", "label": "Scroll-up threshold (px)", "min": 10, "max": 80, "step": 5, "default": 30, "info": "Cumulative scroll-up distance required before the bar is allowed to show." },
    { "type": "range", "id": "show_delay", "label": "Pause before showing (ms)", "min": 100, "max": 2000, "step": 50, "default": 750, "info": "How long after scrolling stops before the bar slides in." }
  ],
  "presets": [{ "name": "Leo · Sticky ATC" }]
}
{% endschema %}