{%- liquid
  assign p = product
  assign review_count = p.metafields.custom.review_count | default: 0
-%}
{%- if section.settings.show_section -%}
  <section class="fk-page ferment-pdp fk-judgeme-section judgeme-section" id="judgeme-reviews" style="background:{{ section.settings.section_bg }}">
    {%- render 'fk-color-cascade' -%}
    <div class="container">
      <div class="section-header centered">
        <div class="eyebrow">{{ section.settings.judgeme_eyebrow | default: 'ALL REVIEWS' }}</div>
        <h2>{% if review_count > 0 %}{{ review_count }} {% endif %}{{ section.settings.judgeme_heading | default: 'VERIFIED' }} <em>{{ section.settings.judgeme_heading_em | default: 'REVIEWS' }}</em></h2>
      </div>
      {%- if section.settings.judgeme_embed != blank -%}
        {{ section.settings.judgeme_embed }}
      {%- else -%}
        <div class="jdgm-widget jdgm-review-widget" data-id="{{ p.id }}"></div>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "FK — Judge.me",
  "tag": "section",
  "class": "fk-judgeme-section",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show section", "default": true },
    { "type": "color", "id": "section_bg", "label": "Section background", "default": "#ffffff" },
    { "type": "text", "id": "judgeme_eyebrow", "label": "Eyebrow", "default": "ALL REVIEWS" },
    { "type": "text", "id": "judgeme_heading", "label": "Heading", "default": "VERIFIED" },
    { "type": "text", "id": "judgeme_heading_em", "label": "Heading (em)", "default": "REVIEWS" },
    { "type": "html", "id": "judgeme_embed", "label": "Custom embed (optional)" }
  ],
  "presets": [ { "name": "FK — Judge.me" } ],
  "enabled_on": { "templates": ["product"] }
}
{% endschema %}
