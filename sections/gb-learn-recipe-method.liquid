{%- render 'leo_kit_chrome' -%}

{%- assign step_blocks = section.blocks | where: 'type', 'method_step' -%}

{%- if step_blocks.size > 0 -%}
  <section class="recipe-section" id="{{ section.settings.anchor | default: 'method' }}" {%- render 'leo_kit_attrs' -%}>
    <div class="container">
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.sub != blank -%}<div class="section-sub">{{ section.settings.sub }}</div>{%- endif -%}

      {%- for block in step_blocks -%}
        <div class="method-step" {{ block.shopify_attributes }}>
          <div class="step-image">
            <span class="step-num">{{ forloop.index }}</span>
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="280" height="280">
            {%- elsif block.settings.emoji != blank -%}
              {{ block.settings.emoji }}
            {%- endif -%}
          </div>
          <div class="step-body">
            <div class="step-title">{{ block.settings.title }}</div>
            <div class="step-desc">{{ block.settings.desc }}</div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "GB · Learn Recipe Method",
  "tag": "section",
  "class": "gb-learn-recipe-method-wrap",
  "settings": [
    { "type": "text", "id": "anchor", "label": "Anchor ID", "default": "method" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Method" },
    { "type": "text", "id": "sub", "label": "Sub-heading", "default": "Step-by-step." },
    { "type": "header", "content": "Spacing & Typography" },
    { "type": "range", "id": "pad_top_d", "label": "Padding top — desktop (px)", "min": 0, "max": 200, "step": 4, "default": 64 },
    { "type": "range", "id": "pad_bot_d", "label": "Padding bottom — desktop (px)", "min": 0, "max": 200, "step": 4, "default": 64 },
    { "type": "range", "id": "pad_top_m", "label": "Padding top — mobile (px)", "min": 0, "max": 120, "step": 4, "default": 48 },
    { "type": "range", "id": "pad_bot_m", "label": "Padding bottom — mobile (px)", "min": 0, "max": 120, "step": 4, "default": 48 }
  ],
  "blocks": [
    { "type": "method_step", "name": "Method step", "limit": 15, "settings": [
      { "type": "image_picker", "id": "image", "label": "Step image (optional, square)" },
      { "type": "text", "id": "emoji", "label": "Emoji fallback (when no image)", "default": "🥬" },
      { "type": "text", "id": "title", "label": "Step title", "default": "Step title" },
      { "type": "richtext", "id": "desc", "label": "Step description" }
    ]}
  ],
  "presets": [{ "name": "GB · Learn Recipe Method" }]
}
{% endschema %}
