{%- render 'leo_kit_chrome' -%}

{%- liquid
  assign p = product
  assign f30_row_blocks  = section.blocks | where: 'type', 'f30_row'
  assign f30_stat_blocks = section.blocks | where: 'type', 'f30_stat'
  assign mf_outcome_stats = p.metafields.custom.featured_outcomes_stats.value
  assign mf_quick_benefits = p.metafields.custom.featured_quick_benefits.value
  assign has_mf_stats = false
  if mf_outcome_stats and mf_outcome_stats.size > 0
    assign has_mf_stats = true
  endif
  assign has_mf_rows = false
  if mf_quick_benefits and mf_quick_benefits.size > 0
    assign has_mf_rows = true
  endif
-%}

{%- if has_mf_rows or has_mf_stats or f30_row_blocks.size > 0 or section.settings.f30_h != blank -%}
  <section class="first30-section ferment-pdp-leo" {%- render 'leo_kit_attrs' -%}>
    <div class="container">
      <div class="first30-grid">
        <div class="first30-header">
          {%- if section.settings.f30_eyebrow != blank -%}<div class="first30-eyebrow">{{ section.settings.f30_eyebrow }}</div>{%- endif -%}
          <h2 class="first30-h">{{ section.settings.f30_h }} {%- if section.settings.f30_h_em != blank %}<em>{{ section.settings.f30_h_em }}</em>{%- endif -%}{{ section.settings.f30_h_tail }}</h2>
        </div>

        <div class="first30-rest">
          {%- if section.settings.f30_intro != blank -%}<p class="first30-intro">{{ section.settings.f30_intro }}</p>{%- endif -%}

          {%- if has_mf_rows -%}
            <div class="first30-rows">
              {%- for qb in mf_quick_benefits -%}
                <div class="first30-row">
                  <div class="f30-icon">
                    {%- if qb.icon != blank -%}{%- render 'kit_icon', icon: qb.icon, size: 24 -%}
                    {%- elsif qb.icon_emoji != blank -%}{{ qb.icon_emoji }}{%- endif -%}
                  </div>
                  <div class="f30-body">
                    <div class="f30-h">{{ qb.heading | default: qb.title }}</div>
                    <div class="f30-d">{{ qb.description | default: qb.body }}</div>
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- elsif f30_row_blocks.size > 0 -%}
            <div class="first30-rows">
              {%- for block in f30_row_blocks -%}
                <div class="first30-row" {{ block.shopify_attributes }}>
                  <div class="f30-icon">
                    {%- if block.settings.icon_svg != blank -%}{%- render 'kit_icon', icon: block.settings.icon_svg, size: 24 -%}
                    {%- elsif block.settings.icon_emoji != blank -%}{{ block.settings.icon_emoji }}{%- endif -%}
                  </div>
                  <div class="f30-body">
                    <div class="f30-h">{{ block.settings.heading }}</div>
                    <div class="f30-d">{{ block.settings.description }}</div>
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- if has_mf_stats or f30_stat_blocks.size > 0 or section.settings.f30_stats_line != blank -%}
            <div class="first30-stats-strip">
              {%- if section.settings.f30_stats_line != blank -%}<div class="first30-stats-line">{{ section.settings.f30_stats_line }}</div>{%- endif -%}
              {%- if has_mf_stats -%}
                <div class="first30-stats-row">
                  {%- for s in mf_outcome_stats -%}
                    <div class="first30-stat-cell">
                      <div class="first30-stat-circle"><div class="first30-stat-num">{{ s.num | default: s.value }}{%- if s.num_unit != blank or s.unit != blank %}<span>{{ s.num_unit | default: s.unit }}</span>{%- endif -%}</div></div>
                      <div class="first30-stat-label">{{ s.label }}</div>
                    </div>
                  {%- endfor -%}
                </div>
              {%- elsif f30_stat_blocks.size > 0 -%}
                <div class="first30-stats-row">
                  {%- for block in f30_stat_blocks -%}
                    <div class="first30-stat-cell" {{ block.shopify_attributes }}>
                      <div class="first30-stat-circle"><div class="first30-stat-num">{{ block.settings.num }}{%- if block.settings.num_unit != blank %}<span>{{ block.settings.num_unit }}</span>{%- endif -%}</div></div>
                      <div class="first30-stat-label">{{ block.settings.label }}</div>
                    </div>
                  {%- endfor -%}
                </div>
              {%- endif -%}
              {%- if section.settings.f30_disclaimer != blank -%}<div class="first30-disclaimer">{{ section.settings.f30_disclaimer }}</div>{%- endif -%}
            </div>
          {%- endif -%}
        </div>

        <div class="first30-right">
          {%- if section.settings.f30_image != blank -%}
            <img src="{{ section.settings.f30_image | image_url: width: 1200 }}" alt="{{ section.settings.f30_h | escape }}" loading="lazy" width="1000" height="1250">
          {%- endif -%}
          {%- if section.settings.f30_overlay_show -%}
            <svg class="f30-overlay-svg" viewBox="0 0 100 125" preserveAspectRatio="none" aria-hidden="true">
              <path class="f30-curve" d="M -3 130 Q 8 122 17 117 T 52 70 T 84 22 T 110 -8"/>
              <circle class="f30-dot" cx="17" cy="117" r="2.4"/>
              <circle class="f30-dot" cx="52" cy="70" r="2.4"/>
              <circle class="f30-dot" cx="84" cy="22" r="2.4"/>
            </svg>
            {%- if section.settings.f30_anno_1 != blank -%}<div class="first30-anno a1">{{ section.settings.f30_anno_1 }}</div>{%- endif -%}
            {%- if section.settings.f30_anno_2 != blank -%}<div class="first30-anno a2">{{ section.settings.f30_anno_2 }}</div>{%- endif -%}
            {%- if section.settings.f30_anno_3 != blank -%}<div class="first30-anno a3">{{ section.settings.f30_anno_3 }}</div>{%- endif -%}
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Leo · First 30 Days",
  "tag": "section",
  "class": "leo-first30-section",
  "settings": [
    {
      "type": "text",
      "id": "f30_eyebrow",
      "label": "Eyebrow",
      "default": "YOUR GUT'S FIRST 90 DAYS"
    },
    {
      "type": "text",
      "id": "f30_h",
      "label": "Heading",
      "default": "The gentle"
    },
    {
      "type": "text",
      "id": "f30_h_em",
      "label": "Heading (highlighted)",
      "default": "science"
    },
    {
      "type": "text",
      "id": "f30_h_tail",
      "label": "Heading (tail)",
      "default": " of balance."
    },
    {
      "type": "textarea",
      "id": "f30_intro",
      "label": "Intro",
      "default": "When your gut finds its rhythm, your body follows. Daily kanji rebuilds balance from the inside — and the shifts arrive on a predictable timeline."
    },
    {
      "type": "image_picker",
      "id": "f30_image",
      "label": "Right-column image"
    },
    {
      "type": "checkbox",
      "id": "f30_overlay_show",
      "label": "Show curve overlay + annotations",
      "default": true,
      "info": "Toggles the white SVG curve, the 3 dots, and all 3 annotation labels together."
    },
    {
      "type": "text",
      "id": "f30_anno_1",
      "label": "Annotation 1 (bottom-left)",
      "default": "Week 1:<br>Digestion<br>Improved"
    },
    {
      "type": "text",
      "id": "f30_anno_2",
      "label": "Annotation 2 (mid)",
      "default": "Week 2:<br>Bloating<br>Reduced"
    },
    {
      "type": "text",
      "id": "f30_anno_3",
      "label": "Annotation 3 (top-right)",
      "default": "Week 3:<br>Steady<br>Energy"
    },
    {
      "type": "text",
      "id": "f30_stats_line",
      "label": "Stats strip headline",
      "default": "Daily kanji. Live cultures. Real, measurable shifts."
    },
    {
      "type": "textarea",
      "id": "f30_disclaimer",
      "label": "Stats disclaimer",
      "default": "When accompanied by a balanced diet and regular routine. Individual results vary."
    },
    {
      "type": "header",
      "content": "Spacing & Typography"
    },
    {
      "type": "range",
      "id": "pad_top_d",
      "label": "Padding top — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_bot_d",
      "label": "Padding bottom — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_top_m",
      "label": "Padding top — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "pad_bot_m",
      "label": "Padding bottom — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "mar_top_d",
      "label": "Margin top — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_d",
      "label": "Margin bottom — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_top_m",
      "label": "Margin top — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_m",
      "label": "Margin bottom — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "eyebrow_size_d",
      "label": "Eyebrow font size — desktop (px)",
      "min": 9,
      "max": 32,
      "step": 1,
      "default": 22
    },
    {
      "type": "range",
      "id": "eyebrow_size_m",
      "label": "Eyebrow font size — mobile (px)",
      "min": 9,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "heading_size_d",
      "label": "Heading font size — desktop (px)",
      "min": 18,
      "max": 80,
      "step": 2,
      "default": 44
    },
    {
      "type": "range",
      "id": "heading_size_m",
      "label": "Heading font size — mobile (px)",
      "min": 16,
      "max": 60,
      "step": 2,
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "f30_row",
      "name": "Timeline row",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_svg",
          "label": "Icon (SVG)"
        },
        {
          "type": "text",
          "id": "icon_emoji",
          "label": "Icon emoji (fallback)"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    },
    {
      "type": "f30_stat",
      "name": "Stat circle",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "num",
          "label": "Number"
        },
        {
          "type": "text",
          "id": "num_unit",
          "label": "Number unit (e.g. %, +, L, ⁹)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Leo · First 30 Days"
    }
  ]
}
{% endschema %}
