{%- render 'leo_kit_chrome' -%}

{%- liquid
  assign p = product
  assign mf_steps = p.metafields.custom.featured_timeline_steps.value
  assign week_blocks = section.blocks | where: 'type', 'week'
  assign has_mf = false
  if mf_steps and mf_steps.size > 0
    assign has_mf = true
  endif
-%}

{%- if has_mf or week_blocks.size > 0 -%}
  <section class="gb-week-timeline-section ferment-pdp-leo" {%- render 'leo_kit_attrs' -%}>
    <div class="container">
      <div class="section-header centered">
        {%- if section.settings.eyebrow != blank -%}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }} <em>{{ section.settings.heading_em }}</em></h2>{%- endif -%}
        {%- if section.settings.intro != blank -%}<p>{{ section.settings.intro }}</p>{%- endif -%}
      </div>

      <div class="gb-week-grid">
        {%- if has_mf -%}
          {%- for s in mf_steps -%}
            {%- assign s_day = s.day_label | default: s.eyebrow | default: s.numeral -%}
            {%- assign s_h = s.heading | default: s.title -%}
            {%- assign s_d = s.description | default: s.body -%}
            <div class="gb-week-card">
              {%- if s_day != blank -%}<div class="gb-week-day">{{ s_day }}</div>{%- endif -%}
              <div class="gb-week-h">{{ s_h }}</div>
              {%- if s_d != blank -%}<div class="gb-week-d">{{ s_d }}</div>{%- endif -%}
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for block in week_blocks -%}
            <div class="gb-week-card" {{ block.shopify_attributes }}>
              {%- if block.settings.day_label != blank -%}<div class="gb-week-day">{{ block.settings.day_label }}</div>{%- endif -%}
              <div class="gb-week-h">{{ block.settings.heading }}</div>
              {%- if block.settings.description != blank -%}<div class="gb-week-d">{{ block.settings.description }}</div>{%- endif -%}
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

      {%- if section.settings.disclaimer != blank -%}
        <div class="gb-week-disclaimer">{{ section.settings.disclaimer }}</div>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "GB · Week Timeline",
  "tag": "section",
  "class": "gb-week-timeline-wrap",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "WHAT TO EXPECT"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "YOUR"
    },
    {
      "type": "text",
      "id": "heading_em",
      "label": "Heading (highlighted)",
      "default": "FIRST 30 DAYS."
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro"
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer (small print)"
    },
    {
      "type": "header",
      "content": "Spacing & Typography"
    },
    {
      "type": "range",
      "id": "pad_top_d",
      "label": "Padding top — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_bot_d",
      "label": "Padding bottom — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_top_m",
      "label": "Padding top — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "pad_bot_m",
      "label": "Padding bottom — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "mar_top_d",
      "label": "Margin top — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_d",
      "label": "Margin bottom — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_top_m",
      "label": "Margin top — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_m",
      "label": "Margin bottom — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "eyebrow_size_d",
      "label": "Eyebrow font size — desktop (px)",
      "min": 9,
      "max": 32,
      "step": 1,
      "default": 22
    },
    {
      "type": "range",
      "id": "eyebrow_size_m",
      "label": "Eyebrow font size — mobile (px)",
      "min": 9,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "heading_size_d",
      "label": "Heading font size — desktop (px)",
      "min": 18,
      "max": 80,
      "step": 2,
      "default": 44
    },
    {
      "type": "range",
      "id": "heading_size_m",
      "label": "Heading font size — mobile (px)",
      "min": 16,
      "max": 60,
      "step": 2,
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "week",
      "name": "Week / period card",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "day_label",
          "label": "Day / week label (pill)",
          "default": "WEEK 1"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GB · Week Timeline"
    }
  ]
}
{% endschema %}
