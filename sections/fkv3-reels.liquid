{%- liquid
  assign p = product
  assign mf_reels = p.metafields.custom.featured_reels.value
  assign mf_ugc_eyebrow = p.metafields.custom.ugc_eyebrow
  assign mf_reels_h = p.metafields.custom.reels_h
  assign reel_blocks = section.blocks | where: 'type', 'reel'
-%}
{%- if mf_reels != blank or section.settings.quinn_embed != blank or reel_blocks.size > 0 -%}
  <div data-kit="fermentation" class="ferment-pdp fkv3-reels-wrap">
    {%- render 'fkv3-color-cascade' -%}
    <section class="reels-section" style="background:{{ section.settings.section_bg }}">
      <div class="container">
        <div class="reels-header">
          {%- if mf_ugc_eyebrow != blank -%}<div class="eyebrow">{{ mf_ugc_eyebrow }}</div>{%- endif -%}
          {%- if mf_reels_h != blank -%}<h2>{{ mf_reels_h }}</h2>
          {%- else -%}<h2>{{ section.settings.reels_heading | default: 'Real People, Real Ferments,' }}<br><em>{{ section.settings.reels_heading_em | default: 'Real Magic' }}</em></h2>{%- endif -%}
        </div>
        {%- if mf_reels != blank -%}
          <div class="reels-grid">
            {%- for r in mf_reels -%}
              <div class="reel-tile">
                {%- if r.video != blank -%}
                  {%- if r.video.sources or r.video.media_type == 'video' -%}
                    {{ r.video | video_tag: image_size: '600x', controls: false, loop: true, muted: true, autoplay: true }}
                  {%- else -%}
                    {%- assign reel_src = r.video.url | default: r.video.src -%}
                    {%- if reel_src != blank -%}<video src="{{ reel_src }}" autoplay loop muted playsinline preload="metadata" style="width:100%;height:100%;object-fit:cover;"></video>{%- endif -%}
                  {%- endif -%}
                {%- elsif r.poster != blank -%}<img src="{{ r.poster | image_url: width: 600 }}" alt="{{ r.caption | escape }}" loading="lazy" width="600" height="1067">
                {%- endif -%}
                {%- if r.author_handle != blank -%}<span class="reels-handle">{{ r.author_handle }}</span>{%- endif -%}
                {%- if r.caption != blank -%}<span class="reels-cap">{{ r.caption }}</span>{%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- elsif section.settings.quinn_embed != blank -%}
          <div class="reels-quinn">{{ section.settings.quinn_embed }}</div>
        {%- else -%}
          <div class="reels-grid">
            {%- for block in reel_blocks -%}
              <div class="reel-tile" {{ block.shopify_attributes }}>
                {%- if block.settings.video != blank -%}{{ block.settings.video | video_tag: image_size: '600x', controls: false, loop: true, muted: true, autoplay: true }}
                {%- elsif block.settings.poster != blank -%}<img src="{{ block.settings.poster | image_url: width: 600 }}" alt="{{ block.settings.caption | escape }}" loading="lazy" width="600" height="1067">{%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </section>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "FK v3 — Reels",
  "tag": "section",
  "class": "fkv3-reels-wrap",
  "settings": [
    { "type": "color", "id": "section_bg", "label": "Section background", "default": "#ffffff" },
    { "type": "text", "id": "reels_heading", "label": "Heading", "default": "Real People, Real Ferments," },
    { "type": "text", "id": "reels_heading_em", "label": "Heading (em)", "default": "Real Magic" },
    { "type": "html", "id": "quinn_embed", "label": "Quinn embed code (fallback)" }
  ],
  "blocks": [
    { "type": "reel", "name": "UGC reel", "limit": 6, "settings": [
      { "type": "video", "id": "video", "label": "Vertical 9:16 video" },
      { "type": "image_picker", "id": "poster", "label": "Poster (fallback)" },
      { "type": "text", "id": "caption", "label": "Caption" }
    ]}
  ],
  "presets": [ { "name": "FK v3 — Reels" } ],
  "enabled_on": { "templates": ["product"] }
}
{% endschema %}
