{%- render 'leo_kit_chrome' -%}

{%- assign cmp_blocks = section.blocks | where: 'type', 'cmp_row' -%}

{%- if cmp_blocks.size > 0 -%}
  {%- assign col_count = section.settings.col_count | default: 3 -%}
  <section class="gb-comparison-section ferment-pdp-leo" data-cols="{{ col_count }}" {%- render 'leo_kit_attrs' -%}>
    <div class="container">
      <div class="section-header centered">
        {%- if section.settings.eyebrow != blank -%}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }} <em>{{ section.settings.heading_em }}</em></h2>{%- endif -%}
        {%- if section.settings.intro != blank -%}<p>{{ section.settings.intro }}</p>{%- endif -%}
      </div>

      <div class="gb-cmp-table-wrap">
        <div class="gb-cmp-table">
          <div class="gb-cmp-head">
            <div class="gb-cmp-h-cell gb-cmp-h-label">&nbsp;</div>
            <div class="gb-cmp-h-cell gb-cmp-h-kit">{{ section.settings.col_kit_label | default: 'GutBasket' }}</div>
            <div class="gb-cmp-h-cell">{{ section.settings.col_2_label | default: 'Alternative A' }}</div>
            {%- if col_count == 3 or col_count == '3' -%}
              <div class="gb-cmp-h-cell">{{ section.settings.col_3_label | default: 'Alternative B' }}</div>
            {%- endif -%}
          </div>

          {%- for block in cmp_blocks -%}
            <div class="gb-cmp-row" {{ block.shopify_attributes }}>
              <div class="gb-cmp-cell gb-cmp-cell-label">{{ block.settings.label }}</div>
              <div class="gb-cmp-cell gb-cmp-cell-kit">
                {%- if block.settings.kit_mark == 'yes' -%}<span class="gb-cmp-mark gb-cmp-mark-yes"></span>
                {%- elsif block.settings.kit_mark == 'no' -%}<span class="gb-cmp-mark gb-cmp-mark-no"></span>{%- endif -%}
                {{ block.settings.kit_text }}
              </div>
              <div class="gb-cmp-cell gb-cmp-cell-other">
                {%- if block.settings.col2_mark == 'yes' -%}<span class="gb-cmp-mark gb-cmp-mark-yes"></span>
                {%- elsif block.settings.col2_mark == 'no' -%}<span class="gb-cmp-mark gb-cmp-mark-no"></span>{%- endif -%}
                {{ block.settings.col2_text }}
              </div>
              {%- if col_count == 3 or col_count == '3' -%}
                <div class="gb-cmp-cell gb-cmp-cell-other">
                  {%- if block.settings.col3_mark == 'yes' -%}<span class="gb-cmp-mark gb-cmp-mark-yes"></span>
                  {%- elsif block.settings.col3_mark == 'no' -%}<span class="gb-cmp-mark gb-cmp-mark-no"></span>{%- endif -%}
                  {{ block.settings.col3_text }}
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "GB · Comparison",
  "tag": "section",
  "class": "gb-comparison-wrap",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "VS THE OTHERS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WHY OUR"
    },
    {
      "type": "text",
      "id": "heading_em",
      "label": "Heading (highlighted)",
      "default": "STANDS OUT."
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro"
    },
    {
      "type": "select",
      "id": "col_count",
      "label": "Number of comparison columns (excluding kit)",
      "options": [
        {
          "value": "2",
          "label": "1 alternative"
        },
        {
          "value": "3",
          "label": "2 alternatives"
        }
      ],
      "default": "2"
    },
    {
      "type": "text",
      "id": "col_kit_label",
      "label": "Kit column label",
      "default": "GutBasket"
    },
    {
      "type": "text",
      "id": "col_2_label",
      "label": "Column 2 label"
    },
    {
      "type": "text",
      "id": "col_3_label",
      "label": "Column 3 label (only if 2 alternatives)"
    },
    {
      "type": "header",
      "content": "Spacing & Typography"
    },
    {
      "type": "range",
      "id": "pad_top_d",
      "label": "Padding top — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_bot_d",
      "label": "Padding bottom — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_top_m",
      "label": "Padding top — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "pad_bot_m",
      "label": "Padding bottom — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "mar_top_d",
      "label": "Margin top — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_d",
      "label": "Margin bottom — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_top_m",
      "label": "Margin top — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_m",
      "label": "Margin bottom — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "eyebrow_size_d",
      "label": "Eyebrow font size — desktop (px)",
      "min": 9,
      "max": 32,
      "step": 1,
      "default": 22
    },
    {
      "type": "range",
      "id": "eyebrow_size_m",
      "label": "Eyebrow font size — mobile (px)",
      "min": 9,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "heading_size_d",
      "label": "Heading font size — desktop (px)",
      "min": 18,
      "max": 80,
      "step": 2,
      "default": 44
    },
    {
      "type": "range",
      "id": "heading_size_m",
      "label": "Heading font size — mobile (px)",
      "min": 16,
      "max": 60,
      "step": 2,
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "cmp_row",
      "name": "Comparison row",
      "limit": 12,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Row label"
        },
        {
          "type": "select",
          "id": "kit_mark",
          "label": "Kit cell mark",
          "options": [
            {
              "value": "none",
              "label": "None"
            },
            {
              "value": "yes",
              "label": "✓"
            },
            {
              "value": "no",
              "label": "✕"
            }
          ],
          "default": "yes"
        },
        {
          "type": "text",
          "id": "kit_text",
          "label": "Kit cell text"
        },
        {
          "type": "select",
          "id": "col2_mark",
          "label": "Col 2 cell mark",
          "options": [
            {
              "value": "none",
              "label": "None"
