            {
              "value": "yes",
              "label": "✓"
            },
            {
              "value": "no",
              "label": "✕"
            }
          ],
          "default": "none"
        },
        {
          "type": "text",
          "id": "col2_text",
          "label": "Col 2 cell text"
        },
        {
          "type": "select",
          "id": "col3_mark",
          "label": "Col 3 cell mark",
          "options": [
            {
              "value": "none",
              "label": "None"
            },
            {
              "value": "yes",
              "label": "✓"
            },
            {
              "value": "no",
              "label": "✕"
            }
          ],
          "default": "none"
        },
        {
          "type": "text",
          "id": "col3_text",
          "label": "Col 3 cell text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GB · Comparison"
    }
  ]
}
{% endschema %}
