        { "type": "menu", "settings": { "heading": "Help",
          "links_text": "Contact us | /contact\nShipping | /shipping\nReturns | /returns\nPrivacy | /privacy\nTerms | /terms",
          "contact_block": "support@gutbasket.com\n+91 78619 40110" } }
      ]
    }
  ]
}
{% endschema %}
