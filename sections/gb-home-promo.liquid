{%- comment -%}
  Section 01 · Promo bar (marquee)
  Source ref: gutbasket-home-page.html lines 1620-1641
{%- endcomment -%}

{%- liquid
  assign block_count = section.blocks.size
  assign duration = section.settings.scroll_duration | default: 38
-%}

<div class="gb-promo" aria-label="Site announcements">
  <div class="gb-promo-track" style="animation-duration: {{ duration }}s;">
    {%- for block in section.blocks -%}
      <span class="gb-promo-item" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
    {%- endfor -%}
    {%- comment -%} Duplicate for seamless loop {%- endcomment -%}
    {%- for block in section.blocks -%}
      <span class="gb-promo-item" aria-hidden="true">{{ block.settings.text }}</span>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
.gb-promo {
  background: #2B2218;
  color: #FFF9EE;
  font-family: 'DM Sans', sans-serif;
  font-size: 12.5px;
  font-weight: 500;
  letter-spacing: 0.02em;
  padding: 9px 0;
  overflow: hidden;
  white-space: nowrap;
  position: relative;
}
.gb-promo-track {
  display: inline-flex;
  gap: 36px;
  padding-left: 36px;
  animation-name: gb-promo-marquee;
  animation-timing-function: linear;
  animation-iteration-count: infinite;
  will-change: transform;
}
.gb-promo:hover .gb-promo-track {
  animation-play-state: paused;
}
.gb-promo-item {
  white-space: nowrap;
  flex-shrink: 0;
}
@keyframes gb-promo-marquee {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
@media (prefers-reduced-motion: reduce) {
  .gb-promo-track { animation: none; }
  .gb-promo { overflow-x: auto; -webkit-overflow-scrolling: touch; }
}
@media (max-width: 768px) {
  .gb-promo { font-size: 11px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "GB · Home Promo",
  "tag": "section",
  "class": "gb-promo-wrap",
  "settings": [
    { "type": "range", "id": "scroll_duration", "label": "Scroll duration (seconds)", "min": 10, "max": 90, "step": 2, "default": 38 }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Promo item",
      "limit": 24,
      "settings": [
        { "type": "text", "id": "text", "label": "Item text", "default": "📦 Free shipping over ₹300" }
      ]
    }
  ],
  "presets": [
    {
      "name": "GB · Home Promo",
      "blocks": [
        { "type": "item", "settings": { "text": "📦 Free shipping over ₹300" } },
        { "type": "item", "settings": { "text": "⚡ Ships next working day" } },
        { "type": "item", "settings": { "text": "🇮🇳 Made in India" } },
        { "type": "item", "settings": { "text": "💸 Cash on delivery" } },
        { "type": "item", "settings": { "text": "✓ FSSAI verified · 10021021000439" } },
        { "type": "item", "settings": { "text": "💬 Join the Ferment Forum" } },
