{%- render 'leo_kit_chrome' -%}

{%- liquid
  assign p = product
  assign mf_faqs = p.metafields.custom.featured_faqs.value
  assign mf_faq_h = p.metafields.custom.faq_h
  assign faq_blocks = section.blocks | where: 'type', 'faq'
  assign has_mf = false
  if mf_faqs and mf_faqs.size > 0
    assign has_mf = true
  endif
-%}

{%- if has_mf or faq_blocks.size > 0 -%}
  <section class="faq-section ferment-pdp-leo" {%- render 'leo_kit_attrs' -%}>
    <div class="container">
      <div class="section-header centered">
        <div class="eyebrow">{{ section.settings.faq_eyebrow }}</div>
        {%- if mf_faq_h != blank -%}
          <h2>{{ mf_faq_h }}</h2>
        {%- else -%}
          <h2>{{ section.settings.faq_heading }} <em>{{ section.settings.faq_heading_em }}</em></h2>
        {%- endif -%}
      </div>
      <div class="faq-list">
        {%- if has_mf -%}
          {%- for f in mf_faqs -%}
            <div class="faq-item {% if forloop.first %}open{% endif %}" data-faq>
              <div class="faq-q"><span>{{ f.question }}</span><span class="faq-toggle">+</span></div>
              <div class="faq-a">{{ f.answer | newline_to_br }}</div>
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for block in faq_blocks -%}
            <div class="faq-item {% if forloop.first %}open{% endif %}" data-faq {{ block.shopify_attributes }}>
              <div class="faq-q"><span>{{ block.settings.question }}</span><span class="faq-toggle">+</span></div>
              <div class="faq-a">{{ block.settings.answer }}</div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Leo · FAQ",
  "tag": "section",
  "class": "leo-faq-section",
  "settings": [
    {
      "type": "text",
      "id": "faq_eyebrow",
      "label": "Eyebrow",
      "default": "QUESTIONS?"
    },
    {
      "type": "text",
      "id": "faq_heading",
      "label": "Heading",
      "default": "COMMON"
    },
    {
      "type": "text",
      "id": "faq_heading_em",
      "label": "Heading (highlighted)",
      "default": "QUESTIONS"
    },
    {
      "type": "header",
      "content": "Spacing & Typography"
    },
    {
      "type": "range",
      "id": "pad_top_d",
      "label": "Padding top — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_bot_d",
      "label": "Padding bottom — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_top_m",
      "label": "Padding top — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "pad_bot_m",
      "label": "Padding bottom — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "mar_top_d",
      "label": "Margin top — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_d",
      "label": "Margin bottom — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_top_m",
      "label": "Margin top — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_m",
      "label": "Margin bottom — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "eyebrow_size_d",
      "label": "Eyebrow font size — desktop (px)",
      "min": 9,
      "max": 32,
      "step": 1,
      "default": 22
    },
    {
      "type": "range",
      "id": "eyebrow_size_m",
      "label": "Eyebrow font size — mobile (px)",
      "min": 9,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "heading_size_d",
      "label": "Heading font size — desktop (px)",
      "min": 18,
      "max": 80,
      "step": 2,
      "default": 44
    },
    {
      "type": "range",
      "id": "heading_size_m",
      "label": "Heading font size — mobile (px)",
      "min": 16,
      "max": 60,
      "step": 2,
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "limit": 20,
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Leo · FAQ"
    }
  ]
}
{% endschema %}
