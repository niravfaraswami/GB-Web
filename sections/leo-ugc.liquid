{%- render 'leo_kit_chrome' -%}

{%- liquid
  assign p = product
  assign mf_reviews = p.metafields.custom.featured_reviews.value
  assign ugc_blocks = section.blocks | where: 'type', 'ugc_review'
  assign has_mf = false
  if mf_reviews and mf_reviews.size > 0
    assign has_mf = true
  endif
-%}

{%- if has_mf or ugc_blocks.size > 0 -%}
  <section class="reviews-section ferment-pdp-leo" data-leo="1" {%- render 'leo_kit_attrs' -%}>
    <div class="container">
      <div class="section-header centered">
        <div class="eyebrow">{{ section.settings.eyebrow }}</div>
        <h2>{{ section.settings.heading }} <em>{{ section.settings.heading_em }}</em></h2>
      </div>
      <div class="ugc-grid">
        {%- if has_mf -%}
          {%- for r in mf_reviews -%}
            <div class="ugc-card">
              <div class="ugc-card-photo">
                {%- if r.photo != blank -%}<img src="{{ r.photo | image_url: width: 800 }}" alt="{{ r.name | escape }}" loading="lazy" width="600" height="800">{%- endif -%}
              </div>
              <div class="ugc-card-text">
                <div class="ugc-card-quote">{{ r.quote }}</div>
                <div class="ugc-card-name">{{ r.name }}</div>
                {%- if r.meta != blank -%}<div class="ugc-card-age">{{ r.meta }}</div>{%- endif -%}
              </div>
              <div class="ugc-card-spacer"></div>
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for block in ugc_blocks -%}
            <div class="ugc-card" {{ block.shopify_attributes }}>
              <div class="ugc-card-photo">
                {%- if block.settings.photo != blank -%}<img src="{{ block.settings.photo | image_url: width: 800 }}" alt="{{ block.settings.name | escape }}" loading="lazy" width="600" height="800">{%- endif -%}
              </div>
              <div class="ugc-card-text">
                <div class="ugc-card-quote">{{ block.settings.quote }}</div>
                <div class="ugc-card-name">{{ block.settings.name }}</div>
                {%- if block.settings.meta != blank -%}<div class="ugc-card-age">{{ block.settings.meta }}</div>{%- endif -%}
              </div>
              <div class="ugc-card-spacer"></div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Leo · UGC Reviews",
  "tag": "section",
  "class": "leo-ugc-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "REAL RESULTS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WHAT OUR"
    },
    {
      "type": "text",
      "id": "heading_em",
      "label": "Heading (highlighted)",
      "default": "CUSTOMERS SAY"
    },
    {
      "type": "header",
      "content": "Spacing & Typography"
    },
    {
      "type": "range",
      "id": "pad_top_d",
      "label": "Padding top — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_bot_d",
      "label": "Padding bottom — desktop (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_top_m",
      "label": "Padding top — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "pad_bot_m",
      "label": "Padding bottom — mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "mar_top_d",
      "label": "Margin top — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_d",
      "label": "Margin bottom — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_top_m",
      "label": "Margin top — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bot_m",
      "label": "Margin bottom — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "eyebrow_size_d",
      "label": "Eyebrow font size — desktop (px)",
      "min": 9,
      "max": 32,
      "step": 1,
      "default": 22
    },
    {
      "type": "range",
      "id": "eyebrow_size_m",
      "label": "Eyebrow font size — mobile (px)",
      "min": 9,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "heading_size_d",
      "label": "Heading font size — desktop (px)",
      "min": 18,
      "max": 80,
      "step": 2,
      "default": 44
    },
    {
      "type": "range",
      "id": "heading_size_m",
      "label": "Heading font size — mobile (px)",
      "min": 16,
      "max": 60,
      "step": 2,
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "ugc_review",
      "name": "UGC review card",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Photo"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name"
        },
        {
          "type": "text",
          "id": "meta",
          "label": "Meta (e.g. age)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Leo · UGC Reviews"
    }
  ]
}
{% endschema %}
